diff --git a/src/vs/workbench/browser/parts/remotePairPrune.ts b/src/vs/workbench/browser/parts/remotePairPrune.ts
new file mode 100644
index 00000000..c83d707e
--- /dev/null
+++ b/src/vs/workbench/browser/parts/remotePairPrune.ts
@@ -0,0 +1,37 @@
+/*---------------------------------------------------------------------------------------------
+ *  RemotePair: UI prune allowlists.
+ *
+ *  We hide IDE surfaces the RemotePair user does not need, but we KEEP the underlying code
+ *  registered (rebase-safety) and only filter what the composite bars actually show. This
+ *  mirrors the left-rail allowlist in `activitybar/activitybarPart.ts`
+ *  (`ActivityBarCompositeBar.getViewContainers()` override) and applies the same idea to the
+ *  bottom panel and the secondary side bar (auxiliary bar).
+ *
+ *  Net effect:
+ *   - Bottom panel: native Problems / Output / Debug Console / Terminal / Ports tabs are hidden.
+ *     Only RemotePair-owned containers (e.g. the session-manager added in a later goal) remain.
+ *   - Auxiliary bar: the native CHAT / "Build with Agent" panel is hidden.
+ *--------------------------------------------------------------------------------------------*/
+
+import { ViewContainer } from '../../common/views.js';
+
+/** A view container owned by RemotePair (the only kind we keep in pruned composite bars). */
+function isRemotePairOwned(id: string): boolean {
+	return id.startsWith('remotepair') || id.startsWith('workbench.view.remotepair');
+}
+
+/**
+ * Containers allowed in the bottom panel composite bar. Native panels stay registered but are
+ * filtered out of the bar so they never surface; RemotePair-owned containers pass through.
+ */
+export function isRemotePairPanelContainerAllowed(container: ViewContainer): boolean {
+	return isRemotePairOwned(container.id);
+}
+
+/**
+ * Containers allowed in the secondary side bar (auxiliary bar) composite bar. The native CHAT /
+ * "Build with Agent" container is filtered out; RemotePair-owned containers pass through.
+ */
+export function isRemotePairAuxBarContainerAllowed(container: ViewContainer): boolean {
+	return isRemotePairOwned(container.id);
+}
