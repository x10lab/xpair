+		const instance = input instanceof TerminalEditorInput ? input.terminalInstance : undefined;
+
+		if (instance) {
+			this.activeTitleListener.value = instance.onTitleChanged(() => {
+				this.updateTitle(instance.title || RemotePairTerminalSidebarView.DEFAULT_TITLE);
+			});
+			this.updateTitle(instance.title || RemotePairTerminalSidebarView.DEFAULT_TITLE);
+		} else {
+			this.activeTitleListener.clear();
+			this.updateTitle(RemotePairTerminalSidebarView.DEFAULT_TITLE);
+		}
+	}
