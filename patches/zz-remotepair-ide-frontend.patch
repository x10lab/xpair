+/*---------------------------------------------------------------------------------------------
+ *  RemotePair: bottom-panel session tabs. Three Panel view containers — Attached / Detached /
+ *  History — each surfaced as a horizontal TAB in the bottom-panel composite bar (exactly like
+ *  the native Problems / Output / Terminal tabs). Selecting a tab switches the shown content.
+ *  Each tab renders ONLY its own category as a single horizontally-scrollable row of cards.
+ *
+ *  - Attached cards come from the Sessions sidebar's embedded EditorPart (sourced via
+ *    `setAttachedSessionsProvider`). The sidebar tracks its own terminals because they are
+ *    created through the low-level ITerminalInstanceService path (S0 reverse-leak isolation)
+ *    and therefore never appear in ITerminalService.instances. ITerminalService.instances is
+ *    kept as a fallback when no provider is registered (dev reload, future uses).
+ *  - Detached / History cards come from a pluggable `SessionDataProvider` (default empty),
+ *    so the renderer never has to child_process. Click a card → reattach the session into
+ *    the Sessions sidebar via the `setSessionReattacher` module hook.
+ *
+ *  Hosting-layer only — it never touches core terminal behavior.
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize, localize2 } from '../../../../nls.js';
+import { $, append, clearNode, addDisposableListener, EventType } from '../../../../base/browser/dom.js';
+import { StandardKeyboardEvent } from '../../../../base/browser/keyboardEvent.js';
+import { KeyCode } from '../../../../base/common/keyCodes.js';
+import { Emitter, Event } from '../../../../base/common/event.js';
+import { DisposableStore } from '../../../../base/common/lifecycle.js';
+import { SyncDescriptor } from '../../../../platform/instantiation/common/descriptors.js';
+import { IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';
+import { IThemeService } from '../../../../platform/theme/common/themeService.js';
+import { IConfigurationService } from '../../../../platform/configuration/common/configuration.js';
+import { IStorageService, StorageScope, StorageTarget } from '../../../../platform/storage/common/storage.js';
+import { IContextKeyService } from '../../../../platform/contextkey/common/contextkey.js';
+import { IKeybindingService } from '../../../../platform/keybinding/common/keybinding.js';
+import { IContextMenuService } from '../../../../platform/contextview/browser/contextView.js';
+import { IOpenerService } from '../../../../platform/opener/common/opener.js';
+import { IHoverService } from '../../../../platform/hover/browser/hover.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { ViewPane, IViewPaneOptions } from '../../../browser/parts/views/viewPane.js';
+import { IViewDescriptor, IViewDescriptorService, IViewsRegistry, IViewContainersRegistry, Extensions as ViewContainerExtensions, ViewContainerLocation } from '../../../common/views.js';
+import { ViewPaneContainer } from '../../../browser/parts/views/viewPaneContainer.js';
+import { ITerminalService } from './terminal.js';
+import { ITerminalInstance } from './terminal.js';
+
+// Container ids MUST start with `remotepair` so they pass the G003 panel allowlist
+// (isRemotePairPanelContainerAllowed in remotePairPrune.ts → id.startsWith('remotepair')).
+export const REMOTEPAIR_SESSIONS_ATTACHED_ID = 'remotepair.sessions.attached';
+export const REMOTEPAIR_SESSIONS_DETACHED_ID = 'remotepair.sessions.detached';
+export const REMOTEPAIR_SESSIONS_HISTORY_ID = 'remotepair.sessions.history';
+
+/** Which session category a `RemotePairSessionCategoryView` renders. */
+export type SessionCategory = 'attached' | 'detached' | 'history';
+
+// --- module hooks -----------------------------------------------------------
+
+/**
+ * A single entry in the Attached tab: a terminal the Sessions sidebar currently hosts.
+ * The id is `instance.resource.toString()` so reveal can look it up in the sidebar map.
+ */
+export interface AttachedSessionInfo {
+	id: string;
+	title: string;
+}
+
+/**
+ * Implemented by `RemotePairTerminalSidebarView` and registered via
+ * `setAttachedSessionsProvider`. Provides the Attached tab's data and the reveal action.
+ * Separate from `ITerminalService.instances` because the sidebar creates terminals through
+ * the low-level ITerminalInstanceService path (S0 isolation) that bypasses the service.
+ */
+export interface AttachedSessionsProvider {
+	getAttached(): readonly AttachedSessionInfo[];
+	reveal(id: string): void;
+	/** Close (dispose) the attached session identified by `id`. Optional → default no-op. */
+	close?(id: string): void;
+	/** The id of the currently-active attached session, if known. Optional → default undefined. */
+	getActiveId?(): string | undefined;
+}
+
+const attachedChangeEmitter = new Emitter<void>();
+/** Fires whenever the sidebar's set of attached sessions changes (open / close / rename). */
+export const onDidChangeAttachedSessions: Event<void> = attachedChangeEmitter.event;
+
+let attachedProvider: AttachedSessionsProvider | undefined;
+export function setAttachedSessionsProvider(p: AttachedSessionsProvider): void {
+	attachedProvider = p;
+	attachedChangeEmitter.fire();
+}
+/** Called by the sidebar whenever its attached set changes; triggers an Attached-tab refresh. */
+export function notifyAttachedSessionsChanged(): void { attachedChangeEmitter.fire(); }
+
+/**
+ * Provides the Detached/History session-name lists for the manager. The core renderer
+ * cannot child_process (`remote-pair ls`), so the host/extension layer registers a
+ * provider best-effort. Defaults to empty (dev: no host) → tabs render an empty state.
+ */
+export interface SessionDataProvider {
+	/** Host/local sessions that exist but are NOT currently attached. */
+	getDetached(): readonly string[];
+	/** Previously-seen session names that are no longer live. */
+	getHistory(): readonly string[];
+}
+
+let dataProvider: SessionDataProvider | undefined;
+export function setSessionDataProvider(provider: SessionDataProvider): void { dataProvider = provider; }
+
+/** Reattach a session by name into the Sessions sidebar (wired by the sidebar view). */
+export type SessionReattacher = (name: string) => void;
+
+let reattacher: SessionReattacher | undefined;
+export function setSessionReattacher(fn: SessionReattacher): void { reattacher = fn; }
+
+function reattach(name: string): void {
+	reattacher?.(name);
+}
+
+// --- view -------------------------------------------------------------------
+
+const HISTORY_STORAGE_KEY = 'remotepair.sessionManager.history';
+
+/**
+ * Shared Panel ViewPane rendering ONE session category (attached / detached / history) as a
+ * single horizontally-scrollable row of cards. The category is supplied per-container by a thin
+ * subclass (`category` getter), so the same body logic backs all three bottom-panel tabs.
+ */
+export abstract class RemotePairSessionCategoryView extends ViewPane {
+
+	/** The category this view renders. Supplied by the concrete subclass per container. */
+	protected abstract get category(): SessionCategory;
+
+	private row: HTMLElement | undefined;
+
+	// Per-render card listener store, cleared at the top of each render so click/keydown
+	// listeners do not accumulate across the (frequent) re-renders.
+	private readonly cardDisposables = this._register(new DisposableStore());
+
+	constructor(
+		options: IViewPaneOptions,
+		@IKeybindingService keybindingService: IKeybindingService,
+		@IContextMenuService contextMenuService: IContextMenuService,
+		@IConfigurationService configurationService: IConfigurationService,
+		@IContextKeyService contextKeyService: IContextKeyService,
+		@IViewDescriptorService viewDescriptorService: IViewDescriptorService,
+		@IInstantiationService instantiationService: IInstantiationService,
+		@IOpenerService openerService: IOpenerService,
+		@IThemeService themeService: IThemeService,
+		@IHoverService hoverService: IHoverService,
+		@ITerminalService private readonly terminalService: ITerminalService,
+		@IStorageService private readonly storageService: IStorageService
+	) {
+		super(options, keybindingService, contextMenuService, configurationService, contextKeyService, viewDescriptorService, instantiationService, openerService, themeService, hoverService);
+	}
+
+	protected override renderBody(container: HTMLElement): void {
+		super.renderBody(container);
+
+		container.classList.add('remotepair-session-manager');
+		this.row = append(container, $('.remotepair-session-row'));
+
+		if (this.category === 'attached') {
+			// Primary: refresh when the Sessions sidebar's attached-sessions set changes.
+			this._register(onDidChangeAttachedSessions(() => this.refresh()));
+			// Fallback: also react to ITerminalService.instances for any other terminal sources.
+			this._register(this.terminalService.onDidChangeInstances(() => this.refresh()));
+		}
+
+		this.refresh();
+	}
+
+	private refresh(): void {
+		switch (this.category) {
+			case 'attached': this.renderAttached(); return;
+			case 'detached': this.renderDetached(); return;
+			case 'history': this.renderHistory(); return;
+		}
+	}
+
+	/** Append a clickable tab to the row. Each tab is a label span + a native-style close "X".
+	 *  Listeners go on `cardDisposables` (cleared per render). When `active` is set the tab gets
+	 *  the `.remotepair-session-card-active` highlight; when `onClose` is set the X disposes it. */
+	private addCard(text: string, onClick: () => void, opts?: { active?: boolean; onClose?: () => void }): void {
+		const row = this.row!;
+		const card = append(row, $('.remotepair-session-card'));
+		if (opts?.active) {
+			card.classList.add('remotepair-session-card-active');
+		}
+		card.title = text;
+		card.setAttribute('role', 'button');
+		card.setAttribute('tabindex', '0');
+		const label = append(card, $('.remotepair-session-card-label'));
+		label.textContent = text;
+		this.cardDisposables.add(addDisposableListener(card, EventType.CLICK, onClick));
+		this.cardDisposables.add(addDisposableListener(card, EventType.KEY_DOWN, (e) => {
+			const k = new StandardKeyboardEvent(e as KeyboardEvent);
+			if (k.equals(KeyCode.Enter) || k.equals(KeyCode.Space)) { k.preventDefault(); onClick(); }
+		}));
+		if (opts?.onClose) {
+			const onClose = opts.onClose;
+			const close = append(card, $('.remotepair-session-card-close.codicon.codicon-close'));
+			close.title = localize('remotepairCloseSession', "Close Session");
+			close.setAttribute('role', 'button');
+			// stopPropagation so closing does not also fire the card's reveal/reattach click.
+			this.cardDisposables.add(addDisposableListener(close, EventType.CLICK, (e) => {
+				e.stopPropagation();
+				onClose();
+			}));
+		}
+	}
+
+	/** Append a non-actionable (display-only) tab — used for History entries that are not
+	 *  reattachable (persisted titles, not real session names). The X removes the entry from the
+	 *  persisted history when `onClose` is supplied. */
+	private addDisplayCard(text: string, onClose?: () => void): void {
+		const card = append(this.row!, $('.remotepair-session-card.remotepair-session-card-readonly'));
+		card.title = text;
+		const label = append(card, $('.remotepair-session-card-label'));
+		label.textContent = text;
+		if (onClose) {
+			const close = append(card, $('.remotepair-session-card-close.codicon.codicon-close'));
+			close.title = localize('remotepairRemoveHistory', "Remove from History");
+			close.setAttribute('role', 'button');
+			this.cardDisposables.add(addDisposableListener(close, EventType.CLICK, (e) => {
+				e.stopPropagation();
+				onClose();
+			}));
+		}
+	}
+
+	/** Render an empty-state message in the row. */
+	private addEmpty(text: string): void {
+		const empty = append(this.row!, $('.remotepair-session-empty'));
+		empty.textContent = text;
+	}
+
+	private renderAttached(): void {
+		const row = this.row;
+		if (!row) {
+			return;
+		}
+		clearNode(row);
+		this.cardDisposables.clear();
+
+		if (attachedProvider) {
+			// Primary source: the Sessions sidebar tracks its own terminals (S0 isolation means
+			// those instances never appear in ITerminalService.instances).
+			const provider = attachedProvider;
+			const sessions = provider.getAttached();
+			this.recordHistory(sessions.map(s => s.title));
+			if (sessions.length === 0) {
+				this.addEmpty(localize('remotepairNoAttached', "No attached sessions"));
+				return;
+			}
+			const activeId = provider.getActiveId?.();
+			for (const session of sessions) {
+				this.addCard(session.title, () => provider.reveal(session.id), {
+					active: !!activeId && session.id === activeId,
+					onClose: provider.close ? () => provider.close!(session.id) : undefined,
+				});
+			}
+		} else {
+			// Fallback: read from ITerminalService for any other terminal sources.
+			const instances = this.terminalService.instances;
+			this.recordHistory(instances.map(i => i.title));
+			if (instances.length === 0) {
+				this.addEmpty(localize('remotepairNoAttached', "No attached sessions"));
+				return;
+			}
+			const active = this.terminalService.activeInstance;
+			for (const instance of instances) {
+				this.addCard(instance.title, () => this.focusInstance(instance), {
+					active: !!active && instance === active,
+					onClose: () => { try { instance.dispose(); } catch { /* best-effort */ } },
+				});
+			}
+		}
+	}
+
+	private renderDetached(): void {
+		const row = this.row;
+		if (!row) {
+			return;
+		}
+		clearNode(row);
+		this.cardDisposables.clear();
+		const names = dataProvider?.getDetached() ?? [];
+		if (names.length === 0) {
+			this.addEmpty(localize('remotepairNoDetached', "No detached sessions"));
+			return;
+		}
+		for (const name of names) {
+			this.addCard(name, () => reattach(name));
+		}
+	}
+
+	private renderHistory(): void {
+		const row = this.row;
+		if (!row) {
+			return;
+		}
+		clearNode(row);
+		this.cardDisposables.clear();
+		// Live provider names are real, reattachable session names → clickable.
+		const providerNames = dataProvider?.getHistory();
+		if (providerNames && providerNames.length > 0) {
+			for (const name of providerNames) {
+				this.addCard(name, () => reattach(name));
+			}
+			return;
+		}
+		// Fallback: the persisted last-seen set holds display TITLES (e.g. "zsh"), which are not
+		// valid `remote-pair attach` names — render them display-only rather than wiring a reattach
+		// that would silently fail.
+		const persisted = this.readHistory();
+		if (persisted.length === 0) {
+			this.addEmpty(localize('remotepairNoHistory', "No history"));
+			return;
+		}
+		for (const name of persisted) {
+			this.addDisplayCard(name, () => this.removeHistory(name));
+		}
+	}
+
+	/** Reveal/focus a live terminal session (best-effort, public APIs only). */
+	private focusInstance(instance: ITerminalInstance): void {
+		try {
+			this.terminalService.setActiveInstance(instance);
+			instance.focus(true);
+		} catch (e) {
+			// best-effort
+		}
+	}
+
+	// --- history persistence (workspace scope) -----------------------------
+
+	private readHistory(): string[] {
+		const raw = this.storageService.get(HISTORY_STORAGE_KEY, StorageScope.WORKSPACE);
+		if (!raw) {
+			return [];
+		}
+		try {
+			const parsed = JSON.parse(raw);
+			return Array.isArray(parsed) ? parsed.filter((n): n is string => typeof n === 'string') : [];
+		} catch (e) {
+			return [];
+		}
+	}
+
+	/** Merge newly-seen names into the persisted last-seen set, then refresh the History tab.
+	 *  Skips empty/generic titles (e.g. the "Session" fallback) which carry no useful history. */
+	private recordHistory(names: readonly string[]): void {
+		const meaningful = names.filter(n => !!n && n.trim() !== '' && n !== 'Session');
+		if (meaningful.length === 0) {
+			return;
+		}
+		const existing = this.readHistory();
+		const merged = Array.from(new Set([...existing, ...meaningful]));
+		if (merged.length === existing.length) {
+			return; // nothing new
+		}
+		this.storageService.store(HISTORY_STORAGE_KEY, JSON.stringify(merged), StorageScope.WORKSPACE, StorageTarget.MACHINE);
+		// Only the History view owns the History row; re-render it if that's us.
+		if (this.category === 'history') {
+			this.renderHistory();
+		}
+	}
+
+	/** Drop a single name from the persisted last-seen set (the History tab's X), then re-render. */
+	private removeHistory(name: string): void {
+		const existing = this.readHistory();
+		const next = existing.filter(n => n !== name);
+		if (next.length === existing.length) {
+			return; // not present
+		}
+		this.storageService.store(HISTORY_STORAGE_KEY, JSON.stringify(next), StorageScope.WORKSPACE, StorageTarget.MACHINE);
+		if (this.category === 'history') {
+			this.renderHistory();
+		}
+	}
+}
+
+/** Attached tab view. */
+class RemotePairAttachedSessionsView extends RemotePairSessionCategoryView {
+	protected get category(): SessionCategory { return 'attached'; }
+}
+/** Detached tab view. */
+class RemotePairDetachedSessionsView extends RemotePairSessionCategoryView {
+	protected get category(): SessionCategory { return 'detached'; }
+}
+/** History tab view. */
+class RemotePairHistorySessionsView extends RemotePairSessionCategoryView {
+	protected get category(): SessionCategory { return 'history'; }
+}
+
+// --- registration: three bottom-panel tabs (one Panel container each) --------
+
+const viewContainerRegistry = Registry.as<IViewContainersRegistry>(ViewContainerExtensions.ViewContainersRegistry);
+const viewsRegistry = Registry.as<IViewsRegistry>(ViewContainerExtensions.ViewsRegistry);
+
+/** Register one Panel view container (a tab) hosting a single category view.
+ *  `title` must be a statically-keyed localize2() result (the NLS build analyzer cannot parse a
+ *  dynamic localize key such as localize2(id, ...) — that fails the production build). */
+function registerSessionTab(id: string, title: ReturnType<typeof localize2>, order: number, ctor: new (...args: any[]) => RemotePairSessionCategoryView): void {
+	const container = viewContainerRegistry.registerViewContainer({
+		id,
+		title,
+		ctorDescriptor: new SyncDescriptor(ViewPaneContainer, [id, { mergeViewWithContainerWhenSingleView: true }]),
+		storageId: id,
+		hideIfEmpty: false,
+		order,
+	}, ViewContainerLocation.Panel, { isDefault: false });
+
+	const viewDescriptor: IViewDescriptor = {
+		id: id + '.view',
+		name: title,
+		ctorDescriptor: new SyncDescriptor(ctor),
+		canToggleVisibility: false,
+		canMoveView: false,
+	};
+	viewsRegistry.registerViews([viewDescriptor], container);
+}
+
+registerSessionTab(REMOTEPAIR_SESSIONS_ATTACHED_ID, localize2('remotepairAttached', "Attached"), 1, RemotePairAttachedSessionsView);
+registerSessionTab(REMOTEPAIR_SESSIONS_DETACHED_ID, localize2('remotepairDetached', "Detached"), 2, RemotePairDetachedSessionsView);
+registerSessionTab(REMOTEPAIR_SESSIONS_HISTORY_ID, localize2('remotepairHistory', "History"), 3, RemotePairHistorySessionsView);
