+		});
+	}
+	async run(accessor: ServicesAccessor): Promise<void> {
+		const viewsService = accessor.get(IViewsService);
+		// Make the Sessions sidebar visible so the embedded EditorPart is constructed.
+		const view = await viewsService.openView(REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view', false);
+		if (view instanceof RemotePairTerminalSidebarView) {
+			view.stageBrowserCommand('remote-pair map add ');
+		}
+	}
+});
