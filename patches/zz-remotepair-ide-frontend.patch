+	protected override renderBody(container: HTMLElement): void {
+		super.renderBody(container);
+
+		container.classList.add('remotepair-terminal-sidebar');
+
+		// G002: "+" New Session button (top-right of the Sessions body). The embedded
+		// EditorPart occupies the view title-action area, so a MenuId.ViewTitle action does
+		// not render here; we own this button instead and call openSessionPicker().
+		const addBtn = append(container, $('.remotepair-sessions-add', undefined, '+'));
+		addBtn.title = localize('remotepairNewSessionTitle', "New Session");
+		addBtn.setAttribute('role', 'button');
+		addBtn.setAttribute('tabindex', '0');
+		this._register(addDisposableListener(addBtn, EventType.CLICK, () => this.openSessionPicker()));
+		this._register(addDisposableListener(addBtn, EventType.KEY_DOWN, (e) => {
+			const k = new StandardKeyboardEvent(e as KeyboardEvent);
+			if (k.equals(KeyCode.Enter) || k.equals(KeyCode.Space)) { k.preventDefault(); this.openSessionPicker(); }
+		}));
+
+		// Defer the embedded EditorPart creation OUT of the synchronous composite-open
+		// path. renderBody runs inside compositePart.doOpenComposite → createComposite;
+		// instantiating a full EditorPart (with its own grid/group/editor + events) there
+		// re-enters the composite machinery so the sidebar's `activeComposite` never
+		// settles on Sessions. That marks the pane-composite-part `.empty`, and the
+		// full-height empty-pane-message (paneCompositePart.ts:615) shoves our viewlet off
+		// the bottom of the sidebar → blank. Building the part on the next frame lets
+		// doOpenComposite finish (activeComposite = Sessions) first.
+		this.partDisposables.add(scheduleAtNextAnimationFrame(getWindow(container), () => this.createEmbeddedPart(container)));
+	}
+
+	private createEmbeddedPart(container: HTMLElement): void {
+		if (this.editorPart) {
+			return; // already built (or rebuilt) — avoid duplicates
+		}
+
+		// EditorParts (the IEditorGroupsService impl) also implements IEditorPartsView.
+		const editorPartsView = this.editorGroupsService as unknown as IEditorPartsView;
+
+		// S0 — routing isolation (reverse-leak fix). We deliberately do NOT call
+		// `editorPartsView.registerPart(part)` here. Registration would add this part
+		// to EditorParts._parts and its MRU list, which feeds `getPartByDocument`
+		// (editorParts.ts:329) and `get activeGroup` (editorParts.ts:676). The result:
+		// when the user focuses this sidebar, `activePart`/`activeGroup` would resolve
+		// to the embedded group, so any editor opened with ACTIVE_GROUP (settings,
+		// search results, diffs, welcome) would be sucked into the session sidebar —
+		// the dual of the "main leak". It would also fire global `onDidActiveGroupChange`
+		// on every sidebar click (breadcrumbs/title/active-editor consumers misfire).
+		//
+		// The session sidebar is NOT a first-class editor area (unlike auxiliary
+		// windows, which is why AuxiliaryEditorPart *does* register). Leaving the part
+		// unregistered keeps it invisible to global group queries; we drive it solely
+		// via `part.activeGroup.openEditor` on the part instance, which is part-local
+		// and registration-independent. `groupsLabel`/`count` come from the part's own
+		// fields, so group construction still works standalone.
+		// CRITICAL: the editor-group layout CSS (editorgroupview.css) is scoped to
+		// `.monaco-workbench .part.editor > .content ...`. The main editor part gets the
+		// `.part .editor` classes from the workbench grid; an embedded part does not, so
+		// without these classes NONE of the group/grid/title/watermark layout rules apply
+		// → the grid container collapses to 0, the group's children fall back to static
+		// flow, the empty watermark stays in-flow, and the editor/terminal renders blank.
+		// `createContentArea` sets `this.element = parent` (this container) and appends the
+		// `.content` directly under it, so tagging the container `.part.editor` makes
+		// `.part.editor > .content` match and the editor renders correctly.
+		container.classList.add('part', 'editor');
+
+		const part = this.instantiationService.createInstance(EmbeddedEditorPart, editorPartsView);
+		this.partDisposables.add(part);
+		part.create(container);
+
+		this.editorPart = part;
+
+		// Blank-fix: drive the embedded part's visibility from the ViewPane body.
+		// Editor panes (including TerminalEditor/xterm) only attach and size when their
+		// group is told it is visible: EditorPart.setVisible → onDidVisibilityChange →
+		// EditorGroupView.onDidVisibilityChange (editorGroupView.ts:868) →
+		// editorPane.setVisible → TerminalEditor.setVisible (terminalEditor.ts:172) →
+		// terminalInstance.setVisible. An embedded part has nobody to drive this, so the
+		// xterm opens at 0×0 and stays blank. Wire it to the pane's own visibility.
+		this.partDisposables.add(this.onDidChangeBodyVisibility(visible => part.setVisible(visible)));
+		part.setVisible(this.isBodyVisible());
+
+		// Lay out immediately with the last known body size (layoutBody may have already
+		// run while the part did not yet exist).
+		if (this.lastWidth > 0 && this.lastHeight > 0) {
+			part.layout(this.lastWidth, this.lastHeight, 0, 0);
+		}
+
+		// Keep the header title in sync with the active session, swapping the
+		// per-group subscription whenever the embedded part's active group changes.
+		this.partDisposables.add(part.onDidChangeActiveGroup(group => this.trackActiveGroup(group)));
+		this.trackActiveGroup(part.activeGroup);
+
+		// Mount an initial terminal so the embedded part shows a terminal editor tab.
+		this.mountTerminal();
+	}
+
+	protected override layoutBody(height: number, width: number): void {
+		super.layoutBody(height, width);
+		this.lastWidth = width;
+		this.lastHeight = height;
+		this.editorPart?.layout(width, height, 0, 0);
+	}
+
+	/**
+	 * Route focus into the embedded editor's active group so that focusing the
+	 * Sessions view (rail click, Cmd+focus, view activation) lands keyboard focus
+	 * on the active session editor (e.g. the terminal) instead of an empty pane
+	 * container. Hosting-layer only — delegates to the group's own focus(); does
+	 * not touch core terminal behavior.
+	 */
+	override focus(): void {
+		super.focus();
+		this.editorPart?.activeGroup?.focus();
+	}
+
+	override dispose(): void {
+		this.partDisposables.dispose();
+		this.editorPart = undefined;
+		super.dispose();
+	}
+}
