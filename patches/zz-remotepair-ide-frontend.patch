+		const part = this.editorPart;
+		if (!part) {
+			return;
+		}
+		// `whenReady` resolves once the grid + initial group exist (synchronously
+		// after `create()` in the common case); guarding it avoids a missing group.
+		part.whenReady.then(() => {
+			if (this.editorPart !== part) {
+				return; // disposed/recreated in the meantime
+			}
+			const group = part.activeGroup;
+			if (!group) {
+				return;
+			}
+			try {
+				// Use the shared helper so this auto-mounted terminal is also tracked in
+				// the attached map (and the Session Manager Attached row reflects it).
+				const { opened } = this.openTerminalInGroup(group);
+				opened.then(() => {
+					// Blank-fix (timing): push visibility + relayout now that the group and
+					// terminal editor actually exist. Part.setVisible only *fires* an event
+					// and EditorGroupView reacts to future events only, so the setVisible in
+					// renderBody (before any group exists) was missed → xterm stayed hidden at
