@@ -0,0 +1,104 @@
+/*---------------------------------------------------------------------------------------------
+ *  RemotePair: in-tab "New Session" picker editor.
+ *
+ *  The Sessions sidebar "+" opens this as an empty editor tab inside the embedded
+ *  EditorPart group. Clicking a card asks the registered launcher to start that session
+ *  kind in the same group and close this picker tab. Hosting-layer only — it never
+ *  touches core terminal behavior (it only drives ITerminalInstance/group public APIs
+ *  via the launcher registered by the Sessions view).
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize } from '../../../../nls.js';
+import { $, append, Dimension, addDisposableListener, EventType } from '../../../../base/browser/dom.js';
+import { StandardKeyboardEvent } from '../../../../base/browser/keyboardEvent.js';
+import { KeyCode } from '../../../../base/common/keyCodes.js';
+import { URI } from '../../../../base/common/uri.js';
+import { CancellationToken } from '../../../../base/common/cancellation.js';
+import { EditorInputCapabilities, IEditorOpenContext, IUntypedEditorInput } from '../../../common/editor.js';
+import { EditorInput } from '../../../common/editor/editorInput.js';
+import { EditorPane } from '../../../browser/parts/editor/editorPane.js';
+import { IEditorGroup } from '../../../services/editor/common/editorGroupsService.js';
+import { IEditorOptions } from '../../../../platform/editor/common/editor.js';
+import { ITelemetryService } from '../../../../platform/telemetry/common/telemetry.js';
+import { IThemeService } from '../../../../platform/theme/common/themeService.js';
+import { IStorageService } from '../../../../platform/storage/common/storage.js';
+
+export type SessionKind = 'claude' | 'shell' | 'codex' | 'gemini';
+
+/** Launch a chosen session kind into `group`, then close the picker `pickerInput`. */
+export type SessionLauncher = (kind: SessionKind, group: IEditorGroup, pickerInput: EditorInput) => void;
+
+let launcher: SessionLauncher | undefined;
+export function setSessionLauncher(fn: SessionLauncher): void { launcher = fn; }
+
+export const SESSION_PICKER_RESOURCE = URI.from({ scheme: 'remotepair-session-picker', path: '/new' });
+
+export class SessionPickerInput extends EditorInput {
+	static readonly ID = 'remotepair.sessionPickerInput';
+	override get typeId(): string { return SessionPickerInput.ID; }
+	override get resource(): URI { return SESSION_PICKER_RESOURCE; }
+	override get capabilities(): EditorInputCapabilities { return EditorInputCapabilities.Readonly | EditorInputCapabilities.Singleton; }
+	override getName(): string { return localize('rpNewSession', "New Session"); }
+	override matches(other: EditorInput | IUntypedEditorInput): boolean { return other instanceof SessionPickerInput; }
+}
+
+const PICKER_CARDS: ReadonlyArray<{ kind: SessionKind; label: string; desc: string }> = [
+	{ kind: 'claude', label: 'Claude (remote)', desc: 'mosh + tmux + claude on the host' },
+	{ kind: 'shell', label: 'Shell', desc: 'local zsh' },
+	{ kind: 'codex', label: 'Codex', desc: 'codex CLI' },
+	{ kind: 'gemini', label: 'Gemini', desc: 'gemini CLI' },
+];
+
+export class SessionPickerPane extends EditorPane {
+	static readonly ID = 'remotepair.sessionPickerPane';
+	private root: HTMLElement | undefined;
+
+	constructor(
+		group: IEditorGroup,
+		@ITelemetryService telemetryService: ITelemetryService,
+		@IThemeService themeService: IThemeService,
+		@IStorageService storageService: IStorageService,
+	) {
+		super(SessionPickerPane.ID, group, telemetryService, themeService, storageService);
+	}
+
+	protected createEditor(parent: HTMLElement): void {
+		const root = this.root = append(parent, $('div.remotepair-session-picker'));
+		root.style.cssText = 'height:100%;width:100%;overflow:auto;padding:16px;box-sizing:border-box;display:flex;flex-direction:column;gap:8px;';
+
+		const title = append(root, $('div'));
+		title.textContent = localize('rpPickerTitle', "Start a session");
+		title.style.cssText = 'font-size:13px;font-weight:600;opacity:0.8;margin-bottom:4px;';
+
+		for (const c of PICKER_CARDS) {
+			const card = append(root, $('div'));
+			card.setAttribute('role', 'button');
+			card.setAttribute('tabindex', '0');
+			card.style.cssText = 'border:1px solid var(--vscode-widget-border, rgba(128,128,128,0.35));border-radius:6px;padding:10px 12px;cursor:pointer;background:var(--vscode-editorWidget-background, transparent);';
+			const l = append(card, $('div')); l.textContent = c.label; l.style.cssText = 'font-weight:600;font-size:13px;';
+			const d = append(card, $('div')); d.textContent = c.desc; d.style.cssText = 'font-size:11px;opacity:0.65;margin-top:2px;';
+			const run = () => {
+				const input = this.input;
+				if (launcher && input) {
+					launcher(c.kind, this.group, input);
+				}
+			};
+			this._register(addDisposableListener(card, EventType.CLICK, run));
+			this._register(addDisposableListener(card, EventType.KEY_DOWN, (e) => {
+				const ke = new StandardKeyboardEvent(e as KeyboardEvent);
+				if (ke.equals(KeyCode.Enter) || ke.equals(KeyCode.Space)) { ke.preventDefault(); run(); }
+			}));
+		}
+	}
+
+	override async setInput(input: EditorInput, options: IEditorOptions | undefined, context: IEditorOpenContext, token: CancellationToken): Promise<void> {
+		await super.setInput(input, options, context, token);
+	}
+
+	layout(dimension: Dimension): void {
+		if (this.root) {
+			this.root.style.height = `${dimension.height}px`;
+			this.root.style.width = `${dimension.width}px`;
+		}
+	}
+}
diff --git a/src/vs/workbench/contrib/terminal/browser/remotePairTerminalSidebar.ts b/src/vs/workbench/contrib/terminal/browser/remotePairTerminalSidebar.ts
