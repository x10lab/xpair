+/*---------------------------------------------------------------------------------------------
+ *  RemotePair session tabs: each bottom-panel tab (Attached / Detached / History) renders ONLY
+ *  its own category as a single horizontally-scrolling row of session cards. Since only one
+ *  category shows at a time, the cards are substantial (room to breathe). The panel stays short:
+ *  composite tab bar + one card row fits comfortably in ~90px.
+ *--------------------------------------------------------------------------------------------*/
+
+.monaco-workbench .remotepair-session-manager {
+	display: flex;
+	flex-direction: column;
+	box-sizing: border-box;
+	height: 100%;
+	padding: 8px 12px;
+	overflow: hidden;
+}
+
+/* One horizontally-scrollable row of cards for the active category. */
+.monaco-workbench .remotepair-session-row {
+	display: flex;
+	flex: 1 1 auto;
+	align-items: center;
+	gap: 8px;
+	overflow-x: auto;
+	overflow-y: hidden;
+	padding: 2px 0;
+	/* Thin horizontal scrollbar so the row stays short. */
+	scrollbar-width: thin;
+}
+.monaco-workbench .remotepair-session-row::-webkit-scrollbar { height: 6px; }
+.monaco-workbench .remotepair-session-row::-webkit-scrollbar-thumb { background: var(--vscode-scrollbarSlider-background, rgba(128,128,128,0.4)); border-radius: 3px; }
+
+/* Substantial session cards — only one category shows at a time, so there is room. */
+.monaco-workbench .remotepair-session-card {
+	flex: 0 0 auto;
+	display: flex;
+	align-items: center;
+	box-sizing: border-box;
+	min-width: 120px;
+	max-width: 220px;
+	overflow: hidden;
+	white-space: nowrap;
+	border: 1px solid var(--vscode-widget-border, rgba(128, 128, 128, 0.45));
+	border-radius: 6px;
+	padding: 6px 12px;
+	font-size: 13px;
+	line-height: 18px;
+	cursor: pointer;
+	color: var(--vscode-foreground);
+	background: var(--vscode-editorWidget-background, rgba(128, 128, 128, 0.08));
+	user-select: none;
+}
+
+/* The card label takes the available room and ellipsizes; the close button stays pinned right. */
+.monaco-workbench .remotepair-session-card .remotepair-session-card-label {
+	flex: 1 1 auto;
+	overflow: hidden;
+	text-overflow: ellipsis;
+	white-space: nowrap;
+}
+
+.monaco-workbench .remotepair-session-card:hover,
+.monaco-workbench .remotepair-session-card:focus {
+	background: var(--vscode-toolbar-hoverBackground, rgba(128, 128, 128, 0.2));
+	border-color: var(--vscode-focusBorder, rgba(128, 128, 128, 0.6));
+	outline: none;
+}
+
+/* Active session: the same rounded card, highlighted with a focus-colored outline so the
+ * currently-active session stands out. */
+.monaco-workbench .remotepair-session-card.remotepair-session-card-active {
+	border-color: var(--vscode-focusBorder, rgba(128, 128, 128, 0.6));
+	outline: 1px solid var(--vscode-focusBorder, rgba(128, 128, 128, 0.6));
+	outline-offset: -1px;
+}
+
+/* Native-style close "X": small, right-aligned codicon. Shown on hover or when the card is active. */
+.monaco-workbench .remotepair-session-card .remotepair-session-card-close {
+	flex: 0 0 auto;
+	margin-left: 6px;
+	font-size: 14px;
+	line-height: 18px;
+	opacity: 0;
+	cursor: pointer;
+	color: inherit;
+}
+.monaco-workbench .remotepair-session-card:hover .remotepair-session-card-close,
+.monaco-workbench .remotepair-session-card:focus .remotepair-session-card-close,
+.monaco-workbench .remotepair-session-card.remotepair-session-card-active .remotepair-session-card-close {
+	opacity: 0.8;
+}
+.monaco-workbench .remotepair-session-card .remotepair-session-card-close:hover {
+	opacity: 1;
+	background: var(--vscode-toolbar-hoverBackground, rgba(128, 128, 128, 0.2));
+	border-radius: 4px;
+}
+
+/* Read-only history cards (persisted titles that are not reattachable): no pointer affordance. */
+.monaco-workbench .remotepair-session-card.remotepair-session-card-readonly {
+	cursor: default;
+	opacity: 0.6;
+}
+.monaco-workbench .remotepair-session-card.remotepair-session-card-readonly:hover {
+	background: var(--vscode-editorWidget-background, rgba(128, 128, 128, 0.08));
+	border-color: var(--vscode-widget-border, rgba(128, 128, 128, 0.45));
+}
+
+.monaco-workbench .remotepair-session-empty {
+	flex: 0 0 auto;
+	font-size: 13px;
+	font-style: italic;
+	opacity: 0.45;
+	user-select: none;
+}
