+		// not the whole Sessions view (otherwise opening/closing N sessions leaks 2*N listeners
+		// and dead onTitleChanged closures keep firing). It is removed from partDisposables and
+		// disposed when the instance is disposed or the editor open fails.
+		const store = new DisposableStore();
+		this.partDisposables.add(store);
+		store.add(instance.onDisposed(() => {
+			this.attached.delete(key);
+			notifyAttachedSessionsChanged();
+			this.partDisposables.delete(store); // removes from set + disposes this store's listeners
+		}));
