# ~/.claude sync allowlist template (applied by RemotePair install on a new machine).
# What gets synced = the agent identity: settings.json / CLAUDE.md / skills (symlink targets) / bin / auto-approve.
# Everything below is *excluded* — machine-specific runtime, credentials, cache, session history. Syncing it breaks things or triggers logouts/conflicts.

# ── Machine-specific / runtime ──
/skills
/plugins/
/settings.local.json
/sessions/
/shell-snapshots/
/file-history/
/backups/
/tasks/
/cache/
/telemetry/
/debug/
/paste-cache/
/projects/
/history.jsonl
/.session-stats.json
/mcp-needs-auth-cache.json
/stats-cache.json
/.omc/

# ── Credentials / machine-local state ──
/.credentials.json
/.last-update-result.json
/todos/
/ide/
/session-env/
/.claude/

# (RemotePair's own config has moved to ~/.config/remote-pair — it lives outside .claude, so no exclusion is needed here)

# ── OS / lock junk ──
.DS_Store
.update.lock
.last-cleanup
