#!/usr/bin/env perl
# hangul-romanize — 한글 → Revised Romanization 로 변환해 tmux 세션명에 안전한
# ASCII 식별자를 만든다. 결정론적·오프라인(perl 만 사용, 맥 기본 내장).
# - 한글 음절(0xAC00–0xD7A3)은 초/중/종성 분해 후 RR 표기로.
# - [A-Za-z0-9] 는 그대로, 그 외 모든 문자(공백/./:/이모지/한자 등)는 '_' 로.
# - '_' 연속은 하나로 축약. (선행 '_' 는 유지: ".claude" → "_claude")
# 입력: argv (없으면 stdin). 출력: 변환 결과(개행 없음).
#
# 예) 창업스터디 → changeopseuteodi,  경인일보 → gyeonginilbo,  문서 → munseo
use strict;
use warnings;
use Unicode::Normalize qw(NFC);   # macOS 파일명은 NFD(자모 분리) — 음절로 재조합해야 변환됨

# 초성 19, 중성 21, 종성 28 (종성 0 = 받침 없음). RR 표준 표기.
my @L = ("g","kk","n","d","tt","r","m","b","pp","s","ss","","j","jj","ch","k","t","p","h");
my @V = ("a","ae","ya","yae","eo","e","yeo","ye","o","wa","wae","oe","yo","u","wo","we","wi","yu","eu","ui","i");
my @T = ("","k","k","k","n","n","n","t","l","k","m","p","t","t","p","l","m","p","p","t","t","ng","t","t","k","t","p","t");

my $in = @ARGV ? join(" ", @ARGV) : do { local $/; my $s = <STDIN>; defined $s ? $s : "" };
utf8::decode($in);              # UTF-8 옥텟 → 문자
$in = NFC($in);                 # NFD(분해형) → NFC(음절 조합형) — macOS basename 대응
$in =~ s/\R+\z//;               # 끝 개행 제거

my $out = "";
for my $ch (split //, $in) {
  my $c = ord($ch);
  if ($c >= 0xAC00 && $c <= 0xD7A3) {
    my $s = $c - 0xAC00;
    $out .= $L[int($s / 588)] . $V[int(($s % 588) / 28)] . $T[$s % 28];
  } elsif ($ch =~ /[A-Za-z0-9_-]/) {
    $out .= $ch;
  } else {
    $out .= "_";
  }
}
$out =~ s/_+/_/g;               # '_' 연속 축약
print $out;
