#!/usr/bin/env bash
# remote-pair — RemotePair 단일 진입점 CLI (클라이언트 측).
#
#   remote-pair launch [<dir>] [--local|--remote] [--fresh] [--yes]
#                              폴더로 (원격 host/로컬) claude 세션 실행·attach. 미매핑이면 등록 확인.
#   remote-pair ls             host(또는 로컬) tmux-aqua 세션 + 등록된 폴더 매핑 목록
#   remote-pair map [list|add <clientDir> [hostDir]|rm <clientDir>]
#                              두 기기에서 같은 내용인 폴더 매핑(외부 sync 전제). hostDir 생략=동일경로.
#   remote-pair doctor         SSH 키 연결·host 앱·tmux 점검 + 안내
#   remote-pair approve [--label P] [--timeout S]   승인 다이얼로그 클릭 요청 (결과 회수)
#   remote-pair status         host 서버·앱·heartbeat 상태
#   remote-pair host           tmux-aqua host 서버 기동 보장 (로컬에 앱 있을 때)
#   remote-pair help
#
# config: ~/.remote-pair/{common,host,client}.env (install.sh 가 확정 — .claude 밖, 자기완결).
set -euo pipefail

RP_DIR="${RP_DIR:-$HOME/.remote-pair}"
CLIENT_ENV="$RP_DIR/client.env"
for _f in common host client; do
  # shellcheck disable=SC1090
  [ -f "$RP_DIR/$_f.env" ] && { set -a; . "$RP_DIR/$_f.env"; set +a; }
done
APP_NAME="${APP_NAME:-RemotePairHost}"
BUNDLE_PREFIX="${BUNDLE_PREFIX:-com.x10lab.remote-pair-host}"
LOCAL_BIN="${LOCAL_BIN:-$HOME/.local/bin}"
AQUA_SOCK="${AQUA_SOCK:-/tmp/aqua-tmux.sock}"
APPROVE_TRIGGER="${APPROVE_TRIGGER:-/tmp/remote-pair.approve-request}"
LOG_FILE="${LOG_FILE:-$RP_DIR/logs/remote-pair.log}"
HEARTBEAT_FILE="${HEARTBEAT_FILE:-$RP_DIR/logs/remote-pair.heartbeat}"
REMOTE_HOST="${REMOTE_HOST:-}"
FOLDER_MAPS="${FOLDER_MAPS:-${SYNC_ROOTS:-}}"     # client::host 매핑 (구 SYNC_ROOTS 호환)
LAUNCHER="${LAUNCHER:-$RP_DIR/bin/remote-pair-launch}"
TMUXB="$LOCAL_BIN/tmux-aqua"
RP_YES="${RP_YES:-0}"

c()    { printf '\033[1;36m▸ %s\033[0m\n' "$*"; }
warn() { printf '\033[1;33m⚠ %s\033[0m\n' "$*" >&2; }
ok()   { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }

tm() { "$TMUXB" -S "$AQUA_SOCK" "$@"; }
host_up() { [ -x "$TMUXB" ] && tm has-session >/dev/null 2>&1; }
app_pid() { pgrep -f "$APP_NAME.app/Contents/MacOS/$APP_NAME" 2>/dev/null | head -1 || true; }

# client.env 의 KEY upsert (매핑 영속용)
rp_set() {
  local k="$1" v="$2" f="$CLIENT_ENV"
  mkdir -p "$(dirname "$f")"; touch "$f"
  { grep -v "^$k=" "$f" 2>/dev/null || true; printf '%s=%q\n' "$k" "$v"; } > "$f.tmp" && mv "$f.tmp" "$f"
}

# ── 매핑 ──
map_client_of() { printf '%s' "${1%%::*}"; }
map_host_of()   { local p="$1" h="${1#*::}"; [ "$h" = "$p" ] && h="$p"; printf '%s' "$h"; }

resolve_host() { # $1=clientDir → echo hostDir (longest-prefix; 매핑 없으면 동일)
  local d="$1" best_c="" best_h="" c h pair IFS=';'
  for pair in $FOLDER_MAPS; do
    [ -n "$pair" ] || continue
    c="$(map_client_of "$pair")"; h="$(map_host_of "$pair")"
    case "$d" in "$c"|"$c"/*) [ "${#c}" -gt "${#best_c}" ] && { best_c="$c"; best_h="$h"; } ;; esac
  done
  [ -n "$best_c" ] && printf '%s%s' "$best_h" "${d#"$best_c"}" || printf '%s' "$d"
}
is_mapped() { local d="$1" c pair IFS=';'; for pair in $FOLDER_MAPS; do [ -n "$pair" ] || continue; c="$(map_client_of "$pair")"; case "$d" in "$c"|"$c"/*) return 0 ;; esac; done; return 1; }

cmd_map() {
  case "${1:-list}" in
    list|"") printf '폴더 매핑 (client → host):\n'
             local pair IFS=';'; for pair in $FOLDER_MAPS; do [ -n "$pair" ] && printf '  %s  →  %s\n' "$(map_client_of "$pair")" "$(map_host_of "$pair")"; done
             [ -z "$FOLDER_MAPS" ] && echo "  (없음)" ;;
    add) local cd hd
         cd="$(cd "${2:?clientDir 필요}" 2>/dev/null && pwd)" || { echo "client 경로 없음: ${2:-}" >&2; return 1; }
         hd="${3:-$cd}"
         is_mapped "$cd" && { echo "이미 매핑됨(또는 상위): $cd"; return 0; }
         local entry="$cd::$hd"
         FOLDER_MAPS="${FOLDER_MAPS:+$FOLDER_MAPS;}$entry"; rp_set FOLDER_MAPS "$FOLDER_MAPS"
         ok "매핑 추가: $cd  →  $hd" ;;
    rm)  local d="${2:?clientDir 필요}" out="" pair IFS=';'
         for pair in $FOLDER_MAPS; do [ "$(map_client_of "$pair")" = "$d" ] || out="${out:+$out;}$pair"; done
         FOLDER_MAPS="$out"; rp_set FOLDER_MAPS "$FOLDER_MAPS"; ok "매핑 제거: $d" ;;
    *) echo "map [list|add <clientDir> [hostDir]|rm <clientDir>]" >&2; return 2 ;;
  esac
}

cmd_ls() {
  cmd_map list; echo
  if [ -n "$REMOTE_HOST" ]; then
    echo "[$REMOTE_HOST] tmux-aqua 세션:"
    ssh -o BatchMode=yes -o ConnectTimeout=5 "$REMOTE_HOST" "\$HOME/.local/bin/tmux-aqua -S '$AQUA_SOCK' list-sessions 2>/dev/null" \
      | grep -v '^_keeper' | sed 's/^/  /' || echo "  (없음 또는 연결 불가)"
  else
    echo "[local] tmux-aqua 세션:"; tm list-sessions 2>/dev/null | grep -v '^_keeper' | sed 's/^/  /' || echo "  (없음)"
  fi
}

cmd_launch() {
  local pass=() dir=""
  while [ $# -gt 0 ]; do case "$1" in
    --local|--remote|--fresh|--yes|-y) pass+=("$1"); [ "$1" = "--yes" ] || [ "$1" = "-y" ] && RP_YES=1; shift ;;
    *) dir="$1"; shift ;;
  esac; done
  dir="$(cd "${dir:-$PWD}" 2>/dev/null && pwd)" || { echo "폴더 없음" >&2; return 1; }
  if ! is_mapped "$dir" && [ -n "$REMOTE_HOST" ] && [ "$RP_YES" != 1 ]; then
    warn "등록된 폴더 매핑 밖입니다: $dir"
    printf '  → host(%s)에 같은 경로(%s)가 없으면 엉뚱한 위치를 잡을 수 있습니다.\n' "$REMOTE_HOST" "$dir" >&2
    local ans=""
    { printf '  매핑 등록? [y]동일경로 등록 / [o]등록없이 1회 / [N]취소: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    case "$ans" in y|Y) cmd_map add "$dir" ;; o|O) : ;; *) echo "취소됨." >&2; return 1 ;; esac
  fi
  [ -x "$LAUNCHER" ] || { echo "런처 없음: $LAUNCHER (client 설치 필요)" >&2; return 1; }
  RP_YES="$RP_YES" exec "$LAUNCHER" "${pass[@]}" "$dir"
}

cmd_host() {
  if host_up; then ok "host 서버 OK ($AQUA_SOCK)"; return 0; fi
  c "host 서버 미기동 → $APP_NAME 기동..."
  open -a "$APP_NAME" 2>/dev/null || launchctl kickstart -k "gui/$(id -u)/$BUNDLE_PREFIX" 2>/dev/null || true
  for _ in $(seq 1 12); do host_up && { ok "host 서버 OK"; return 0; }; sleep 0.5; done
  warn "host 서버 기동 실패 — System Settings 권한/앱 설치 확인"; return 13
}

cmd_status() {
  local p; p="$(app_pid)"
  printf '%-14s %s\n' "app"       "${p:+running (pid $p)}${p:-NOT running}"
  printf '%-14s %s\n' "host 서버"  "$(host_up && echo "up ($AQUA_SOCK)" || echo down)"
  if [ -f "$HEARTBEAT_FILE" ]; then
    local age=$(( $(date +%s) - $(stat -f %m "$HEARTBEAT_FILE" 2>/dev/null || echo 0) ))
    printf '%-14s %s\n' "heartbeat" "${age}s ago $([ "$age" -le 90 ] && echo "(fresh)" || echo "(STALE)")"
  else printf '%-14s %s\n' "heartbeat" "없음 (앱 미기동?)"; fi
  printf '%-14s %s\n' "remote" "${REMOTE_HOST:-(로컬 전용)}"
  printf '%-14s %s\n' "bundle" "$BUNDLE_PREFIX"
  return 0
}

cmd_doctor() {
  local fail=0
  c "RemotePair doctor"
  # 로컬
  printf '%-22s %s\n' "런처" "$([ -x "$LAUNCHER" ] && echo "OK ($LAUNCHER)" || { echo "없음 — install.sh --role client"; fail=1; })"
  printf '%-22s %s\n' "mosh(로컬)" "$(command -v mosh >/dev/null && echo OK || echo "없음 (ssh 폴백)")"
  printf '%-22s %s\n' "폴더 매핑" "$([ -n "$FOLDER_MAPS" ] && echo "$(printf '%s' "$FOLDER_MAPS" | tr ';' '\n' | grep -c .)개" || echo "없음 (첫 launch 시 등록)")"
  if [ -z "$REMOTE_HOST" ]; then
    warn "REMOTE_HOST 미설정 — 로컬 전용 모드 (원격 점검 생략)"; return "$fail"
  fi
  # SSH 키 연결
  printf '%-22s ' "SSH($REMOTE_HOST)"
  if ssh -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" true 2>/dev/null; then
    echo "OK (키 인증 통과)"
  else
    echo "실패"; fail=1
    warn "SSH 키 인증 실패. 아래 중 하나로 연결:"
    cat >&2 <<EOF
   1) 키 없으면 생성:   ssh-keygen -t ed25519
   2) host 에 공개키 등록:   ssh-copy-id $REMOTE_HOST
   3) ~/.ssh/config 에 Host 별칭(IdentityFile/User/HostName) 확인
   4) 1Password 등 SSH agent 사용 시: agent 승인/잠금해제 필요 (remote-pair approve 로 자동클릭 가능)
   확인:   ssh -o BatchMode=yes $REMOTE_HOST true && echo OK
EOF
    return "$fail"
  fi
  # host 측 구성
  local rb='$HOME/.local/bin/tmux-aqua'
  printf '%-22s %s\n' "host tmux-aqua" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "[ -x $rb ]" 2>/dev/null && echo OK || { echo "없음 — host 에 install.sh --role host"; fail=1; })"
  printf '%-22s %s\n' "host 앱" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "[ -d ~/Applications/$APP_NAME.app ]" 2>/dev/null && echo "OK ($APP_NAME.app)" || { echo "없음"; fail=1; })"
  printf '%-22s %s\n' "host 서버" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "$rb -S '$AQUA_SOCK' has-session" 2>/dev/null && echo "up" || echo "down (앱 실행/권한 확인)")"
  [ "$fail" = 0 ] && ok "이상 없음 — remote-pair launch 가능" || warn "위 항목 확인 필요"
  return "$fail"
}

cmd_approve() {
  local label="" timeout=12
  while [ $# -gt 0 ]; do case "$1" in
    --label) label="${2:-}"; shift 2 ;;
    --timeout) timeout="${2:-12}"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; return 2 ;;
  esac; done
  [ -n "$(app_pid)" ] || warn "$APP_NAME 미기동 — 'remote-pair host' 로 먼저 기동 권장"
  local base=0; [ -f "$LOG_FILE" ] && base=$(wc -l < "$LOG_FILE")
  [ -n "$label" ] && printf '%s\n' "$label" > "$APPROVE_TRIGGER.label" 2>/dev/null || true
  : > "$APPROVE_TRIGGER" 2>/dev/null || { echo "트리거 쓰기 실패: $APPROVE_TRIGGER" >&2; return 1; }
  echo "approve 요청 → $APP_NAME (최대 ${timeout}s 관찰)"
  local end=$(( $(date +%s) + timeout ))
  while [ "$(date +%s)" -lt "$end" ]; do
    if [ -f "$LOG_FILE" ]; then
      local now; now=$(wc -l < "$LOG_FILE")
      if [ "$now" -gt "$base" ]; then
        local new; new=$(tail -n "$(( now - base ))" "$LOG_FILE")
        if printf '%s\n' "$new" | grep -qiE 'router:.*(click|key)|clicked|coord'; then
          printf '%s\n' "$new" | grep -iE 'router:.*(click|key)|clicked|coord' | sed 's/^/  /'
          echo "✓ 클릭됨"; return 0
        fi
        base="$now"
      fi
    fi
    sleep 0.5
  done
  echo "⏱ ${timeout}s 내 클릭 로그 없음 ($LOG_FILE 확인)" >&2; return 1
}

case "${1:-help}" in
  launch)  shift; cmd_launch "$@" ;;
  ls)      cmd_ls ;;
  map)     shift; cmd_map "$@" ;;
  roots)   shift; cmd_map "$@" ;;     # 구 별칭
  doctor)  cmd_doctor ;;
  approve) shift; cmd_approve "$@" ;;
  status)  cmd_status ;;
  host)    cmd_host ;;
  help|-h|--help) sed -n '3,16p' "$0" ;;
  *) echo "unknown command: $1" >&2; sed -n '3,16p' "$0"; exit 2 ;;
esac
