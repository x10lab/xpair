.DS_Store
build/
host/app/RemotePairHost
*.o
# OMC runtime state (device-local)
.omc/
# Never commit signing keys/certificates (back them up under ~/Library/Application Support/RemotePair/)
*.p12
*.pem
*.key
host/ocr-find

# generated at build from AppIcon-1024.png
assets/icon/AppIcon.icns
assets/icon/*.iconset/

# Python bytecode cache
__pycache__/
*.pyc

# External references for reference only (comparison/analysis, do not commit)
context/

# Debug renders/screenshots (do not commit)
/rp-*.png

# MCP browser artifacts
.playwright-mcp/

# SwiftPM build artifacts (host/Package.swift — links sentry-cocoa). Package.resolved IS tracked
# (pins the dependency for reproducible builds); only the build dir + local working state are ignored.
.build/
.swiftpm/

# RemotePair IDE per-build marker counter (changes every build)
client/ide/remotepair/.build-counter

shared/.build-counter
