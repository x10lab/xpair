#!/usr/bin/env bash
# xpair-editor — Launch code-server for the Xpair web editor tab.
#
# Usage:
#   xpair-editor [start] [<folder>]   Launch code-server on 127.0.0.1:${EDITOR_PORT:-8080}
#   xpair-editor status               Is code-server listening on EDITOR_PORT?
#   xpair-editor stop                 Kill the running code-server for this port
#
# Security note: --auth none is intentional and safe ONLY because the server is bound to
# 127.0.0.1 (loopback). Never expose EDITOR_PORT to an external interface without auth.
#
# Install path: $LOCAL_BIN/xpair-editor (placed by shared/install.sh)
# Config:  EDITOR_PORT (default 8080)
#          RP_DIR      (default ~/.xpair/host)
set -euo pipefail

# ── Config ──────────────────────────────────────────────────────────────────
EDITOR_PORT="${EDITOR_PORT:-8080}"
RP_DIR="${RP_DIR:-$HOME/.xpair/host}"
LOCAL_BIN="${LOCAL_BIN:-$HOME/.local/bin}"
BIND_ADDR="127.0.0.1"

# Source the shared logger; no-op fallback for partially-updated clients.
# shellcheck disable=SC1090
[ -f "$RP_DIR/bin/logging.sh" ] && . "$RP_DIR/bin/logging.sh"
type rp_log >/dev/null 2>&1 || { rp_log(){ :; }; log_info(){ :; }; log_warn(){ printf '%s\n' "$*" >&2; }; log_error(){ printf '%s\n' "$*" >&2; }; err(){ printf '\033[1;31m✗ %s\033[0m\n' "$*" >&2; }; warn(){ printf '\033[1;33m⚠ %s\033[0m\n' "$*" >&2; }; }

# ── Colours (err/warn come from logging.sh or the fallback above) ─────────────────────────────────────────────────────────
c()  { printf '\033[1;36m▸ %s\033[0m\n' "$*"; }
ok() { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }

# ── Resolve code-server binary ───────────────────────────────────────────────
find_code_server() {
  # 1. Already on PATH
  if command -v code-server >/dev/null 2>&1; then
    command -v code-server; return 0
  fi
  # 2. Common user-local install paths
  for candidate in \
      "$HOME/.local/bin/code-server" \
      "$HOME/.yarn/bin/code-server" \
      "/usr/local/bin/code-server" \
      "/opt/homebrew/bin/code-server"; do
    if [ -x "$candidate" ]; then printf '%s' "$candidate"; return 0; fi
  done
  return 1
}

print_install_guidance() {
  err "code-server not found."
  cat >&2 <<'EOF'

  Install options (pick one):
    Homebrew:   brew install code-server
    npm (global): npm install -g code-server
    Official script: curl -fsSL https://code-server.dev/install.sh | sh

  After installing, re-run:
    xpair-editor [<folder>]

  For the full Xpair custom fork (progressive VS Code modification),
  see docs/m4-code-server.md.
EOF
}

# ── Status helper ────────────────────────────────────────────────────────────
port_listening() {
  # lsof is available on macOS without extra deps
  lsof -nP -iTCP:"$EDITOR_PORT" -sTCP:LISTEN >/dev/null 2>&1
}

cmd_status() {
  if port_listening; then
    ok "code-server is listening on ${BIND_ADDR}:${EDITOR_PORT}"
    lsof -nP -iTCP:"$EDITOR_PORT" -sTCP:LISTEN 2>/dev/null | tail -n +2 | awk '{print "  pid="$2, "cmd="$1}' || true
    return 0
  else
    warn "code-server is NOT listening on port ${EDITOR_PORT}"
    return 1
  fi
}

# ── Stop helper ──────────────────────────────────────────────────────────────
cmd_stop() {
  local pids
  pids="$(lsof -nP -iTCP:"$EDITOR_PORT" -sTCP:LISTEN 2>/dev/null | tail -n +2 | awk '{print $2}' | sort -u || true)"
  if [ -z "$pids" ]; then
    warn "No process found listening on port ${EDITOR_PORT}."
    return 0
  fi
  for pid in $pids; do
    kill "$pid" 2>/dev/null && ok "Sent SIGTERM to pid $pid" || warn "Could not kill pid $pid"
  done
  # Give it a moment, then hard-kill if still up
  sleep 1
  if port_listening; then
    for pid in $pids; do kill -9 "$pid" 2>/dev/null || true; done
    ok "Force-killed lingering code-server process(es)."
  fi
}

# ── Start helper ─────────────────────────────────────────────────────────────
cmd_start() {
  local folder="${1:-$(pwd)}"
  folder="$(cd "$folder" 2>/dev/null && pwd)" || { err "Folder not found: $1"; exit 1; }

  local cs_bin
  if ! cs_bin="$(find_code_server)"; then
    print_install_guidance
    exit 1
  fi
  ok "Using code-server: $cs_bin  ($(command "$cs_bin" --version 2>/dev/null | head -1 || echo 'unknown version'))"

  if port_listening; then
    ok "code-server already listening on ${BIND_ADDR}:${EDITOR_PORT} — not starting a second instance."
    c "URL: http://${BIND_ADDR}:${EDITOR_PORT}/?folder=${folder}"
    return 0
  fi

  # Ensure log dir exists
  mkdir -p "$RP_DIR/logs"
  local logfile="$RP_DIR/logs/code-server.log"

  c "Starting code-server"
  c "  folder : $folder"
  c "  bind   : ${BIND_ADDR}:${EDITOR_PORT}"
  c "  auth   : none (loopback-only — safe)"
  c "  log    : $logfile"

  # Launch detached; parent returns immediately so WEB bridge can proceed
  nohup "$cs_bin" \
    --bind-addr "${BIND_ADDR}:${EDITOR_PORT}" \
    --auth none \
    "$folder" \
    >> "$logfile" 2>&1 &

  local cs_pid=$!
  # Brief wait to detect fast-fail
  sleep 1
  if ! kill -0 "$cs_pid" 2>/dev/null && ! port_listening; then
    err "code-server exited immediately. Check log: $logfile"
    exit 1
  fi

  ok "code-server started (pid=$cs_pid)"
  c "URL: http://${BIND_ADDR}:${EDITOR_PORT}/?folder=${folder}"
}

# ── Argument dispatch ────────────────────────────────────────────────────────
CMD="${1:-start}"
case "$CMD" in
  status)
    cmd_status
    ;;
  stop)
    cmd_stop
    ;;
  start|"")
    shift 2>/dev/null || true
    cmd_start "${1:-}"
    ;;
  -h|--help|help)
    sed -n '2,13p' "$0"
    exit 0
    ;;
  *)
    # Treat a bare path as the folder argument to start
    if [ -d "$CMD" ]; then
      cmd_start "$CMD"
    else
      err "Unknown subcommand: $CMD"
      sed -n '2,13p' "$0"
      exit 2
    fi
    ;;
esac
