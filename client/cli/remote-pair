# remote-pair mount — host-folder mount (Syncthing alternative; see docs/m-mount.md).
# Thin pass-through to remote-pair-mount (mount/unmount/status/help; backends smb|sshfs).
cmd_mount() {
  local tool; tool="$(_resolve_client_tool remote-pair-mount)" \
    || { echo "remote-pair-mount not found (install client, or run from the repo)" >&2; return 1; }
