# remote-pair notify — CLI parity with the web notifications panel.
# Best-effort SSH pull of the host queue (~/.remote-pair/notifications/queue.jsonl), filtered by the
# LOCAL ~/.remote-pair/notify.conf ENABLED_TYPES. Prints recent events. Never errors hard (queue is
# advisory): unreachable host / missing queue / absent python3 all degrade to an empty list.
cmd_notify() {
  local n=20
  while [ $# -gt 0 ]; do case "$1" in
    -n) n="${2:-20}"; shift 2 ;;
    *)  shift ;;
  esac; done
  # Validate n is a positive integer — guards against remote shell injection via 'tail -n $n'.
  case "$n" in (''|*[!0-9]*) n=20 ;; esac
  [ -n "$REMOTE_HOST" ] || { warn "no REMOTE_HOST configured — notify pulls from the host ('remote-pair config set host <ssh-host>')"; return 0; }

  # Local ENABLED_TYPES filter (mirror remote-pair-notify.sh parsing). Default: all on.
  local enabled="Stop,Notification,SubagentStop,approve"
  local conf="$RP_DIR/notify.conf"
  if [ -f "$conf" ]; then
    local v; v="$(sed -n 's/^[[:space:]]*ENABLED_TYPES[[:space:]]*=[[:space:]]*\(.*\)$/\1/p' "$conf" | tail -1)"
    # An explicit empty value (ENABLED_TYPES=) means "all off" — honor it; only fall back when the key is absent.
    if grep -qE '^[[:space:]]*ENABLED_TYPES[[:space:]]*=' "$conf" 2>/dev/null; then enabled="${v// /}"; fi
  fi

  # Pull the tail of the host queue (best-effort; never hard-fail).
  local rq='$HOME/.remote-pair/notifications/queue.jsonl'
  local raw; raw="$(ssh -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" "tail -n $n $rq 2>/dev/null" 2>/dev/null || true)"
  if [ -z "$raw" ]; then c "no recent host notifications (host unreachable, or queue empty)"; return 0; fi

  # Filter by ENABLED_TYPES + pretty-print. Prefer python3 (robust JSON); degrade to a raw dump.
  if command -v python3 >/dev/null 2>&1; then
    printf '%s\n' "$raw" | _RP_ENABLED="$enabled" python3 -c '
import json, os, sys, time
enabled = set(t for t in os.environ.get("_RP_ENABLED", "").split(",") if t)
rows = []
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        ev = json.loads(line)
    except Exception:
        continue
    typ = ev.get("type", "")
    if enabled and typ and typ not in enabled:
        continue
    rows.append(ev)
if not rows:
    print("\033[1;36m▸ no notifications match ENABLED_TYPES=%s\033[0m" % ",".join(sorted(enabled)))
    sys.exit(0)
now = int(time.time())
for ev in rows:
    ts = ev.get("ts", 0)
    try: age = now - int(ts)
    except Exception: age = 0
    ago = ("%ds" % age) if age < 90 else ("%dm" % (age // 60)) if age < 3600 else ("%dh" % (age // 3600))
    typ = ev.get("type", "?")
    title = ev.get("title", "")
    msg = (ev.get("message", "") or "").replace("\n", " ")
    if len(msg) > 100: msg = msg[:99] + "…"
    print("\033[1;33m[%-12s]\033[0m %s ago  %s" % (typ, ago, title))
    if msg: print("                %s" % msg)
'
  else
    warn "python3 absent — raw queue dump (no type filter):"
    printf '%s\n' "$raw"
  fi
  return 0
}

# remote-pair update — M6 LEVEL-1: CodePush-style HOT-SWAP of the glue layer ONLY.
#
# 2-level update model:
#   Level-1 (this command): re-install the *glue* layer (CLI, launchers,
#     approve rules/skills, host hooks) from the repo/source WITHOUT touching the running .app or the
#     tmux-aqua server. No relaunch. This is hot-swappable because it's all interpreted scripts/assets.
#   Level-2 (NOT here): the native .app binary itself. If the repo's app version differs from the
#     running status.json version, the binary must be updated by the app's own Updater (with the
#     session/consent gate). This command refuses to touch the binary and tells you to use Level-2.
#
# Detection: compare the repo VERSION (host/build-host.sh RP_VERSION → Casks fallback) against the
# running app version (status.json "version"). Mismatch ⇒ a Level-2 native update is also required.
cmd_update() {
  local check=0 ref="main"
  while [ $# -gt 0 ]; do case "$1" in
    --check) check=1; shift ;;
    --ref)   ref="${2:-main}"; shift 2 ;;
    -h|--help)
      sed -n '/^# remote-pair update — M6/,/^cmd_update()/p' "$0" | sed 's/^# \{0,1\}//; /^cmd_update()/d'
      return 0 ;;
    *) echo "update [--check] [--ref <git-ref>]" >&2; return 2 ;;
  esac; done

  # Locate the repo/source layout. Glue hot-swap re-runs the installer scoped to the client glue.
  # CLI lives at <repo>/client/cli/remote-pair, so the repo root (the dir that
  # contains shared/) is two levels up from here, not one.
  local repo_root="" here; here="$(cd "$(dirname "$0")" 2>/dev/null && pwd)"
  if [ -f "$here/../../shared/install.sh" ]; then repo_root="$(cd "$here/../.." 2>/dev/null && pwd)"; fi

  # ── Detect glue-only vs native binary mismatch ──
  # Running app version (status.json ground truth).
  local running_ver=""
  [ -f "$STATUS_FILE" ] && running_ver="$(_jget "$(cat "$STATUS_FILE" 2>/dev/null)" version)"
  # Repo app version: host/build-host.sh RP_VERSION default, else Casks/*.rb, else unknown.
  local repo_ver=""
  if [ -n "$repo_root" ] && [ -f "$repo_root/host/build-host.sh" ]; then
    repo_ver="$(sed -n 's/^VERSION="${RP_VERSION:-\([0-9.]*\)}".*/\1/p' "$repo_root/host/build-host.sh" | head -1)"
  fi
  if [ -z "$repo_ver" ] && [ -n "$repo_root" ]; then
    repo_ver="$(sed -n 's/^[[:space:]]*version "\([0-9.]*\)".*/\1/p' "$repo_root"/Casks/*.rb 2>/dev/null | head -1)"
  fi

  c "remote-pair update (M6 Level-1 glue hot-swap)"
  printf '  %-16s %s\n' "running app" "${running_ver:-unknown (status.json absent — app may be down)}"
  printf '  %-16s %s\n' "repo/source" "${repo_ver:-unknown}"

  local native_needed=0
  if [ -n "$running_ver" ] && [ -n "$repo_ver" ] && [ "$running_ver" != "$repo_ver" ]; then
    native_needed=1
  fi

  if [ "$check" = 1 ]; then
    if [ "$native_needed" = 1 ]; then
      warn "Level-2 native update required: app binary $running_ver → $repo_ver (use the app's Updater — session/consent gated)."
    else
      ok "no native mismatch — Level-1 glue hot-swap is sufficient."
    fi
    return 0
  fi

  # ── Level-2 guard: NEVER hot-swap the binary here. ──
  if [ "$native_needed" = 1 ]; then
    warn "App binary version mismatch ($running_ver → $repo_ver)."
    cat >&2 <<EOF
   This is a Level-2 NATIVE update — the .app binary changed. Level-1 (this command) will NOT
   touch the running app or tmux server. Apply the native update via the app's own Updater, which
   gates on the current session + user consent:
     • Host menubar: $APP_NAME → "Check for updates…"   (or the app auto-checks GitHub Releases)
     • The Updater downloads ${APP_NAME}.zip, prompts, and swaps the binary safely.
   After the native update lands, re-run 'remote-pair update' to refresh the glue layer too.
EOF
    return 12
  fi

  # ── Level-1 hot-swap. Reuse the existing self-update machinery (network path) OR re-run the
  #    repo installer scoped to client glue (local repo path). Neither relaunches the .app/tmux. ──
  if [ -n "$repo_root" ] && [ -f "$repo_root/shared/install.sh" ]; then
    c "glue hot-swap ← local repo ($repo_root) — re-installing client glue (--no-native, no relaunch)"
    # --no-native keeps the app/LaunchAgent untouched; install.sh re-installs CLI/launchers/etc.
    if RP_YES=1 bash "$repo_root/shared/install.sh" --role client --no-native --no-sync; then
      ok "glue layer hot-swapped (app + tmux untouched). New code applies on next invocation."
    else
      warn "repo installer failed — falling back to network self-update"; cmd_self_update "$ref"
    fi
  else
    c "no local repo — glue hot-swap via network self-update (GitHub @$ref)"
    cmd_self_update "$ref"
    warn "network self-update covers CLI/launcher/romanize only. For the full glue layer (approve rules/skills, host hooks), run from a repo checkout or re-run host install."
  fi
}

