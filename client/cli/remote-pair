#!/usr/bin/env bash
# remote-pair — RemotePair single entry-point CLI (client side).
#
#   remote-pair launch [<dir>] [--local|--remote] [--fresh] [--yes]
#                              Launch/attach a claude session (remote host/local) for a folder. Prompts to register if unmapped.
#   remote-pair ls             List host (or local) tmux-aqua sessions + registered folder mappings
#   remote-pair map [list|add <clientDir> [hostDir]|rm <clientDir>]
#                              Folder mappings with identical content on both machines (external sync assumed). Omit hostDir = same path.
#   remote-pair config [list|get <key>|set <key> <value>|maps]
#                              View/edit client config. keys: host (REMOTE_HOST), terminal (iterm2|terminal).
#   remote-pair onboard        Interactive, re-runnable client setup (host, terminal app, folder mapping, doctor).
#   remote-pair open-gui <dir> Open the configured terminal app in a new window running 'launch <dir>'.
#   remote-pair doctor         Check SSH key connection, host app, tmux + guidance
#   remote-pair approve [--for "<what>"] [--type "key:..|ocr:.."] [--timeout S]   Handle a blocked approval dialog
#                              --for: which dialog (alias-tolerant)  ·  --type: how to approve — agent decides (key:<combo>|ocr:<label>)
#   remote-pair status         Host server, app, heartbeat status
#   remote-pair editor [start|status|stop] [<dir>]   Launch/inspect the code-server editor (loopback EDITOR_PORT, default 8080)
#   remote-pair desktop [open|check]    Open the host screen via macOS Screen Sharing (vnc://REMOTE_HOST), or check reachability
#   remote-pair mount [mount|unmount|status|help] ...   Mount a host folder directly (Syncthing alternative; backends smb|sshfs — see docs/m-mount.md)
#   remote-pair notify [-n N]  Pull recent host notifications (Stop/Notification/SubagentStop/approve), filtered by ~/.remote-pair/notify.conf
#   remote-pair logs [--host] [-f] [-n N]   Tail logs (local launcher/app; --host = host logs over ssh; -f = follow)
#   remote-pair self-update    Update client (launcher/CLI/romanize) to latest from GitHub (keep in sync with host)
#   remote-pair update [--check] [--ref <git-ref>]   HOT-SWAP the glue layer (CLI/launchers/approve/host-hooks) without touching the .app/tmux (M6 Level-1). Native .app changes → Level-2 (app Updater).
#   remote-pair host           Ensure the tmux-aqua host server is up (when the app is local)
#   remote-pair help
#
# config: ~/.remote-pair/{common,host,client}.env (finalized by install.sh — outside .claude, self-contained).
set -euo pipefail

RP_DIR="${RP_DIR:-$HOME/.remote-pair}"
CLIENT_ENV="$RP_DIR/client.env"
for _f in common host client; do
  # shellcheck disable=SC1090
  [ -f "$RP_DIR/$_f.env" ] && { set -a; . "$RP_DIR/$_f.env"; set +a; }
done
APP_NAME="${APP_NAME:-RemotePairHost}"
BUNDLE_PREFIX="${BUNDLE_PREFIX:-com.x10lab.remote-pair-host}"
# Dual-id fallbacks: current shipping id is com.x10lab.remote-pair-host / RemotePairHost (above).
# The 0.5 flip will move the host to the unified id com.x10lab.remote-pair / RemotePair — so we ALSO
# probe that forward id here. app_pid/app_available/cmd_host accept EITHER id and EITHER app name,
# making this CLI future-proof across the flip (no false-negative on status/doctor/host).
FORWARD_BUNDLE="com.x10lab.remote-pair"
FORWARD_APP="RemotePair"
LOCAL_BIN="${LOCAL_BIN:-$HOME/.local/bin}"
AQUA_SOCK="${AQUA_SOCK:-/tmp/aqua-tmux.sock}"
APPROVE_TRIGGER="${APPROVE_TRIGGER:-/tmp/remote-pair.approve-request}"
LOG_FILE="${LOG_FILE:-$RP_DIR/logs/remote-pair.log}"
HEARTBEAT_FILE="${HEARTBEAT_FILE:-$RP_DIR/logs/remote-pair.heartbeat}"
REMOTE_HOST="${REMOTE_HOST:-}"
FOLDER_MAPS="${FOLDER_MAPS:-${SYNC_ROOTS:-}}"     # client::host mappings (legacy SYNC_ROOTS compatible)
LAUNCHER="${LAUNCHER:-$RP_DIR/bin/remote-pair-launch}"
# Terminal app for open-gui/onboard. Default iterm2 if iTerm installed, else terminal.
TERMINAL_APP="${TERMINAL_APP:-$( [ -d /Applications/iTerm.app ] && echo iterm2 || echo terminal )}"
TMUXB="$LOCAL_BIN/tmux-aqua"
RP_YES="${RP_YES:-0}"

# Absolute path to this CLI (for relaunch via terminal apps). Prefer LOCAL_BIN, fall back to $0.
SELF_CLI="$LOCAL_BIN/remote-pair"
[ -x "$SELF_CLI" ] || SELF_CLI="$(cd "$(dirname "$0")" 2>/dev/null && pwd)/$(basename "$0")"

ITERM_PATH="/Applications/iTerm.app"
TERMINAL_PATH="/System/Applications/Utilities/Terminal.app"

# Source the shared logger (installed by install.sh / self-update); no-op fallback keeps the
# script functional on a partially-updated client where logging.sh is absent.
# shellcheck disable=SC1090
[ -f "$RP_DIR/bin/logging.sh" ] && . "$RP_DIR/bin/logging.sh"
type rp_log >/dev/null 2>&1 || { rp_log(){ :; }; log_info(){ :; }; log_warn(){ printf '%s\n' "$*" >&2; }; log_error(){ printf '%s\n' "$*" >&2; }; err(){ printf '\033[1;31m✗ %s\033[0m\n' "$*" >&2; }; info(){ printf '\033[1;36m▸ %s\033[0m\n' "$*"; }; warn(){ printf '\033[1;33m⚠ %s\033[0m\n' "$*" >&2; }; }

# ── UI helpers (err/info/warn come from logging.sh or the fallback above) ──
c()  { printf '\033[1;36m▸ %s\033[0m\n' "$*"; }
ok() { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }

STATUS_FILE="${STATUS_FILE:-$RP_DIR/logs/status.json}"

tm() { "$TMUXB" -S "$AQUA_SOCK" "$@"; }
host_up() { [ -x "$TMUXB" ] && tm has-session >/dev/null 2>&1; }
# launchctl is authoritative for our LaunchAgent. pgrep -f MISSES .app-bundle processes on macOS
# (false "not running"), which is what misleads agents — so check the label first, pgrep only as fallback.
app_pid() {
  local p
  # Match the configured label OR the forward one (transition-era hosts not yet migrated).
  p="$(launchctl list 2>/dev/null | awk -v l="$BUNDLE_PREFIX" -v lg="$FORWARD_BUNDLE" '($3==l || $3==lg) && $1 ~ /^[0-9]+$/ {print $1; exit}')"
  [ -n "$p" ] || p="$(pgrep -f "$APP_NAME.app/Contents/MacOS/$APP_NAME" 2>/dev/null | head -1)"
  [ -n "$p" ] || p="$(pgrep -f "$FORWARD_APP.app/Contents/MacOS/$FORWARD_APP" 2>/dev/null | head -1)"
  printf '%s' "$p"
}
# Minimal flat-JSON value reader (no jq dep). _jget '<json>' key → value (string or bool/number).
_jget() { printf '%s' "$1" | sed -n "s/.*\"$2\":\"\{0,1\}\([^,\"}]*\)\"\{0,1\}.*/\1/p"; }
_mark() { [ "$1" = true ] && printf '✓' || printf '✗'; }
# Are we running INSIDE a RemotePair host tmux session? (computer-use available here)
in_host_session() { case "${TMUX:-}" in *aqua-tmux.sock*) return 0;; *) return 1;; esac; }

# Is the RemotePair app available to serve app-dependent commands here?
#   true if the app is installed locally (bundle/process/status.json) OR we're inside a live host session.
app_available() {
  # Existence check covers BOTH install locations (cask → /Applications, manual → ~/Applications)
  # AND both the new and legacy app names (transition-era hosts not yet migrated).
  for d in "/Applications" "$HOME/Applications"; do
    [ -d "$d/$APP_NAME.app" ] && return 0
    [ -d "$d/$FORWARD_APP.app" ] && return 0
  done
  [ -n "$(app_pid)" ] && return 0
  [ -f "$STATUS_FILE" ] && return 0
  in_host_session && host_up && return 0
  return 1
}
# Shown when an app-dependent command (approve/host) runs where the host app isn't installed.
# host = CLI + app;  client = CLI only.  These commands need the app → guide to install it on the host.
need_app_guidance() {
  warn "this command needs the $APP_NAME app (the privileged daemon) — set up the HOST Mac:"
  cat >&2 <<EOF
   • One-shot host setup (app daemon + approve rules + skills + CLI):
       curl -fsSL https://raw.githubusercontent.com/${GH_REPO:-ghyeongl/remote-pair}/main/shared/bootstrap.sh | ROLE=host bash
   • App binary only: ${APP_NAME}.zip from Releases → ~/Applications → open once (daemon only;
     run the host setup above for approve rules + the approve skill).
       https://github.com/${GH_REPO:-ghyeongl/remote-pair}/releases/latest
   Then grant Accessibility + Screen Recording once. Verify with: remote-pair status
   (This client/CLI maps/launches/attaches; approve & host run where the app lives.)
EOF
}

# Is there a tty for interactive prompts?
have_tty() { [ -t 0 ] || [ -e /dev/tty ]; }

# Upsert KEY in client.env (persists mappings/config)
rp_set() {
  local k="$1" v="$2" f="$CLIENT_ENV"
  mkdir -p "$(dirname "$f")"; touch "$f"
  { grep -v "^$k=" "$f" 2>/dev/null || true; printf '%s=%q\n' "$k" "$v"; } > "$f.tmp" && mv "$f.tmp" "$f"
}

# ── mappings ──
map_client_of() { printf '%s' "${1%%::*}"; }
map_host_of()   { local p="$1" h="${1#*::}"; [ "$h" = "$p" ] && h="$p"; printf '%s' "$h"; }

resolve_host() { # $1=clientDir → echo hostDir (longest-prefix; same path if unmapped)
  local d="$1" best_c="" best_h="" c h pair IFS=';'
  for pair in $FOLDER_MAPS; do
    [ -n "$pair" ] || continue
    c="$(map_client_of "$pair")"; h="$(map_host_of "$pair")"
    case "$d" in "$c"|"$c"/*) [ "${#c}" -gt "${#best_c}" ] && { best_c="$c"; best_h="$h"; } ;; esac
  done
  [ -n "$best_c" ] && printf '%s%s' "$best_h" "${d#"$best_c"}" || printf '%s' "$d"
}
is_mapped() { local d="$1" c pair IFS=';'; for pair in $FOLDER_MAPS; do [ -n "$pair" ] || continue; c="$(map_client_of "$pair")"; case "$d" in "$c"|"$c"/*) return 0 ;; esac; done; return 1; }

cmd_map() {
  case "${1:-list}" in
    list|"") printf 'Folder mappings (client → host):\n'
             local pair IFS=';'; for pair in $FOLDER_MAPS; do [ -n "$pair" ] && printf '  %s  →  %s\n' "$(map_client_of "$pair")" "$(map_host_of "$pair")"; done
             [ -z "$FOLDER_MAPS" ] && echo "  (none)" ;;
    add) local cd hd
         cd="$(cd "${2:?clientDir required}" 2>/dev/null && pwd)" || { echo "client path not found: ${2:-}" >&2; return 1; }
         hd="${3:-$cd}"
         is_mapped "$cd" && { echo "already mapped (or under a mapped root): $cd"; return 0; }
         local entry="$cd::$hd"
         FOLDER_MAPS="${FOLDER_MAPS:+$FOLDER_MAPS;}$entry"; rp_set FOLDER_MAPS "$FOLDER_MAPS"
         ok "mapping added: $cd  →  $hd" ;;
    rm)  local d="${2:?clientDir required}" out="" pair IFS=';'
         for pair in $FOLDER_MAPS; do [ "$(map_client_of "$pair")" = "$d" ] || out="${out:+$out;}$pair"; done
         FOLDER_MAPS="$out"; rp_set FOLDER_MAPS "$FOLDER_MAPS"; ok "mapping removed: $d" ;;
    *) echo "map [list|add <clientDir> [hostDir]|rm <clientDir>]" >&2; return 2 ;;
  esac
}

cmd_ls() {
  cmd_map list; echo
  if [ -n "$REMOTE_HOST" ]; then
    echo "[$REMOTE_HOST] tmux-aqua sessions:"
    ssh -o BatchMode=yes -o ConnectTimeout=5 "$REMOTE_HOST" "\$HOME/.local/bin/tmux-aqua -S '$AQUA_SOCK' list-sessions 2>/dev/null" \
      | grep -v '^_keeper' | sed 's/^/  /' || echo "  (none or unreachable)"
  else
    echo "[local] tmux-aqua sessions:"; tm list-sessions 2>/dev/null | grep -v '^_keeper' | sed 's/^/  /' || echo "  (none)"
  fi
}

# Shared interactive mapping registration (Option A UX).
# Used by onboard Step 3 and the lazy [m] branch.
#   $1 = optional seed client dir. If given, fixes the client folder.
#        Otherwise input/auto-detect (default candidate: ~/Spaces if it exists, else $PWD).
# Non-interactive (no tty or RP_YES): auto-register with identity host path.
map_register_interactive() {
  local seed="${1:-}" client_dir="" host_dir="" ans=""
  # Resolve client folder
  if [ -n "$seed" ]; then
    client_dir="$(cd "$seed" 2>/dev/null && pwd)" || { warn "client path not found: $seed"; return 1; }
  else
    local cand="$PWD"; [ -d "$HOME/Spaces" ] && cand="$HOME/Spaces"
    if [ "$RP_YES" = 1 ] || ! have_tty; then
      client_dir="$cand"
    else
      { printf 'Client folder to map [%s]: ' "$cand" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
      client_dir="$(cd "${ans:-$cand}" 2>/dev/null && pwd)" || { warn "client path not found: ${ans:-$cand}"; return 1; }
    fi
  fi

  # Non-interactive: auto identity register.
  if [ "$RP_YES" = 1 ] || ! have_tty; then
    cmd_map add "$client_dir" "$client_dir"
    return $?
  fi

  if [ -z "$REMOTE_HOST" ]; then
    warn "REMOTE_HOST is not set — mapping host paths has no effect. Set a host first ('remote-pair config set host ...')."
  fi

  # Host path input: default = identity (client path), validated by ssh '[ -d ]'.
  while :; do
    { printf 'Host path that has this content [%s]: ' "$client_dir" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    host_dir="${ans:-$client_dir}"
    if [ -z "$REMOTE_HOST" ]; then
      break   # cannot probe without a host; accept as-is
    fi
    if ssh -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" "[ -d '$host_dir' ]" 2>/dev/null; then
      ok "exists on $REMOTE_HOST: $host_dir"
      break
    fi
    warn "not found on $REMOTE_HOST: $host_dir"
    { printf '  [r] re-enter path  [c] create it on host  [N] cancel: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    case "$ans" in
      c|C) ssh "$REMOTE_HOST" "mkdir -p '$host_dir'" 2>/dev/null && { ok "created on $REMOTE_HOST: $host_dir"; break; } || { warn "mkdir failed on $REMOTE_HOST"; } ;;
      r|R) : ;;
      *)   echo "cancelled."; return 1 ;;
    esac
  done

  # This folder only, or a parent sync root?
  { printf 'Map this folder only, or a parent sync root? [t]his / [p]arent root: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
  if [ "$ans" = p ] || [ "$ans" = P ]; then
    local croot hroot
    { printf '  Parent client root [%s]: ' "$(dirname "$client_dir")" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    croot="$(cd "${ans:-$(dirname "$client_dir")}" 2>/dev/null && pwd)" || croot="$(dirname "$client_dir")"
    { printf '  Parent host root [%s]: ' "$(dirname "$host_dir")" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    hroot="${ans:-$(dirname "$host_dir")}"
    cmd_map add "$croot" "$hroot" && echo "  All subfolders under $croot are now covered."
  else
    cmd_map add "$client_dir" "$host_dir"
  fi
}

cmd_config() {
  case "${1:-list}" in
    list|"")
      c "RemotePair client config"
      printf '%-12s %s\n' "host"     "${REMOTE_HOST:-(local-only)}"
      printf '%-12s %s\n' "terminal" "$TERMINAL_APP"
      printf '%-12s %s\n' "mappings" "$([ -n "$FOLDER_MAPS" ] && printf '%s' "$FOLDER_MAPS" | tr ';' '\n' | grep -c . || echo 0)"
      ;;
    get)
      case "${2:-}" in
        host)     printf '%s\n' "$REMOTE_HOST" ;;
        terminal) printf '%s\n' "$TERMINAL_APP" ;;
        *) echo "config get <host|terminal>" >&2; return 2 ;;
      esac
      ;;
    set)
      local key="${2:-}" val="${3:-}"
      case "$key" in
        host)
          rp_set REMOTE_HOST "$val"; REMOTE_HOST="$val"
          if [ -n "$val" ]; then
            ok "host set: $val"
            printf '  Checking SSH ... '
            if ssh -o BatchMode=yes -o ConnectTimeout=6 "$val" true 2>/dev/null; then echo "OK (key auth)"
            else echo "FAILED"; warn "SSH key auth failed — run 'remote-pair doctor' for guidance."; fi
          else
            ok "host cleared (local-only mode)"
          fi
          ;;
        terminal)
          case "$val" in
            iterm2|terminal) rp_set TERMINAL_APP "$val"; TERMINAL_APP="$val"; ok "terminal set: $val" ;;
            *) echo "config set terminal <iterm2|terminal>" >&2; return 2 ;;
          esac
          ;;
        *) echo "config set <host|terminal> <value>" >&2; return 2 ;;
      esac
      ;;
    maps) cmd_map list ;;
    *) echo "config [list|get <key>|set <key> <value>|maps]" >&2; return 2 ;;
  esac
}

# Open the configured terminal app in a NEW window running 'launch <dir>'.
cmd_open_gui() {
  local dir="${1:?dir required}"
  dir="$(cd "$dir" 2>/dev/null && pwd)" || { echo "folder not found: $1" >&2; return 1; }

  # Pick the app, falling back to the other if the configured one isn't installed.
  local app="$TERMINAL_APP"
  if [ "$app" = iterm2 ] && [ ! -d "$ITERM_PATH" ]; then
    warn "iTerm2 not installed — falling back to Terminal.app"; app=terminal
  elif [ "$app" = terminal ] && [ ! -e "$TERMINAL_PATH" ] && [ -d "$ITERM_PATH" ]; then
    warn "Terminal.app not found — falling back to iTerm2"; app=iterm2
  fi

  # Command string to run in the new window. Quote dir safely.
  local cmd
  cmd="exec $(printf '%q' "$SELF_CLI") launch $(printf '%q' "$dir")"

  if [ "$app" = iterm2 ]; then
    # AppleScript string escaping: backslash and double-quote.
    local esc="${cmd//\\/\\\\}"; esc="${esc//\"/\\\"}"
    osascript <<OSA
tell application "iTerm"
  activate
  if (count of windows) is 0 then
    set targetWindow to (create window with default profile)
  else
    tell current window to set newTab to (create tab with default profile)
    set targetWindow to current window
  end if
  tell current session of targetWindow to write text "$esc"
end tell
OSA
  else
    local esc="${cmd//\\/\\\\}"; esc="${esc//\"/\\\"}"
    osascript <<OSA
tell application "Terminal"
  activate
  do script "$esc"
end tell
OSA
  fi
}

# Fancy, re-runnable, pure-bash onboarding (bash 3.2, no new deps).
cmd_onboard() {
  local interactive=1
  { [ "$RP_YES" = 1 ] || ! have_tty; } && interactive=0

  # Header box
  local title="RemotePair client onboarding"
  local line; line="$(printf '%*s' $(( ${#title} + 2 )) '' | tr ' ' '─')"
  printf '\033[1;36m┌%s┐\033[0m\n' "$line"
  printf '\033[1;36m│ %s │\033[0m\n' "$title"
  printf '\033[1;36m└%s┘\033[0m\n' "$line"
  echo

  if [ "$interactive" = 0 ]; then
    echo "Non-interactive mode — applying detected defaults."
    printf '  host:     %s\n' "${REMOTE_HOST:-(local-only)}"
    printf '  terminal: %s\n' "$TERMINAL_APP"
    rp_set TERMINAL_APP "$TERMINAL_APP"
    echo
    cmd_doctor || true
    return 0
  fi

  local ans=""

  # Detect role: ~/.remote-pair/role — host|client|both (absent = host default, mirrors Installer.swift logic)
  local _rp_role=""
  [ -f "$RP_DIR/role" ] && _rp_role="$(cat "$RP_DIR/role" 2>/dev/null || true)"
  local _is_client=0 _is_host=0
  case "$_rp_role" in
    client) _is_client=1 ;;
    host|both|"") _is_host=1 ;;
  esac

  # Step 1: REMOTE_HOST
  c "Step 1/4 — Remote host"
  printf '  Current: %s\n' "${REMOTE_HOST:-(local-only)}"
  { printf '  SSH host (blank = local-only): ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
  if [ -n "$ans" ]; then
    cmd_config set host "$ans"
    # Re-read so subsequent steps see the new value
    REMOTE_HOST="$ans"
  else
    echo "  Keeping: ${REMOTE_HOST:-(local-only)}"
  fi
  echo

  # ── CLIENT-ONLY path: SSH-assist + handshake verify; skip local-app/permission steps ──
  if [ "$_is_client" = 1 ]; then
    c "Step 2/4 — SSH key setup (client-access-only mode)"

    if [ -z "$REMOTE_HOST" ]; then
      warn "REMOTE_HOST not set — skipping SSH setup (local-only mode)"
    else
      # Check for existing public key
      local _pubkey=""
      _pubkey="$(ls "$HOME/.ssh/id_"*.pub 2>/dev/null | head -1 || true)"
      if [ -z "$_pubkey" ]; then
        warn "No SSH public key found (~/.ssh/id_*.pub)"
        { printf '  Generate a new ed25519 key now? [Y/n]: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
        case "${ans:-y}" in
          [nN]*) echo "  Skipped. Create manually: ssh-keygen -t ed25519" ;;
          *)
            ssh-keygen -t ed25519 -f "$HOME/.ssh/id_ed25519" -N "" </dev/null
            _pubkey="$HOME/.ssh/id_ed25519.pub"
            ok "Key generated: $_pubkey"
            ;;
        esac
      fi

      if [ -n "$_pubkey" ]; then
        echo
        printf '  \033[1mYour public key\033[0m (%s):\n' "$_pubkey"
        cat "$_pubkey"
        echo
        printf '  Add to host with ssh-copy-id? [Y/n]: ' >/dev/tty; read -r ans </dev/tty
        case "${ans:-y}" in
          [nN]*) printf '  Manual: append the key above to %s:~/.ssh/authorized_keys\n' "$REMOTE_HOST" ;;
          *)
            ssh-copy-id -i "$_pubkey" "$REMOTE_HOST" </dev/tty || warn "ssh-copy-id failed — add the key manually"
            ;;
        esac
        echo
      fi

      # Verify key auth
      printf '  Verifying SSH key auth to %s … ' "$REMOTE_HOST" >/dev/tty
      if ssh -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" true 2>/dev/null; then
        ok "SSH key auth OK — passwordless connection verified"
      else
        warn "SSH key auth FAILED. Fix and rerun 'remote-pair onboard'."
        printf '  Hint: ssh -o BatchMode=yes %s true && echo OK\n' "$REMOTE_HOST"
      fi
    fi
    echo

    c "Step 3/4 — Terminal app"
    local has_iterm="no" has_term="no"
    [ -d "$ITERM_PATH" ] && has_iterm="yes"
    [ -e "$TERMINAL_PATH" ] && has_term="yes"
    printf '  iTerm2 installed: %s   Terminal.app: %s\n' "$has_iterm" "$has_term"
    { printf '  Choose terminal app [iterm2/terminal] (default %s): ' "$TERMINAL_APP" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    case "${ans:-$TERMINAL_APP}" in
      iterm2|terminal) cmd_config set terminal "${ans:-$TERMINAL_APP}" ;;
      *) warn "unknown value '$ans' — keeping $TERMINAL_APP" ;;
    esac
    echo

    c "Step 4/4 — Folder mapping"
    cmd_map list
    { printf '  Register a folder mapping now? [Y/n]: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
    case "${ans:-y}" in [nN]*) echo "  Skipped." ;; *) map_register_interactive || true ;; esac
    echo

    ok "Onboarding complete (client mode — no local app/permission steps). Edit later with 'remote-pair config' / 'remote-pair map'."
    return 0
  fi

  # ── HOST / BOTH path: original flow ──
  # Step 2: Terminal app
  c "Step 2/4 — Terminal app"
  local has_iterm="no" has_term="no"
  [ -d "$ITERM_PATH" ] && has_iterm="yes"
  [ -e "$TERMINAL_PATH" ] && has_term="yes"
  printf '  iTerm2 installed: %s   Terminal.app: %s\n' "$has_iterm" "$has_term"
  { printf '  Choose terminal app [iterm2/terminal] (default %s): ' "$TERMINAL_APP" >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
  case "${ans:-$TERMINAL_APP}" in
    iterm2|terminal) cmd_config set terminal "${ans:-$TERMINAL_APP}" ;;
    *) warn "unknown value '$ans' — keeping $TERMINAL_APP" ;;
  esac
  echo

  # Step 3: Folder mapping
  c "Step 3/4 — Folder mapping"
  cmd_map list
  { printf '  Register a folder mapping now? [Y/n]: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
  case "${ans:-y}" in [nN]*) echo "  Skipped." ;; *) map_register_interactive || true ;; esac
  echo

  # Step 4: doctor + local AX/SR grant gate
  c "Step 4/4 — Verify (local permissions)"
  cmd_doctor || true
  echo
  # Gate: confirm AX+SR are granted before declaring completion
  local _sj_local=""
  [ -f "$STATUS_FILE" ] && _sj_local="$(cat "$STATUS_FILE" 2>/dev/null || true)"
  if [ -n "$_sj_local" ]; then
    local _ax _sr
    _ax="$(_jget "$_sj_local" ax)"; _sr="$(_jget "$_sj_local" sr)"
    if [ "$_ax" = true ] && [ "$_sr" = true ]; then
      ok "Onboarding complete. AX✓ SR✓ — computer-use ready. Edit later with 'remote-pair config' / 'remote-pair map'."
    else
      warn "Not done yet: System Settings → Privacy & Security → turn $APP_NAME ON for Accessibility (AX=$_ax) and Screen Recording (SR=$_sr). Re-run 'remote-pair onboard' to confirm."
    fi
  else
    ok "Onboarding complete. Edit later with 'remote-pair config' / 'remote-pair map'."
    warn "Could not read status.json — verify AX+SR grants in System Settings if this is a host machine."
  fi
}

cmd_launch() {
  local pass=() dir=""
  while [ $# -gt 0 ]; do case "$1" in
    --local|--remote|--fresh|--yes|-y) pass+=("$1"); [ "$1" = "--yes" ] || [ "$1" = "-y" ] && RP_YES=1; shift ;;
    *) dir="$1"; shift ;;
  esac; done
  dir="$(cd "${dir:-$PWD}" 2>/dev/null && pwd)" || { echo "folder not found" >&2; return 1; }
  if ! is_mapped "$dir" && [ -n "$REMOTE_HOST" ] && [ "$RP_YES" != 1 ]; then
    # Active host probe: only when the host is reachable. Resolve the candidate host
    # path and check whether it actually exists on the host.
    if ssh -n -o BatchMode=yes -o ConnectTimeout=4 "$REMOTE_HOST" true 2>/dev/null; then
      local hostdir; hostdir="$(resolve_host "$dir")"
      if ssh -n -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" "[ -d '$hostdir' ]" 2>/dev/null; then
        # Exists on host → offer to register.
        c "This folder is outside any registered mapping:"
        printf '  client: %s\n' "$dir"
        printf '  host:   %s\n' "$hostdir"
        ok "exists on $REMOTE_HOST"
        local ans=""
        { printf '  Register this mapping for next time? [Y/n]: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
        case "${ans:-y}" in [nN]*) : ;; *) cmd_map add "$dir" "$hostdir" ;; esac
      else
        # Missing on host → no "launch once anyway" (tmux would silently fall back to $HOME).
        c "This folder is outside any registered mapping:"
        printf '  client: %s\n' "$dir"
        printf '  host:   %s\n' "$hostdir"
        warn "not found on $REMOTE_HOST — usually this folder should also exist on the host via sync."
        local ans=""
        { printf '  [m] map to the host path that actually has this content
  [c] create an empty dir on host (new project only — content will not be synced here)
  [N] cancel
  choose: ' >/dev/tty; read -r ans </dev/tty; } 2>/dev/null || true
        case "$ans" in
          m|M) map_register_interactive "$dir" || return 1 ;;
          c|C) ssh "$REMOTE_HOST" "mkdir -p '$hostdir'" 2>/dev/null && ok "created on $REMOTE_HOST: $hostdir" || { echo "mkdir failed on $REMOTE_HOST" >&2; return 1; } ;;
          *)   echo "cancelled." >&2; return 1 ;;
        esac
      fi
      echo "  Edit later with 'remote-pair config' / 'remote-pair map'."
    fi
    # ssh-probe failure: just proceed — defer to the launcher's own dir-check.
  fi
  [ -x "$LAUNCHER" ] || { echo "launcher missing: $LAUNCHER (client install required)" >&2; return 1; }
  # bash 3.2 + set -u: an empty array "${pass[@]}" is "unbound" → guard with ${arr[@]+...}
  RP_YES="$RP_YES" exec "$LAUNCHER" ${pass[@]+"${pass[@]}"} "$dir"
}

cmd_host() {
  if host_up; then ok "host server OK ($AQUA_SOCK)"; return 0; fi
  # Starting the server means launching the local app. If the app isn't installed here, guide instead.
  # Existence covers BOTH locations (cask /Applications + manual ~/Applications) and BOTH app names (legacy).
  local _installed=0 d
  for d in "/Applications" "$HOME/Applications"; do
    { [ -d "$d/$APP_NAME.app" ] || [ -d "$d/$FORWARD_APP.app" ]; } && { _installed=1; break; }
  done
  if [ "$_installed" = 0 ] && [ -z "$(app_pid)" ]; then need_app_guidance; return 1; fi
  c "host server not running → starting $APP_NAME ..."
  # Try the current identity first, then fall back to the forward one (open -a / kickstart).
  open -a "$APP_NAME" 2>/dev/null || open -a "$FORWARD_APP" 2>/dev/null \
    || launchctl kickstart -k "gui/$(id -u)/$BUNDLE_PREFIX" 2>/dev/null \
    || launchctl kickstart -k "gui/$(id -u)/$FORWARD_BUNDLE" 2>/dev/null || true
  for _ in $(seq 1 12); do host_up && { ok "host server OK"; return 0; }; sleep 0.5; done
  warn "host server failed to start — check System Settings permissions / app install"; return 13
}

cmd_status() {
  local p; p="$(app_pid)"
  if [ -n "$p" ]; then printf '%-14s %s\n' "app" "running (pid $p)"
  else                 printf '%-14s %s\n' "app" "NOT running"; fi
  printf '%-14s %s\n' "host server" "$(host_up && echo "up ($AQUA_SOCK)" || echo down)"
  # Ground truth from the app's status.json — AX/SR are the real computer-use gates.
  # This lets you tell "app up but NOT granted" (→ re-grant) from "app down" (→ start it) —
  # instead of guessing. The app rewrites this every ~1s while alive.
  if [ -f "$STATUS_FILE" ]; then
    local s sage sts; s="$(cat "$STATUS_FILE" 2>/dev/null)"
    sts="$(_jget "$s" ts)"; sage=$(( $(date +%s) - ${sts:-0} ))
    printf '%-14s AX %s  SR %s  FDA %s   (status.json, %ss ago%s)\n' "permissions" \
      "$(_mark "$(_jget "$s" ax)")" "$(_mark "$(_jget "$s" sr)")" "$(_mark "$(_jget "$s" fda)")" \
      "$sage" "$([ "$sage" -gt 15 ] && echo ' — STALE, app may be down')"
    [ "$(_jget "$s" ax)" = true ] && [ "$(_jget "$s" sr)" = true ] || \
      printf '%-14s %s\n' "" "⚠ computer-use gated: AX+SR must both be ✓. If ✗, the app is running but NOT granted → grant in System Settings (this is NOT 'host down')."
  elif [ -n "$p" ] || host_up; then
    printf '%-14s %s\n' "permissions" "unknown (no status.json yet — update host app)"
  fi
  if [ -f "$HEARTBEAT_FILE" ]; then
    local age=$(( $(date +%s) - $(stat -f %m "$HEARTBEAT_FILE" 2>/dev/null || echo 0) ))
    printf '%-14s %s\n' "heartbeat" "${age}s ago $([ "$age" -le 90 ] && echo "(fresh)" || echo "(STALE)")"
  else printf '%-14s %s\n' "heartbeat" "none (app not running?)"; fi
  in_host_session && printf '%-14s %s\n' "this session" "INSIDE RemotePair host → computer-use available here"
  printf '%-14s %s\n' "remote" "${REMOTE_HOST:-(local-only)}"
  printf '%-14s %s\n' "bundle" "$BUNDLE_PREFIX"
  return 0
}

cmd_doctor() {
  local fail=0
  c "RemotePair doctor"
  # If we're ON the host (inside its tmux) or the app's status.json exists, report local app/grant
  # ground truth FIRST. This is the check that prevents the "host is down" misdiagnosis: the app
  # liveness comes from launchctl + status.json (reliable), not pgrep (false-negatives on .app).
  if in_host_session || [ -f "$STATUS_FILE" ]; then
    c "host app (this machine)"
    cmd_status | sed 's/^/  /'
    echo
  fi
  # local (client)
  printf '%-22s %s\n' "launcher" "$([ -x "$LAUNCHER" ] && echo "OK ($LAUNCHER)" || { echo "missing — install.sh --role client"; fail=1; })"
  printf '%-22s %s\n' "mosh (local)" "$(command -v mosh >/dev/null && echo OK || echo "missing (ssh fallback)")"
  printf '%-22s %s\n' "folder mappings" "$([ -n "$FOLDER_MAPS" ] && echo "$(printf '%s' "$FOLDER_MAPS" | tr ';' '\n' | grep -c .) entries" || echo "none (registered on first launch)")"

  # ── Informational rows (US-006): file-access backend, notify hook. ──
  # These never affect the verdict (no fail=1) — they help users see what's wired.
  # (b) file-access backend: mount → check active mount; syncthing → best-effort local daemon probe.
  local _sync_backend="${SYNC_BACKEND:-syncthing}"
  if [ "$_sync_backend" = mount ]; then
    local _mount_tool _mounted="not mounted"
    if _mount_tool="$(_resolve_client_tool remote-pair-mount 2>/dev/null)"; then
      if "$_mount_tool" status 2>/dev/null | grep -qvE '^\s*\(none\)\s*$' \
         && "$_mount_tool" status 2>/dev/null | grep -qE '(smbfs|sshfs|macfuse|osxfuse|mounts)'; then
        _mounted="mounted"
      fi
    fi
    printf '%-22s %s\n' "file access (mount)" "backend=${MOUNT_BACKEND:-smb} — $_mounted"
  else
    # syncthing is optional/external — never hard-fail; just report reachability of the local GUI/API.
    local _st="not detected (optional — only needed if you use Syncthing sync)"
    if command -v curl >/dev/null 2>&1; then
      curl -sf -o /dev/null --max-time 2 http://127.0.0.1:8384/ 2>/dev/null && _st="up (127.0.0.1:8384)"
    elif command -v nc >/dev/null 2>&1; then
      nc -z -G 2 127.0.0.1 8384 >/dev/null 2>&1 && _st="up (127.0.0.1:8384)"
    fi
    printf '%-22s %s\n' "file access (sync)" "Syncthing $_st"
  fi
  # (c) notify hook: is host notification forwarding installed on the host? Best-effort over SSH.
  if [ -n "$REMOTE_HOST" ]; then
    printf '%-22s %s\n' "host notify hook" "$(ssh -o BatchMode=yes -o ConnectTimeout=4 "$REMOTE_HOST" 'grep -q remote-pair-notify ~/.claude/settings.json 2>/dev/null' 2>/dev/null && echo "OK (forwarding installed)" || echo "not detected (install.sh --role host on the host)")"
  else
    printf '%-22s %s\n' "host notify hook" "n/a (no REMOTE_HOST — host-side hook)"
  fi

  if [ -z "$REMOTE_HOST" ]; then
    warn "REMOTE_HOST not set — local-only mode (skipping remote checks)"; return "$fail"
  fi
  # SSH key connection
  printf '%-22s ' "SSH ($REMOTE_HOST)"
  if ssh -o BatchMode=yes -o ConnectTimeout=6 "$REMOTE_HOST" true 2>/dev/null; then
    echo "OK (key auth passed)"
  else
    echo "FAILED"; fail=1
    warn "SSH key auth failed. Fix with one of:"
    cat >&2 <<EOF
   1) No key? Create one:   ssh-keygen -t ed25519
   2) Register the public key on the host:   ssh-copy-id $REMOTE_HOST
   3) Check the Host alias (IdentityFile/User/HostName) in ~/.ssh/config
   4) Using an SSH agent (e.g. 1Password): approve/unlock it (remote-pair approve can auto-click)
   Verify:   ssh -o BatchMode=yes $REMOTE_HOST true && echo OK
EOF
    return "$fail"
  fi
  # host-side config
  local rb='$HOME/.local/bin/tmux-aqua'
  printf '%-22s %s\n' "host tmux-aqua" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "[ -x $rb ]" 2>/dev/null && echo OK || { echo "missing — run install.sh --role host on the host"; fail=1; })"
  printf '%-22s %s\n' "host app" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "[ -d ~/Applications/$APP_NAME.app ]" 2>/dev/null && echo "OK ($APP_NAME.app)" || { echo "missing"; fail=1; })"
  printf '%-22s %s\n' "host server" "$(ssh -o BatchMode=yes "$REMOTE_HOST" "$rb -S '$AQUA_SOCK' has-session" 2>/dev/null && echo "up" || echo "down (check app launch/permissions)")"
  # approve path (skill + hook) — the key to clearing GUI approval dialogs on a headless host. Both are installed by install.sh --role host.
  printf '%-22s %s\n' "host approve skill" "$(ssh -o BatchMode=yes "$REMOTE_HOST" '[ -f ~/.claude/skills/approve/SKILL.md ]' 2>/dev/null && echo OK || { echo "missing — install.sh --role host"; fail=1; })"
  printf '%-22s %s\n' "host approve hook" "$(ssh -o BatchMode=yes "$REMOTE_HOST" 'grep -q remote-pair-approve-reminder ~/.claude/settings.json 2>/dev/null' 2>/dev/null && echo OK || { echo "missing — install.sh --role host (or python3 absent)"; fail=1; })"
  # AX/SR grant — the real gate for computer-use (= approve clicks/screenshots). Read from status.json (ground truth).
  local sj; sj="$(ssh -o BatchMode=yes "$REMOTE_HOST" 'cat ~/.remote-pair/logs/status.json 2>/dev/null' 2>/dev/null)"
  if [ -n "$sj" ]; then
    local ax sr; ax="$(_jget "$sj" ax)"; sr="$(_jget "$sj" sr)"
    printf '%-22s %s\n' "host AX+SR grant" "$([ "$ax" = true ] && [ "$sr" = true ] && echo "OK (AX✓ SR✓)" || { echo "NOT granted (AX $(_mark "$ax") SR $(_mark "$sr")) — turn these ON in System Settings for computer-use/approve to work"; fail=1; })"
  else
    printf '%-22s %s\n' "host AX+SR grant" "unknown (status.json absent — update the host app)"
  fi
  [ "$fail" = 0 ] && ok "all good — remote-pair launch ready" || warn "check the items above"
  return "$fail"
}

cmd_approve() {
  local forhint="" type="" timeout=22     # longer than the router's adaptive polling (~18s default)
  while [ $# -gt 0 ]; do case "$1" in
    --for|--label|--expect) forhint="${2:-}"; shift 2 ;;   # hint for which approval dialog (rule id/free text; alias-tolerant)
    --type) type="${2:-}"; shift 2 ;;                       # how to approve — key:<combo> | ocr:<label> (the agent picks the method)
    --timeout) timeout="${2:-22}"; shift 2 ;;
    *) echo "unknown arg: $1" >&2; return 2 ;;
  esac; done
  # approve needs the privileged app. If it isn't here (e.g. a client-only machine), guide to install
  # the host app instead of silently sending a trigger nobody will pick up.
  if ! app_available; then need_app_guidance; return 1; fi
  # base0 = log length just before triggering (so we show only this request's router log to the agent)
  local base0=0; [ -f "$LOG_FILE" ] && base0=$(wc -l < "$LOG_FILE")
  local base="$base0"
  # Pass the hint: the router reads the .label file to prioritize the matching rule + use it as a haiku prior, then consumes it.
  if [ -n "$forhint" ]; then printf '%s\n' "$forhint" > "$APPROVE_TRIGGER.label" 2>/dev/null || true
  else rm -f "$APPROVE_TRIGGER.label" 2>/dev/null || true; fi
  if [ -n "$type" ]; then printf '%s\n' "$type" > "$APPROVE_TRIGGER.type" 2>/dev/null || true
  else rm -f "$APPROVE_TRIGGER.type" 2>/dev/null || true; fi
  : > "$APPROVE_TRIGGER" 2>/dev/null || { echo "failed to write trigger: $APPROVE_TRIGGER" >&2; return 1; }
  echo "approve request → $APP_NAME${forhint:+ (expect: $forhint)} (observing up to ${timeout}s)"
  # Print only this request's router log lines (so the agent can read the result and decide next steps).
  _router_trail() { [ -f "$LOG_FILE" ] || return 0; local tot; tot=$(wc -l < "$LOG_FILE"); [ "$tot" -gt "$base0" ] && tail -n "$(( tot - base0 ))" "$LOG_FILE" | grep 'router:'; }
  local end=$(( $(date +%s) + timeout ))
  while [ "$(date +%s)" -lt "$end" ]; do
    if [ -f "$LOG_FILE" ]; then
      local now; now=$(wc -l < "$LOG_FILE")
      if [ "$now" -gt "$base" ]; then
        local new; new=$(tail -n "$(( now - base ))" "$LOG_FILE")
        if printf '%s\n' "$new" | grep -qiE 'router:.*success'; then
          _router_trail | sed 's/^/  /'
          echo "✓ handled (window-close verified)"; return 0
        fi
        base="$now"
      fi
    fi
    sleep 0.5
  done
  # Timeout/failure: show this request's router log so the agent can read the cause and decide.
  echo "✗ not handled within ${timeout}s — router log:" >&2
  local trail; trail="$(_router_trail)"
  if [ -n "$trail" ]; then printf '%s\n' "$trail" | sed 's/^/  /' >&2
  else echo "  (no router log — check app/permissions/trigger. full: $LOG_FILE)" >&2; fi
  echo "  → If the window appears late: re-trigger non-blocking, then immediately retry the blocked call. For an unknown window, add a rule to $RP_DIR/rules.txt." >&2
  return 1
}

# remote-pair logs [--host] [-f] [-n N] [--collect]
#   default: tail all local logs (glob $LOG_DIR/*.log).
#   --host: tail host logs over ssh.  -f: follow.  --collect: tar+gzip $LOG_DIR for bug reports.
cmd_logs() {
  local host=0 follow=0 n=200 collect=0
  while [ $# -gt 0 ]; do case "$1" in
    --host)      host=1; shift ;;
    -f|--follow) follow=1; shift ;;
    -n)          n="${2:-200}"; shift 2 ;;
    --collect)   collect=1; shift ;;
    *)           shift ;;
  esac; done

  # --collect: tar+gzip $LOG_DIR → $LOG_DIR/remote-pair-logs-<stamp>.tgz and print path
  if [ "$collect" = 1 ]; then
    local stamp out
    stamp="$(date +%Y%m%d-%H%M%S)"
    out="${RP_DIR}/logs/remote-pair-logs-${stamp}.tgz"
    tar -czf "$out" -C "$(dirname "${RP_DIR}/logs")" "$(basename "${RP_DIR}/logs")" 2>/dev/null \
      || { warn "collect: tar failed"; return 1; }
    printf '%s\n' "$out"
    return
  fi

  if [ "$host" = 1 ]; then
    [ -n "$REMOTE_HOST" ] || { echo "no REMOTE_HOST configured — 'remote-pair config set host <ssh-host>'" >&2; return 1; }
    local rl='$HOME/.remote-pair/logs'
    if [ "$follow" = 1 ]; then exec ssh -t "$REMOTE_HOST" "tail -n $n -F $rl/*.log 2>/dev/null"
    else ssh "$REMOTE_HOST" "tail -n $n $rl/*.log 2>/dev/null || echo '(no host logs at ~/.remote-pair/logs)'"; fi
    return
  fi

  # Local: glob all *.log files in $LOG_DIR (covers cli.log, remote-pair.log, launchd captures, etc.)
  local log_dir="${RP_DIR}/logs"
  if [ "$follow" = 1 ]; then
    # shellcheck disable=SC2086
    exec tail -n "$n" -F "$log_dir"/*.log 2>/dev/null
  else
    # shellcheck disable=SC2086
    tail -n "$n" "$log_dir"/*.log 2>/dev/null || echo "(no local logs at $log_dir)"
  fi
}

# Self-update the client (launcher/CLI/romanize) to the latest from GitHub — prevents version drift with the host app (e.g. unrecognized --type).
cmd_self_update() {
  local repo="${GH_REPO:-ghyeongl/remote-pair}" ref="${1:-main}"
  local base="https://raw.githubusercontent.com/$repo/$ref/client"
  c "self-update ← $repo@$ref"
  local tmp; tmp="$(mktemp -d)" || { warn "mktemp failed"; return 1; }
  local got=0 f
  for f in remote-pair remote-pair-launch hangul-romanize; do
    curl -fsSL "$base/$f" -o "$tmp/$f" 2>/dev/null && [ -s "$tmp/$f" ] && got=$((got+1))
  done
  # logging.sh lives in shared/, not client/ — fetch separately so a flat client loop won't 404.
  local shared_base="https://raw.githubusercontent.com/$repo/$ref/shared"
  curl -fsSL "$shared_base/logging.sh" -o "$tmp/logging.sh" 2>/dev/null && [ -s "$tmp/logging.sh" ] && got=$((got+1))
  [ "$got" -ge 2 ] || { warn "download failed (got=$got) — check network/repo"; rm -rf "$tmp"; return 1; }
  [ -s "$tmp/remote-pair" ]        && { chmod +x "$tmp/remote-pair";        mv "$tmp/remote-pair" "$SELF_CLI" && ok "CLI → $SELF_CLI"; }
  [ -s "$tmp/remote-pair-launch" ] && { chmod +x "$tmp/remote-pair-launch"; mkdir -p "$(dirname "$LAUNCHER")"; mv "$tmp/remote-pair-launch" "$LAUNCHER" && ok "launcher → $LAUNCHER"; }
  [ -s "$tmp/hangul-romanize" ]    && { chmod +x "$tmp/hangul-romanize";    mkdir -p "$RP_DIR/bin"; mv "$tmp/hangul-romanize" "$RP_DIR/bin/hangul-romanize"; }
  [ -s "$tmp/logging.sh" ]         && { mkdir -p "$RP_DIR/bin"; mv "$tmp/logging.sh" "$RP_DIR/bin/logging.sh" && ok "logger → $RP_DIR/bin/logging.sh"; }
  rm -rf "$tmp"; ok "self-update complete — applies from the next invocation"
}

# Resolve a sibling client tool (installed → LOCAL_BIN/~/.remote-pair/bin → repo copy).
# Echoes the path, or returns 1. Used by editor/desktop to resolve their launcher.
_resolve_client_tool() {
  local name="$1" p=""
  if command -v "$name" >/dev/null 2>&1; then p="$(command -v "$name")"
  elif [ -x "$LOCAL_BIN/$name" ]; then p="$LOCAL_BIN/$name"
  elif [ -x "$RP_DIR/bin/$name" ]; then p="$RP_DIR/bin/$name"
  else
    local _repo; _repo="$(cd "$(dirname "$0")" 2>/dev/null && pwd)/$name"
    [ -x "$_repo" ] && p="$_repo"
  fi
  [ -n "$p" ] && { printf '%s' "$p"; return 0; }
  return 1
}

# remote-pair editor — code-server launcher (M4). Thin pass-through to remote-pair-editor.
cmd_editor() {
  local tool; tool="$(_resolve_client_tool remote-pair-editor)" \
    || { echo "remote-pair-editor not found (install client, or run from the repo)" >&2; return 1; }
  exec "$tool" "$@"
}

# remote-pair desktop — macOS Screen Sharing launcher (M5). Thin pass-through to remote-pair-desktop.
cmd_desktop() {
