#!/usr/bin/env bash
# xpair-askpass — SSH_ASKPASS helper for the Xpair client.
#
# Purpose: collect ONE secret (account password OR key passphrase) in a process
# distinct from the parent CLI/Electron renderer, so the secret NEVER transits a
# parent that logs/telemeters. Invoked by ssh ONLY when there is no controlling
# TTY and SSH_ASKPASS_REQUIRE=force is set (OpenSSH 8.4+). ssh passes its prompt
# string as $1 (e.g. "<user>@<host>'s password:" or "Enter passphrase for key …").
#
#   SSH_ASKPASS=<this> SSH_ASKPASS_REQUIRE=force setsid -w ssh … <  /dev/null
#
# Invariants (security-critical — see plan C5):
#   • The secret is read here and written to STDOUT only. ssh consumes stdout.
#   • The secret is NEVER echoed to a terminal, written to a log, persisted to
#     disk, put in an env var, or emitted to telemetry. Diagnostics go to stderr
#     and contain only the (non-secret) prompt label.
#   • On cancel / read failure → exit non-zero with NO output, so ssh fails closed.
#
# The secret may be supplied two ways (the caller picks based on environment):
#   1) RP_ASKPASS_FD=<n>   → read one line from that inherited file descriptor
#      (the recommended path: the bridge/CLI writes the secret to a pipe; nothing
#      touches argv, env values, or the filesystem).
#   2) interactive GUI prompt via osascript "display dialog … with hidden answer"
#      (headless/no-Electron fallback; the secret is typed into the OS dialog only).
# If neither is available, fail closed.
set -euo pipefail

# ssh's prompt text (label only — safe to show; never the secret).
prompt="${1:-Password:}"

emit_secret() {
  # $1 = secret. Write verbatim to stdout (ssh reads this), then scrub the var.
  printf '%s\n' "$1"
  unset _secret 2>/dev/null || true
}

# ── Path 1: FIFO by path (no argv/env-value/disk exposure) ──
# Preferred handoff: the caller writes ONE line to a private FIFO and passes its PATH here. Unlike an
# inherited fd, a path-opened FIFO survives ssh's exec of this helper (ssh closes fds >2 first), so
# this is the mechanism that actually works through ssh→askpass. The env holds only the path.
if [ -n "${RP_ASKPASS_FIFO:-}" ]; then
  [ -p "$RP_ASKPASS_FIFO" ] || { printf 'xpair-askpass: RP_ASKPASS_FIFO is not a fifo\n' >&2; exit 2; }
  _secret=""
  IFS= read -r _secret < "$RP_ASKPASS_FIFO" || { printf 'xpair-askpass: no secret on fifo\n' >&2; exit 3; }
  [ -n "$_secret" ] || { printf 'xpair-askpass: empty secret\n' >&2; exit 3; }
  emit_secret "$_secret"
  exit 0
fi

# ── Path 2 (legacy/no-op through ssh): inherited FD — kept only for direct (non-ssh) callers ──
if [ -n "${RP_ASKPASS_FD:-}" ]; then
  case "$RP_ASKPASS_FD" in
    (''|*[!0-9]*) printf 'xpair-askpass: bad RP_ASKPASS_FD\n' >&2; exit 2 ;;
  esac
  _secret=""
  # Read exactly one line from the inherited descriptor. Fail closed if empty/closed.
  IFS= read -r _secret <&"$RP_ASKPASS_FD" || { printf 'xpair-askpass: no secret on fd %s\n' "$RP_ASKPASS_FD" >&2; exit 3; }
  [ -n "$_secret" ] || { printf 'xpair-askpass: empty secret\n' >&2; exit 3; }
  emit_secret "$_secret"
  exit 0
fi

# ── Path 2: native GUI prompt (osascript) — secret stays inside the OS dialog ──
if command -v osascript >/dev/null 2>&1; then
  # Escape the (non-secret) prompt label for AppleScript string context.
  esc="${prompt//\\/\\\\}"; esc="${esc//\"/\\\"}"
  _secret="$(osascript <<OSA 2>/dev/null
try
  set r to display dialog "Xpair: $esc" default answer "" with hidden answer with title "Xpair" buttons {"Cancel", "OK"} default button "OK"
  text returned of r
on error
  ""
end try
OSA
)" || { printf 'xpair-askpass: dialog failed\n' >&2; exit 4; }
  [ -n "$_secret" ] || { printf 'xpair-askpass: cancelled\n' >&2; exit 5; }
  emit_secret "$_secret"
  exit 0
fi

printf 'xpair-askpass: no secret source (set RP_ASKPASS_FD or install osascript)\n' >&2
exit 6
