#!/usr/bin/env bash
# remote-pair-desktop — open the host screen for viewing via macOS Screen Sharing (VNC).
#
# Usage:
#   remote-pair-desktop [open]   Open vnc://<REMOTE_HOST> in macOS Screen Sharing (default)
#   remote-pair-desktop check    Check whether REMOTE_HOST is reachable and port 5900 is open (best-effort)
#   remote-pair-desktop help     Print this help
#
# Prerequisites (HOST-SIDE MANUAL STEP — like TCC grants):
#   On the host Mac: System Settings > General > Sharing > enable "Screen Sharing" (or Remote Management).
#   This exposes port 5900 (VNC). No extra software needed on the client — macOS ships a built-in
#   Screen Sharing client (/System/Library/CoreServices/Screen Sharing.app).
#
# REMOTE_HOST comes from ~/.remote-pair/client.env (set by 'remote-pair config set host <alias>')
#   or from the environment. It must be an ssh alias or hostname resolvable on the client.
#
# License: RemotePair is AGPL-3.0-or-later, pure first-party code (no external AGPL deps).
#   macOS Screen Sharing (vnc://) is an OS-provided client: zero dependency, zero licensing risk.
#   Screen sharing uses our own host/rd/screen engine.
#
# Roadmap (see docs/m5-remote-desktop.md):
#   v0   — this script (macOS Screen Sharing, arm's-length)
#   v0.5 — in-web low-fps screencapture feed reusing the existing InputServer SR grant
#   v1   — WebRTC / ScreenCaptureKit + VideoToolbox (requires Input Monitoring on host)

set -euo pipefail

# ── config (single source of truth: ~/.remote-pair) ──
RP_DIR="${RP_DIR:-$HOME/.remote-pair}"
for _f in common host client; do
  # shellcheck disable=SC1090
  [ -f "$RP_DIR/$_f.env" ] && { set -a; . "$RP_DIR/$_f.env"; set +a; }
done
REMOTE_HOST="${REMOTE_HOST:-}"

# Source the shared logger; no-op fallback for partially-updated clients.
# shellcheck disable=SC1090
[ -f "$RP_DIR/bin/logging.sh" ] && . "$RP_DIR/bin/logging.sh"
type rp_log >/dev/null 2>&1 || { rp_log(){ :; }; log_info(){ :; }; log_warn(){ printf '%s\n' "$*" >&2; }; log_error(){ printf '%s\n' "$*" >&2; }; err(){ printf '\033[1;31m✗ %s\033[0m\n' "$*" >&2; }; info(){ printf '\033[1;36m▸ %s\033[0m\n' "$*"; }; warn(){ printf '\033[1;33m⚠ %s\033[0m\n' "$*" >&2; }; }

# ── UI-only helpers (err/info/warn come from logging.sh or the fallback above) ──
ok() { printf '\033[1;32m✓ %s\033[0m\n' "$*"; }

require_host() {
  if [ -z "$REMOTE_HOST" ]; then
    err "REMOTE_HOST is not set."
    printf >&2 '  Set it with:  remote-pair config set host <ssh-alias>\n'
    printf >&2 '  Or export it: export REMOTE_HOST=<ssh-alias>\n'
    exit 1
  fi
}

cmd_open() {
  require_host
  local url="vnc://${REMOTE_HOST}"
  info "Opening $url via macOS Screen Sharing …"
  # 'open vnc://…' hands off to /System/Library/CoreServices/Screen\ Sharing.app.
  # Screen Sharing prompts for VNC credentials (set on the host in Sharing prefs).
  open "$url"
  ok "Screen Sharing launched for $REMOTE_HOST"
  printf '  If prompted for a password, use the VNC password set on the host\n'
  printf '  (System Settings > General > Sharing > Screen Sharing > "VNC viewers may control screen with password").\n'
}

cmd_check() {
  require_host
  info "Checking $REMOTE_HOST …"

  # 1. Basic SSH reachability (ConnectTimeout=5 avoids long hangs)
  if ssh -o BatchMode=yes -o ConnectTimeout=5 "$REMOTE_HOST" true 2>/dev/null; then
    ok "SSH reachable: $REMOTE_HOST"
  else
    warn "SSH not reachable (or key auth required): $REMOTE_HOST"
    warn "VNC check may still work if the host is on the same LAN."
  fi

  # 2. Port 5900 (VNC) — nc with a short timeout; fall back silently if nc unavailable
  local vnc_ok=0
  if command -v nc >/dev/null 2>&1; then
    if nc -z -G 4 "$REMOTE_HOST" 5900 2>/dev/null; then
      ok "Port 5900 (VNC) is open on $REMOTE_HOST"
      vnc_ok=1
    else
      warn "Port 5900 (VNC) is not reachable on $REMOTE_HOST"
      warn "On the host: System Settings > General > Sharing > enable Screen Sharing (or Remote Management)."
    fi
  else
    warn "nc not available — skipping port 5900 check (install Homebrew netcat if needed)"
  fi

  if [ "$vnc_ok" -eq 1 ]; then
    info "Host appears ready. Run:  remote-pair-desktop open"
  fi
}

cmd_help() {
  sed -n '3,9p' "$0"
}

case "${1:-open}" in
  open|"")   cmd_open ;;
  check)     cmd_check ;;
  help|-h|--help) cmd_help ;;
  *) err "unknown command: $1"; cmd_help; exit 2 ;;
esac
