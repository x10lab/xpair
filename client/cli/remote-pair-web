# ── 유틸리티 ──────────────────────────────────────────────────────────────────

def run(cmd, timeout=15):
    """CLI shell-out. (stdout, stderr, returncode) 반환. 예외는 오류 튜플로 변환."""
    try:
        r = subprocess.run(
            cmd, shell=True, capture_output=True, text=True, timeout=timeout
        )
        return r.stdout.strip(), r.stderr.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", "timeout", 1
    except Exception as e:
        return "", str(e), 1


def read_json(path):
    """파일 읽어 JSON dict 반환. 없거나 파싱 불가면 None."""
    try:
        return json.loads(Path(path).read_text())
    except Exception:
        return None


def read_text(path):
    """파일 텍스트 반환. 없으면 None."""
    try:
        return Path(path).read_text().strip()
    except Exception:
        return None


def parse_client_env():
    """client.env 파싱 → {key: value} dict. 없으면 {}."""
    result = {}
    try:
        for line in CLIENT_ENV.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            if "=" in line:
                k, _, v = line.partition("=")
                # bash quote($'...' / "..." / '...') 단순 strip
                v = v.strip().strip("'\"")
                result[k.strip()] = v
    except Exception:
        pass
    return result


def compute_liveness(status_dict):
    """
    status.json dict → (appUp: bool, staleSecs: int)
    CLI cmd_status 의 로직 미러:
      - ts 기준으로 경과 시간 계산
      - >STALE_SECS 이면 app-down (stale)
      - 신선하면 ax/sr 값이 실제 grant 상태
    """
    if not status_dict:
        return False, None
    ts = status_dict.get("ts", 0)
    age = int(time.time()) - int(ts)
    app_up = age <= STALE_SECS
    return app_up, age


# ── REMOTE_HOST 해석 + ssh 헬퍼 ──────────────────────────────────────────────
# cmd_web 이 REMOTE_HOST 를 env 로 전달하지 않을 수 있으므로 env → client.env 순서로 해석.
# (api_status 의 parse_client_env 와 동일 소스.)

def resolve_host():
    """REMOTE_HOST 를 환경변수 또는 client.env 에서 해석. 없으면 ''."""
    h = os.environ.get("REMOTE_HOST", "").strip()
    if h:
        return h
    return parse_client_env().get("REMOTE_HOST", "").strip()


def ssh_run(remote_cmd, timeout=15):
    """
    REMOTE_HOST 로 SSH 실행. (stdout, stderr, returncode) 반환.
    BatchMode=yes — 키 없으면 즉시 실패 (프롬프트 대기 금지).
    remote_cmd 는 원격 쉘에서 평가되는 완성된 명령 문자열.
    host 미설정 시 (-1, 'no host', 1) 반환 — 호출부가 graceful 처리.
    """
    host = resolve_host()
    if not host:
        return "", "REMOTE_HOST not set", 1
    # subprocess argv 로 ssh 호출 — remote_cmd 는 단일 인자로 원격 쉘에 그대로 전달.
    argv = [
        "ssh", "-n",
        "-o", "BatchMode=yes",
        "-o", "ConnectTimeout=6",
        host, remote_cmd,
    ]
    try:
        r = subprocess.run(argv, capture_output=True, text=True, timeout=timeout)
        return r.stdout, r.stderr.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", "ssh timeout", 1
    except Exception as e:
        return "", str(e), 1


def sq(s):
    """POSIX 단일따옴표 쉘 이스케이프. 원격 쉘로 보낼 인자에 사용."""
    return "'" + str(s).replace("'", "'\\''") + "'"


def read_role():
    """
    ~/.remote-pair/role → 'host'|'client'|'both'|''.
    Installer.shouldSkipSelfInstall (Installer.swift:50-55) 의 파싱 미러:
      파일 읽어 trim. 없거나 비면 ''.
    """
    return read_text(ROLE_FILE) or ""


def is_client():
    """role == 'client' 면 클라(ACCESS ONLY). AX/SR 권한 요청·프롬프트 절대 안 함."""
    return read_role() == "client"


def is_host():
    """
    role 이 host | both | 빈값/없음 → host 로 간주(기본 host).
    Installer 의 'role.isEmpty → host 로 간주' 의미를 미러.
    """
    return read_role() != "client"


def tmux_remote(*args):
    """원격 tmux-aqua 명령 문자열 구성. 각 인자는 단일따옴표 이스케이프."""
    parts = [HOST_TMUX, "-S", sq(AQUA_SOCK)] + [sq(a) for a in args]
    return " ".join(parts)


def read_notify_types():
    """
    notify.conf 의 ENABLED_TYPES (콤마목록) 파싱 → set.
    파일/키 없으면 기본값(전부). 알 수 없는 토큰은 무시.
    """
    try:
        for line in NOTIFY_CONF.read_text().splitlines():
            line = line.strip()
            if not line or line.startswith("#"):
                continue
            k, _, v = line.partition("=")
            if k.strip() == "ENABLED_TYPES":
                toks = [t.strip() for t in v.strip().strip("'\"").split(",") if t.strip()]
                valid = [t for t in toks if t in ALL_NOTIFY_TYPES]
                return set(valid) if valid else set(DEFAULT_NOTIFY_TYPES)
    except Exception:
        pass
    return set(DEFAULT_NOTIFY_TYPES)


def write_notify_types(types):
    """ENABLED_TYPES 만 갱신하고 다른 KEY 들은 보존하여 notify.conf 재작성."""
    valid = [t for t in types if t in ALL_NOTIFY_TYPES]
    lines = []
    found = False
    try:
        if NOTIFY_CONF.exists():
            for line in NOTIFY_CONF.read_text().splitlines():
                stripped = line.strip()
                if stripped and not stripped.startswith("#") and stripped.split("=", 1)[0].strip() == "ENABLED_TYPES":
                    lines.append("ENABLED_TYPES=" + ",".join(valid))
                    found = True
                else:
                    lines.append(line)
    except Exception:
        lines = []
        found = False
    if not found:
        lines.append("ENABLED_TYPES=" + ",".join(valid))
    RP_DIR.mkdir(parents=True, exist_ok=True)
    NOTIFY_CONF.write_text("\n".join(lines).rstrip("\n") + "\n")


def read_cursor():
    """클라 알림 커서(바이트 오프셋) 읽기. 없으면 0."""
    try:
        return int(NOTIFY_CURSOR.read_text().strip() or "0")
    except Exception:
        return 0


def write_cursor(offset):
    """클라 알림 커서 갱신."""
    try:
        NOTIFY_CURSOR.parent.mkdir(parents=True, exist_ok=True)
        NOTIFY_CURSOR.write_text(str(int(offset)) + "\n")
    except Exception:
        pass


# ── API 핸들러 ─────────────────────────────────────────────────────────────────

def api_status():
    """
    GET /api/status
    status.json + role + client.env(host/maps) 머지 → 단일 JSON 응답.
    liveness: ts 신선도로 app-down vs denied 구분 (cmd_status 로직 미러).
    """
    raw = read_json(STATUS_FILE)
    app_up, age_secs = compute_liveness(raw)

    if raw and app_up:
        ax        = raw.get("ax", False)
        sr        = raw.get("sr", False)
        fda       = raw.get("fda", False)
        bundle_id = raw.get("bundle_id", "")
        version   = raw.get("version", "")
        socket    = raw.get("socket", "")
        pid       = raw.get("pid", None)
    elif raw:
        # stale — 마지막 값은 있지만 앱이 내려간 것으로 간주
        ax = sr = fda = False
        bundle_id = raw.get("bundle_id", "")
        version   = raw.get("version", "")
        socket    = raw.get("socket", "")
        pid       = None
    else:
        ax = sr = fda = False
        bundle_id = version = socket = ""
        pid = None

    role = read_text(ROLE_FILE) or ""

    env = parse_client_env()
    host     = env.get("REMOTE_HOST", "")
    maps_raw = env.get("FOLDER_MAPS", env.get("SYNC_ROOTS", ""))

    # maps: "clientDir::hostDir;..." → [{client, host}, ...]
    maps = []
    for entry in maps_raw.split(";"):
        entry = entry.strip()
        if not entry:
            continue
        if "::" in entry:
            c_dir, h_dir = entry.split("::", 1)
        else:
            c_dir = h_dir = entry
        maps.append({"client": c_dir, "host": h_dir})

    return {
        "appUp":    app_up,
        "ageSecs":  age_secs,
        "ax":       ax,
        "sr":       sr,
        "fda":      fda,
        "bundleId": bundle_id,
        "version":  version,
        "socket":   socket,
        "pid":      pid,
        "role":     role,
        "host":     host,
        "maps":     maps,
    }


def api_permissions_open(body):
    """
    POST /api/permissions/open {pane: 'ax'|'sr'|'fda'}
    Permissions.swift 41-43의 정확한 URL로 open.
    macOS가 토글하는 것이지 앱이 토글할 수 없음 — 열기만.

    CLIENT 모드(role=client)는 ACCESS ONLY — AX/SR 권한이 필요 없으므로 no-op.
    System Settings 창을 띄우지 않는다(불필요한 권한 프롬프트 유발 금지).
    host/both/기본 은 기존대로 동작.
    """
    if is_client():
        return {"ok": False, "msg": "client mode, no permissions needed", "client": True}

    pane_urls = {
        "ax":  "x-apple.systempreferences:com.apple.preference.security?Privacy_Accessibility",
        "sr":  "x-apple.systempreferences:com.apple.preference.security?Privacy_ScreenCapture",
        "fda": "x-apple.systempreferences:com.apple.preference.security?Privacy_AllFiles",
    }
    pane = body.get("pane", "")
    url  = pane_urls.get(pane)
    if not url:
        return {"ok": False, "error": f"unknown pane: {pane!r}. Use ax/sr/fda."}, 400

    _, err, code = run(f"open {sq(url)}")
    if code != 0:
        return {"ok": False, "error": err or "open failed"}, 500
    return {"ok": True, "pane": pane}


def api_role(body):
    """POST /api/role {role} → ~/.remote-pair/role 기록."""
    role = body.get("role", "").strip()
    if role not in ("host", "client", "both"):
        return {"ok": False, "error": "role must be host|client|both"}, 400
    try:
        RP_DIR.mkdir(parents=True, exist_ok=True)
        ROLE_FILE.write_text(role + "\n")
    except Exception as e:
        return {"ok": False, "error": str(e)}, 500
    return {"ok": True, "role": role}


def api_config(body):
    """POST /api/config {key, value} → remote-pair config set <key> <value>."""
    key   = body.get("key", "").strip()
    value = body.get("value", "").strip()
    if key not in ("host", "terminal"):
        return {"ok": False, "error": "key must be host|terminal"}, 400

    # shell-out — CLI가 검증 및 저장 담당
    out, err, code = run(f"remote-pair config set {key} {sq(value)}")
    if code != 0:
        return {"ok": False, "error": err or out}, 500
    return {"ok": True, "key": key, "value": value, "output": out}


def api_ssh_check():
    """GET /api/ssh-check → remote-pair doctor (SSH 섹션 관련 출력 + 종료코드)."""
    out, err, code = run("remote-pair doctor", timeout=30)
    return {
        "ok":       code == 0,
        "exitCode": code,
        "output":   out or err,
    }


def api_map_list():
    """GET /api/map → remote-pair map list."""
    out, err, code = run("remote-pair map list")
    # 파싱 보조: maps 배열도 같이 반환
    status = api_status()
    return {
        "ok":     code == 0,
        "text":   out or err,
        "maps":   status.get("maps", []),
    }


def api_map_mutate(body):
    """
    POST /api/map {action: add|rm, clientDir, hostDir?}
    remote-pair map add/rm 위임.
    """
    action     = body.get("action", "").strip()
    client_dir = body.get("clientDir", "").strip()
    host_dir   = body.get("hostDir", "").strip()

    if action not in ("add", "rm"):
        return {"ok": False, "error": "action must be add|rm"}, 400
    if not client_dir:
        return {"ok": False, "error": "clientDir required"}, 400

    if action == "add":
        cmd = f"remote-pair map add {sq(client_dir)}"
        if host_dir:
            cmd += f" {sq(host_dir)}"
    else:
        cmd = f"remote-pair map rm {sq(client_dir)}"

    out, err, code = run(cmd)
    if code != 0:
        return {"ok": False, "error": err or out}, 500
    return {"ok": True, "action": action, "output": out}


def api_syncthing():
    """
    GET /api/syncthing → 로컬 Syncthing(127.0.0.1:8384) 프로빙.
    미설치/중지 시 graceful "not-detected" — 절대 오류 처리 안 함 (외부/선택사항).
    """
    try:
        req = urllib.request.Request(SYNCTHING_URL, headers={"X-API-Key": "x"})
        with urllib.request.urlopen(req, timeout=2) as resp:
            body = resp.read().decode()
            return {"detected": True, "status": "up", "raw": body}
    except urllib.error.HTTPError as e:
        # 403/401이면 실행 중이지만 API 키가 맞지 않는 것 → up으로 간주
        if e.code in (401, 403):
            return {"detected": True, "status": "up", "raw": f"HTTP {e.code}"}
        return {"detected": False, "status": "not-detected", "raw": f"HTTP {e.code}"}
    except Exception:
        return {"detected": False, "status": "not-detected", "raw": "unreachable"}


def api_regrant():
    """
    GET /api/regrant
    번들 id 통일(com.x10lab.remote-pair)은 v0.5.0 으로 DEFERRED.
    현재 출하 id(com.x10lab.remote-pair-host)가 active expected identity 이다.

    needed=true:  bundle_id 가 존재하고 EXPECTED 와 다름 (예상치 못한 정체성),
                  또는 앱이 떠있는데 ax/sr 중 하나라도 false (재허용 필요).
    needed=false: status.json 없음(앱 미설치/초기) — 안내 무의미,
                  또는 EXPECTED id + ax + sr 모두 OK.

    CLIENT 모드(role=client)는 ACCESS ONLY — 로컬 AX/SR grant 가 아예 무의미하므로
    항상 needed=false. host/both/기본 은 기존 판단 로직대로.
    """
    if is_client():
        return {"needed": False, "reason": "client mode, no permissions needed", "client": True}

    # 0.5 RELEASE FLIP: change to com.x10lab.remote-pair when bundle-id unification ships
    EXPECTED_BUNDLE_ID = "com.x10lab.remote-pair-host"

    status = api_status()
    app_up    = status.get("appUp", False)
    ax        = status.get("ax", False)
    sr        = status.get("sr", False)
    bundle_id = status.get("bundleId", "")

    # 아직 앱이 없으면 번들 id를 알 수 없으므로 needed=false (안내 무의미)
    if not bundle_id:
        return {"needed": False, "reason": "status.json 없음 — 앱 미설치 또는 초기 상태"}

    if bundle_id != EXPECTED_BUNDLE_ID:
        return {
            "needed":    True,
            "reason":    "예상과 다른 번들 id 가 감지됨. AX/SR 재허용이 필요할 수 있습니다.",
            "bundleId":  bundle_id,
        }

    if app_up and not (ax and sr):
        return {
            "needed":    True,
            "reason":    "AX 또는 SR이 미허용 상태. System Settings에서 재허용 필요.",
            "bundleId":  bundle_id,
        }

    return {"needed": False, "reason": "ok", "bundleId": bundle_id}


# ── SSH-assist API (BRIDGE) ───────────────────────────────────────────────────
# 클라(또는 host/both)가 SSH 키 없이 마법사에서 keygen → copy-id → 핸드셰이크까지
# 안내받도록 보조. 모든 외부 실행은 argv 리스트(shell=False) 또는 sq() 이스케이프.
# 셸 문자열 인젝션 금지 (프로젝트 인젝션 버그 수정 표준 유지).

DEFAULT_SSH_KEY = Path.home() / ".ssh" / "id_ed25519"


def _find_ssh_pubkey():
    """~/.ssh/id_*.pub 중 첫 번째. 없으면 None. (id_ed25519.pub 우선)."""
    ssh_dir = Path.home() / ".ssh"
    try:
        pubs = sorted(ssh_dir.glob("id_*.pub"))
    except Exception:
        pubs = []
    if not pubs:
        return None
    # ed25519 우선 노출 (keygen 기본과 정합).
    for p in pubs:
        if "ed25519" in p.name:
            return p
    return pubs[0]


def api_ssh_pubkey():
    """
    GET /api/ssh/pubkey
    ~/.ssh/id_*.pub 글롭 → {exists, pubkey, keyPath}.
    keyPath 는 private key 경로(.pub 제거) — copy-id/-i 에 쓰는 식별자.
    """
    pub = _find_ssh_pubkey()
    if not pub:
        return {"exists": False, "pubkey": "", "keyPath": str(DEFAULT_SSH_KEY)}
    pubkey = read_text(pub) or ""
    key_path = str(pub)[:-4] if str(pub).endswith(".pub") else str(pub)
    return {"exists": True, "pubkey": pubkey, "keyPath": key_path}


def api_ssh_keygen():
    """
    POST /api/ssh/keygen
    키가 이미 있으면 no-op(생성 안 함). 없으면 ed25519 키 생성(빈 passphrase).
    argv 리스트로 ssh-keygen 호출 — shell=False, 인젝션 표면 없음.
    """
    pub = _find_ssh_pubkey()
    if pub:
        key_path = str(pub)[:-4] if str(pub).endswith(".pub") else str(pub)
        return {"ok": True, "output": "key already exists", "keyPath": key_path, "created": False}

    (Path.home() / ".ssh").mkdir(parents=True, exist_ok=True, mode=0o700)
    argv = ["ssh-keygen", "-t", "ed25519", "-N", "", "-f", str(DEFAULT_SSH_KEY)]
    try:
        r = subprocess.run(argv, capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        return {"ok": False, "error": "ssh-keygen timeout", "output": ""}, 500
    except Exception as e:
        return {"ok": False, "error": str(e), "output": ""}, 500
    out = (r.stdout or "") + (r.stderr or "")
    if r.returncode != 0:
        return {"ok": False, "error": r.stderr.strip() or "ssh-keygen failed", "output": out.strip()}, 500
    return {"ok": True, "output": out.strip(), "keyPath": str(DEFAULT_SSH_KEY), "created": True}


def api_ssh_copy_id():
    """
    POST /api/ssh/copy-id
    resolve_host() 대상으로 ssh-copy-id -i <pubkey> <host>.
    argv 리스트 — shell=False. host 미설정 시 400.
    (ssh-copy-id 는 비밀번호 프롬프트가 필요할 수 있어 인터랙티브일 수 있다 —
     마법사가 별도 터미널/안내로 처리. 여기서는 best-effort 비대화로 시도.)
    """
    host = resolve_host()
    if not host:
        return {"ok": False, "error": "REMOTE_HOST not set"}, 400

    pub = _find_ssh_pubkey()
    if not pub:
        return {"ok": False, "error": "no ssh public key — run /api/ssh/keygen first"}, 400

    argv = ["ssh-copy-id", "-i", str(pub), host]
    try:
        r = subprocess.run(argv, capture_output=True, text=True, timeout=30)
    except subprocess.TimeoutExpired:
        return {"ok": False, "error": "ssh-copy-id timeout (password prompt? run manually)", "output": ""}
    except Exception as e:
        return {"ok": False, "error": str(e), "output": ""}
    return {
        "ok":     r.returncode == 0,
        "output": (r.stdout or "").strip(),
        "error":  (r.stderr or "").strip(),
    }


def api_handshake():
    """
    GET /api/handshake
    클라↔host 페어링 준비 상태를 한 번에 점검(via ssh_run):
      (a) reachability: ssh_run('true') 성공 여부
      (b) status freshness + ax/sr: 원격 ~/.remote-pair/logs/status.json 의 ts 신선도
      (c) tmux liveness: tmux-aqua has-session(_keeper) 또는 서버 응답 여부

    Return {ok, ssh, statusFresh, statusAge, ax, sr, tmuxUp, error?}.
    ok = ssh AND statusFresh AND tmuxUp (전부 통과).
    """
    host = resolve_host()
    if not host:
        return {
            "ok": False, "ssh": False, "statusFresh": False, "statusAge": None,
            "ax": False, "sr": False, "tmuxUp": False, "error": "REMOTE_HOST not set",
        }

    result = {
        "ok": False, "ssh": False, "statusFresh": False, "statusAge": None,
        "ax": False, "sr": False, "tmuxUp": False,
    }

    # (a) reachability
    _o, ssh_err, ssh_rc = ssh_run("true")
    result["ssh"] = (ssh_rc == 0)
    if not result["ssh"]:
        result["error"] = ssh_err or "ssh unreachable"
        return result

    # (b) status.json freshness + ax/sr
    out, _e, code = ssh_run("cat ~/.remote-pair/logs/status.json 2>/dev/null || true")
    status = None
    if code == 0 and out.strip():
        try:
            status = json.loads(out.strip())
        except Exception:
            status = None
    if status:
        ts = status.get("ts", 0)
        try:
            age = int(time.time()) - int(ts)
        except (TypeError, ValueError):
            age = None
        result["statusAge"] = age
        fresh = age is not None and age <= STALE_SECS
        result["statusFresh"] = fresh
        if fresh:
            result["ax"] = bool(status.get("ax", False))
            result["sr"] = bool(status.get("sr", False))

    # (c) tmux liveness — has-session 으로 keeper 확인.
    tcmd = tmux_remote("has-session", "-t", "_keeper")
    _to, _te, tcode = ssh_run(tcmd)
    result["tmuxUp"] = (tcode == 0)

    result["ok"] = result["ssh"] and result["statusFresh"] and result["tmuxUp"]
    return result


# ── 터미널 API (M3) ──────────────────────────────────────────────────────────
# 모든 호출은 REMOTE_HOST 의 tmux-aqua(/tmp/aqua-tmux.sock)로 ssh. 세션을 죽이지 않는다
# (kill-session 절대 호출 안 함). 탭 닫기 = detached view 일 뿐, 세션은 host 에 남는다.

def api_term_list():
    """
    GET /api/term/list
    tmux-aqua list-sessions → [{name, attached}] JSON.
    _keeper 같은 내부 세션은 노출하되 호출부가 필터링 가능하도록 그대로 반환.
    """
    host = resolve_host()
    if not host:
        return {"ok": False, "error": "REMOTE_HOST not set", "sessions": []}
    cmd = tmux_remote("list-sessions", "-F", "#{session_name}\t#{session_attached}")
    out, err, code = ssh_run(cmd)
    if code != 0:
        # tmux 서버가 없으면 'no server running' — 세션 0개로 graceful.
        return {"ok": True, "sessions": [], "note": err or "no sessions"}
    sessions = []
    for line in out.splitlines():
        line = line.rstrip("\n")
        if not line:
            continue
        name, _, attached = line.partition("\t")
        sessions.append({"name": name, "attached": attached.strip() not in ("", "0")})
    return {"ok": True, "sessions": sessions}


def api_term_output(session):
    """
    GET /api/term/output?session=NAME
    capture-pane -p -e -J → ansi 포함 raw 텍스트.
    한계: alt-screen(vim, less, claude TUI 풀스크린 등)에서는 capture-pane 가
    현재 보이는 화면만 캡처하며, 스크롤백/ansi 일부가 손실될 수 있다. 이는 v0
    폴링 방식의 알려진 제약 (진짜 PTY 스트리밍은 향후 업그레이드).
    """
    if not session:
        return {"ok": False, "error": "session required"}, 400
    cmd = tmux_remote("capture-pane", "-p", "-e", "-J", "-t", session)
    out, err, code = ssh_run(cmd)
    if code != 0:
        return {"ok": False, "error": err or "capture failed", "output": ""}
    return {"ok": True, "session": session, "output": out}


def api_term_input(body):
    """
    POST /api/term/input {session, data}
    -l 로 literal 전송 (키 이름 해석 방지). data 안의 개행은 send-keys 가 그대로
    리터럴 전송하므로, 줄바꿈/Enter 가 필요하면 별도 {session, enter:true} 또는
    data 끝에 명시. 여기서는 data 를 literal 로 보내고, enter=true 면 Enter 키 추가.
    """
    session = body.get("session", "").strip()
    data    = body.get("data", "")
    enter   = bool(body.get("enter", False))
    if not session:
        return {"ok": False, "error": "session required"}, 400

    # data 가 있으면 literal 전송 ('--' 로 옵션 종료 → '-' 로 시작하는 입력도 안전).
    if data != "":
        cmd = " ".join([
            HOST_TMUX, "-S", sq(AQUA_SOCK),
            "send-keys", "-t", sq(session), "-l", "--", sq(data),
        ])
        out, err, code = ssh_run(cmd)
        if code != 0:
            return {"ok": False, "error": err or "send-keys failed"}, 500

    # Enter 는 키 이름으로 별도 전송 (literal 아님).
    if enter:
        cmd2 = tmux_remote("send-keys", "-t", session, "Enter")
        out2, err2, code2 = ssh_run(cmd2)
        if code2 != 0:
            return {"ok": False, "error": err2 or "send Enter failed"}, 500

    return {"ok": True, "session": session}


def api_term_key(body):
    """
    POST /api/term/key {session, key}
    키 이름(Enter/Escape/Up/C-c 등)을 literal 아닌 키로 전송.
    xterm.js 의 특수키/제어키 처리에 사용.
    """
    session = body.get("session", "").strip()
    key     = body.get("key", "").strip()
    if not session or not key:
        return {"ok": False, "error": "session and key required"}, 400
    cmd = tmux_remote("send-keys", "-t", session, key)
    out, err, code = ssh_run(cmd)
    if code != 0:
        return {"ok": False, "error": err or "send-keys failed"}, 500
    return {"ok": True, "session": session, "key": key}


def api_term_resize(body):
    """
    POST /api/term/resize {session, cols, rows}
    resize-window -x cols -y rows. (window-size manual 가정; aqua 패치 서버는
    클라가 attach 안 해도 윈도우 크기를 명시적으로 잡을 수 있다.)
    실패해도 비치명적 — capture-pane 출력엔 영향 적음.
    """
    session = body.get("session", "").strip()
    try:
        cols = int(body.get("cols", 0))
        rows = int(body.get("rows", 0))
    except (TypeError, ValueError):
        return {"ok": False, "error": "cols/rows must be integers"}, 400
    if not session or cols <= 0 or rows <= 0:
        return {"ok": False, "error": "session, positive cols/rows required"}, 400
    cmd = tmux_remote("resize-window", "-t", session, "-x", str(cols), "-y", str(rows))
    out, err, code = ssh_run(cmd)
    if code != 0:
        return {"ok": True, "session": session, "note": err or "resize ignored"}
    return {"ok": True, "session": session, "cols": cols, "rows": rows}


# ── Remote Desktop API (M5) ──────────────────────────────────────────────────

def api_desktop_open():
    """
    POST /api/desktop/open
    M5 런처(remote-pair-desktop) 가 있으면 그것을, 없으면 'open vnc://$REMOTE_HOST'.
    화면 공유는 macOS 가 처리 (AGPL noVNC 코드 임베드 안 함 — arm's-length).
    """
    host = resolve_host()
    if not host:
        return {"ok": False, "error": "REMOTE_HOST not set — cannot open screen sharing"}, 400

    # 런처 우선 (PATH → LOCAL_BIN → ~/.remote-pair/bin)
    candidates = [
        "remote-pair-desktop",
        str(Path.home() / ".local" / "bin" / "remote-pair-desktop"),
        str(RP_DIR / "bin" / "remote-pair-desktop"),
    ]
    for c in candidates:
        found = c if (c == "remote-pair-desktop") else (c if Path(c).is_file() and os.access(c, os.X_OK) else None)
        if c == "remote-pair-desktop":
            _o, _e, _rc = run("command -v remote-pair-desktop")
            if _rc != 0:
                continue
            found = "remote-pair-desktop"
        if found:
            out, err, code = run(f"{found} {sq(host)}")
            if code == 0:
                return {"ok": True, "via": "launcher", "host": host}
            # 런처 실패 시 기본 open 으로 폴백
            break

    out, err, code = run(f"open {sq('vnc://' + host)}")
    if code != 0:
        return {"ok": False, "error": err or "open vnc:// failed"}, 500
    return {"ok": True, "via": "open-vnc", "host": host, "url": f"vnc://{host}"}


# ── Editor API (M4) — code-server iframe ─────────────────────────────────────

def api_editor_status():
    """
    GET /api/editor/status
    로컬 127.0.0.1:EDITOR_PORT 에 code-server 가 떠있는지 HTTP 프로빙.
    응답(2xx/3xx/401/403) 이면 running. iframe 으로 임베드 가능.
    """
    try:
        req = urllib.request.Request(EDITOR_URL, method="HEAD")
        with urllib.request.urlopen(req, timeout=2) as resp:
            return {"running": True, "url": EDITOR_URL, "code": resp.status, "port": EDITOR_PORT}
    except urllib.error.HTTPError as e:
        # 인증 게이트(401/403) 라도 서버는 떠있는 것.
        running = e.code in (401, 403, 302)
        return {"running": running, "url": EDITOR_URL, "code": e.code, "port": EDITOR_PORT}
    except Exception:
        return {"running": False, "url": EDITOR_URL, "port": EDITOR_PORT}


def api_editor_start():
    """
    POST /api/editor/start
    M4 런처(remote-pair-editor) 가 있으면 실행 (백그라운드). 없으면 안내만.
    code-server 바이너리 직접 호출은 하지 않는다 — 런처가 brain.
    """
    candidates = [
        ("remote-pair-editor", None),
        (str(Path.home() / ".local" / "bin" / "remote-pair-editor"), None),
        (str(RP_DIR / "bin" / "remote-pair-editor"), None),
    ]
    launcher = None
    _o, _e, _rc = run("command -v remote-pair-editor")
    if _rc == 0:
        launcher = "remote-pair-editor"
    else:
        for c, _ in candidates[1:]:
            if Path(c).is_file() and os.access(c, os.X_OK):
                launcher = c
                break

    if not launcher:
        return {
            "ok": False,
            "error": "remote-pair-editor launcher not found",
            "hint": "Install the M4 editor launcher, or start code-server manually on "
                    f"127.0.0.1:{EDITOR_PORT}.",
        }, 404

    try:
        subprocess.Popen(
            [launcher],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
            start_new_session=True,
        )
    except Exception as e:
        return {"ok": False, "error": str(e)}, 500
    return {"ok": True, "via": launcher, "url": EDITOR_URL}


# ── Notifications API (M2) ────────────────────────────────────────────────────

def api_notifications():
    """
    GET /api/notifications
    host 큐(~/.remote-pair/notifications/queue.jsonl) 에서 클라 커서 이후의
    새 줄만 ssh 로 가져온다. notify.conf ENABLED_TYPES 로 필터. 커서는 갱신하지
    않는다 (읽기 전용) — mark-seen 은 별도 POST.

    구현: ssh 로 (1) 파일 바이트 크기, (2) 커서부터 tail. 'wc -c' + 'tail -c +N'.
    커서가 파일보다 크면(로테이션/리셋) 0 으로 리셋하고 전체 다시.
    """
    host = resolve_host()
    if not host:
        return {"ok": False, "error": "REMOTE_HOST not set", "events": [], "cursor": 0}

    enabled = read_notify_types()
    cursor  = read_cursor()

    # 원격 파일 크기 (없으면 0). 그 다음 cursor+1 바이트부터 tail.
    size_out, _se, size_rc = ssh_run(f"wc -c < {HOST_QUEUE} 2>/dev/null || echo 0")
    try:
        size = int(size_out.strip() or "0")
    except ValueError:
        size = 0

    # 로테이션 감지: 커서가 현재 크기보다 크면 처음부터.
    if cursor > size:
        cursor = 0

    if size <= cursor:
        return {"ok": True, "events": [], "cursor": cursor, "size": size}

    # tail -c +N 은 1-기반(N번째 바이트부터). 커서가 0이면 +1.
    start = cursor + 1
    out, err, code = ssh_run(f"tail -c +{start} {HOST_QUEUE} 2>/dev/null || true")
    if code != 0:
        return {"ok": False, "error": err or "tail failed", "events": [], "cursor": cursor}

    events = []
    for line in out.splitlines():
        line = line.strip()
        if not line:
            continue
        try:
            ev = json.loads(line)
        except Exception:
            continue
        typ = ev.get("type", "")
        if typ and typ not in enabled:
            continue
        events.append(ev)

    # next 커서 = 현재 파일 크기 (다음 폴링이 그 뒤만 읽도록). 단 mark-seen 전까지는
    # 클라가 명시적으로 커서를 옮길 때만 영속화. 여기서는 미리보기 next 만 반환.
    return {"ok": True, "events": events, "cursor": cursor, "nextCursor": size, "size": size}


def api_notifications_seen(body):
    """
    POST /api/notifications/seen {cursor}
    클라가 표시 완료한 알림까지 커서를 전진. cursor 미지정 시 현재 host 큐 크기로.
    """
    cur = body.get("cursor", None)
    if cur is None:
        size_out, _se, _rc = ssh_run(f"wc -c < {HOST_QUEUE} 2>/dev/null || echo 0")
        try:
            cur = int(size_out.strip() or "0")
        except ValueError:
            cur = 0
    try:
        cur = int(cur)
    except (TypeError, ValueError):
        return {"ok": False, "error": "cursor must be an integer"}, 400
    write_cursor(cur)
    return {"ok": True, "cursor": cur}


# ── Settings API — notify.conf ENABLED_TYPES ─────────────────────────────────

def api_notify_settings_get():
    """GET /api/notify/settings → {enabledTypes, allTypes}."""
    return {
        "ok": True,
        "enabledTypes": sorted(read_notify_types(), key=ALL_NOTIFY_TYPES.index),
        "allTypes": ALL_NOTIFY_TYPES,
    }


def api_notify_settings_set(body):
    """
    POST /api/notify/settings {enabledTypes: [...]}
    notify.conf 의 ENABLED_TYPES 갱신. 다른 KEY 는 보존.
    """
    types = body.get("enabledTypes", None)
    if not isinstance(types, list):
        return {"ok": False, "error": "enabledTypes must be a list"}, 400
    valid = [t for t in types if t in ALL_NOTIFY_TYPES]
    try:
        write_notify_types(valid)
    except Exception as e:
        return {"ok": False, "error": str(e)}, 500
    return {"ok": True, "enabledTypes": sorted(valid, key=ALL_NOTIFY_TYPES.index)}


# ── Mount API (M-Mount) ───────────────────────────────────────────────────────
# 얇은 어댑터: 모든 마운트 로직은 'remote-pair-mount' 런처에 위임.
# 런처 부재 시 graceful 응답.

MOUNT_LAUNCHER = "remote-pair-mount"

def _find_mount_launcher():
    """remote-pair-mount 런처 경로 반환. 없으면 None."""
    _, _, rc = run("command -v remote-pair-mount")
    if rc == 0:
        return MOUNT_LAUNCHER
    # PATH 에 없으면 알려진 위치도 확인
    candidates = [
        str(Path.home() / ".local" / "bin" / "remote-pair-mount"),
        str(RP_DIR / "bin" / "remote-pair-mount"),
    ]
    for c in candidates:
        if Path(c).is_file() and os.access(c, os.X_OK):
            return c
    return None


def api_mount_status():
    """
    GET /api/mount/status
    remote-pair-mount status → {mounts:[...], backend, launcherFound}
    런처 부재 시 graceful empty 응답.
    """
    launcher = _find_mount_launcher()
    if not launcher:
        env = parse_client_env()
        return {
            "ok": True,
            "launcherFound": False,
            "mounts": [],
            "backend": env.get("MOUNT_BACKEND", "smb"),
            "syncBackend": env.get("SYNC_BACKEND", "syncthing"),
        }

    out, err, code = run(f"{launcher} status", timeout=10)
    # 런처 출력은 사람이 읽는 텍스트 — mounts 배열은 파싱 최선(best-effort).
    # 형식: 한 줄 = mountpoint (launcher 의 status 출력이 텍스트일 수 있음).
    mounts = []
    for line in out.splitlines():
        line = line.strip()
        if line and not line.startswith("#"):
            mounts.append(line)

    env = parse_client_env()
    return {
        "ok": True,
        "launcherFound": True,
        "mounts": mounts,
        "backend": env.get("MOUNT_BACKEND", "smb"),
        "syncBackend": env.get("SYNC_BACKEND", "syncthing"),
        "raw": out,
    }


def api_mount_mount(body):
    """
    POST /api/mount/mount {hostPath, mountpoint?}
    remote-pair-mount mount <hostPath> [mountpoint]
    """
    host_path = body.get("hostPath", "").strip()
    mountpoint = body.get("mountpoint", "").strip()

    if not host_path:
        return {"ok": False, "error": "hostPath required"}, 400

    launcher = _find_mount_launcher()
    if not launcher:
        return {"ok": False, "error": "remote-pair-mount launcher not found — install the M-Mount launcher first"}, 404

    if mountpoint:
        cmd = f"{launcher} mount {sq(host_path)} {sq(mountpoint)}"
    else:
        cmd = f"{launcher} mount {sq(host_path)}"

    out, err, code = run(cmd, timeout=30)
    if code != 0:
        return {"ok": False, "error": err or out or "mount failed"}, 500
    return {"ok": True, "hostPath": host_path, "output": out}


def api_mount_unmount(body):
    """
    POST /api/mount/unmount {target}
    remote-pair-mount unmount <target>
    """
    target = body.get("target", "").strip()

    if not target:
        return {"ok": False, "error": "target required"}, 400

    launcher = _find_mount_launcher()
    if not launcher:
        return {"ok": False, "error": "remote-pair-mount launcher not found"}, 404

    out, err, code = run(f"{launcher} unmount {sq(target)}", timeout=15)
    if code != 0:
        return {"ok": False, "error": err or out or "unmount failed"}, 500
    return {"ok": True, "target": target, "output": out}


# ── Sync-backend config API ───────────────────────────────────────────────────

def _write_client_env_keys(updates):
    """
    client.env 의 지정 키들만 갱신. 다른 키는 보존.
    updates: {KEY: value} dict.
    notify.conf 기록 패턴과 동일.
    """
    lines = []
    found_keys = set()
    try:
        if CLIENT_ENV.exists():
            for line in CLIENT_ENV.read_text().splitlines():
                stripped = line.strip()
                if stripped and not stripped.startswith("#") and "=" in stripped:
                    k = stripped.split("=", 1)[0].strip()
                    if k in updates:
                        lines.append(f"{k}={updates[k]}")
                        found_keys.add(k)
                        continue
                lines.append(line)
    except Exception:
        lines = []
        found_keys = set()

    for k, v in updates.items():
        if k not in found_keys:
            lines.append(f"{k}={v}")

    RP_DIR.mkdir(parents=True, exist_ok=True)
    CLIENT_ENV.write_text("\n".join(lines).rstrip("\n") + "\n")


def api_sync_backend_get():
    """
    GET /api/sync-backend
    client.env 에서 SYNC_BACKEND + MOUNT_BACKEND 읽기.
    """
    env = parse_client_env()
    return {
        "ok": True,
        "syncBackend": env.get("SYNC_BACKEND", "syncthing"),
        "mountBackend": env.get("MOUNT_BACKEND", "smb"),
    }


def api_sync_backend_set(body):
    """
    POST /api/sync-backend {syncBackend, mountBackend?}
    client.env 에 SYNC_BACKEND (+ 선택적 MOUNT_BACKEND) 기록. 다른 키 보존.
    """
    sync_backend = body.get("syncBackend", "").strip()
    mount_backend = body.get("mountBackend", "").strip()

    if sync_backend not in ("syncthing", "mount"):
        return {"ok": False, "error": "syncBackend must be syncthing|mount"}, 400
    if mount_backend and mount_backend not in ("smb", "sshfs"):
        return {"ok": False, "error": "mountBackend must be smb|sshfs"}, 400

    updates = {"SYNC_BACKEND": sync_backend}
    if mount_backend:
        updates["MOUNT_BACKEND"] = mount_backend

    try:
        _write_client_env_keys(updates)
    except Exception as e:
        return {"ok": False, "error": str(e)}, 500

    result = {"ok": True, "syncBackend": sync_backend}
    if mount_backend:
        result["mountBackend"] = mount_backend
    return result


# ── HTTP 핸들러 ────────────────────────────────────────────────────────────────

class Handler(http.server.BaseHTTPRequestHandler):

    def log_message(self, fmt, *args):  # 기본 로그 억제 (토큰 URL 노출 방지)
        pass

    # ── 토큰 검증 ──────────────────────────────────────────────────────────────
    def _check_token(self):
        parsed = urllib.parse.urlparse(self.path)
        qs     = urllib.parse.parse_qs(parsed.query)

        # 쿼리파라미터 또는 X-Token 헤더 — 둘 중 하나면 통과
        token_qs     = qs.get("token", [""])[0]
        token_header = self.headers.get("X-Token", "")

        return secrets.compare_digest(_TOKEN, token_qs or token_header)

    # ── 공통 응답 헬퍼 ─────────────────────────────────────────────────────────
    def _json(self, data, status=200):
        body = json.dumps(data, ensure_ascii=False).encode()
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.send_header("Cache-Control", "no-store")
        self.end_headers()
        self.wfile.write(body)

    def _json_result(self, result):
        """api_* 가 dict 또는 (dict, status) 를 반환하는 두 경우 모두 직렬화."""
        if isinstance(result, tuple):
            data, status = result
        else:
            data, status = result, 200
        self._json(data, status)

    def _read_body(self):
        length = int(self.headers.get("Content-Length", "0"))
        if length <= 0:
            return {}
        try:
            return json.loads(self.rfile.read(length))
        except Exception:
            return {}

    # ── 정적 파일 서빙 ─────────────────────────────────────────────────────────
    def _serve_static(self):
        parsed = urllib.parse.urlparse(self.path)
        # / 혹은 /index.html → index.html
        rel = parsed.path.lstrip("/") or "index.html"
        # 디렉터리 트래버설 방지
        target = (WEB_DIR / rel).resolve()
        if not str(target).startswith(str(WEB_DIR.resolve())):
            self.send_response(403)
            self.end_headers()
            return

        if not target.is_file():
            self.send_response(404)
            self.end_headers()
            self.wfile.write(b"Not found")
            return

        ext  = target.suffix.lower()
        mime = {
            ".html": "text/html; charset=utf-8",
            ".js":   "application/javascript; charset=utf-8",
            ".css":  "text/css; charset=utf-8",
            ".json": "application/json",
            ".ico":  "image/x-icon",
        }.get(ext, "application/octet-stream")

        data = target.read_bytes()
        self.send_response(200)
        self.send_header("Content-Type", mime)
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    # ── GET 라우팅 ─────────────────────────────────────────────────────────────
    def do_GET(self):
        parsed = urllib.parse.urlparse(self.path)
        path   = parsed.path

        # API 엔드포인트 → 토큰 필수
        if path.startswith("/api/"):
            if not self._check_token():
                self._json({"error": "forbidden — token missing or invalid"}, 403)
                return
            self._handle_get_api(path)
            return

        # 정적 파일 (index.html, app.js, style.css …) — 토큰 불필요
        self._serve_static()

    def _handle_get_api(self, path):
        parsed = urllib.parse.urlparse(self.path)
        qs     = urllib.parse.parse_qs(parsed.query)

        if path == "/api/status":
            self._json(api_status())
        elif path == "/api/ssh-check":
            self._json(api_ssh_check())
        elif path == "/api/map":
            self._json(api_map_list())
        elif path == "/api/syncthing":
            self._json(api_syncthing())
        elif path == "/api/regrant":
            self._json(api_regrant())
        # ── SSH-assist + handshake (BRIDGE) ──
        elif path == "/api/ssh/pubkey":
            self._json(api_ssh_pubkey())
        elif path == "/api/handshake":
            self._json(api_handshake())
        # ── 터미널 (M3) ──
        elif path == "/api/term/list":
            self._json(api_term_list())
        elif path == "/api/term/output":
            self._json_result(api_term_output(qs.get("session", [""])[0]))
        # ── 에디터 (M4) ──
        elif path == "/api/editor/status":
            self._json(api_editor_status())
        # ── 알림 (M2) ──
        elif path == "/api/notifications":
            self._json(api_notifications())
        # ── 설정 ──
        elif path == "/api/notify/settings":
            self._json(api_notify_settings_get())
        # ── Mount (M-Mount) ──
        elif path == "/api/mount/status":
            self._json(api_mount_status())
        # ── Sync-backend config ──
        elif path == "/api/sync-backend":
            self._json(api_sync_backend_get())
        else:
            self._json({"error": f"unknown endpoint: {path}"}, 404)

    # ── POST 라우팅 ────────────────────────────────────────────────────────────
    def do_POST(self):
        parsed = urllib.parse.urlparse(self.path)
        path   = parsed.path

        if not self._check_token():
            self._json({"error": "forbidden — token missing or invalid"}, 403)
            return

        body = self._read_body()
        self._handle_post_api(path, body)

    def _handle_post_api(self, path, body):
        if path == "/api/permissions/open":
            result = api_permissions_open(body)
        elif path == "/api/role":
            result = api_role(body)
        elif path == "/api/config":
            result = api_config(body)
        elif path == "/api/map":
            result = api_map_mutate(body)
        # ── SSH-assist (BRIDGE) ──
        elif path == "/api/ssh/keygen":
            result = api_ssh_keygen()
        elif path == "/api/ssh/copy-id":
            result = api_ssh_copy_id()
        # ── 터미널 (M3) ──
        elif path == "/api/term/input":
            result = api_term_input(body)
        elif path == "/api/term/key":
            result = api_term_key(body)
        elif path == "/api/term/resize":
            result = api_term_resize(body)
        # ── Remote Desktop (M5) ──
        elif path == "/api/desktop/open":
            result = api_desktop_open()
        # ── 에디터 (M4) ──
        elif path == "/api/editor/start":
            result = api_editor_start()
        # ── 알림 (M2) ──
        elif path == "/api/notifications/seen":
            result = api_notifications_seen(body)
        # ── 설정 ──
        elif path == "/api/notify/settings":
            result = api_notify_settings_set(body)
        # ── Mount (M-Mount) ──
        elif path == "/api/mount/mount":
            result = api_mount_mount(body)
        elif path == "/api/mount/unmount":
            result = api_mount_unmount(body)
        # ── Sync-backend config ──
        elif path == "/api/sync-backend":
            result = api_sync_backend_set(body)
        else:
            self._json({"error": f"unknown endpoint: {path}"}, 404)
            return

        # api_*가 (dict, status) 튜플을 반환하는 경우와 dict만 반환하는 경우 모두 처리
        if isinstance(result, tuple):
            data, status = result
        else:
            data, status = result, 200
        self._json(data, status)


# ── 서버 실행 ──────────────────────────────────────────────────────────────────

def main():
    server = http.server.HTTPServer((WEB_BIND, WEB_PORT), Handler)
    host, port = server.server_address

    # 토큰을 URL 쿼리스트링에 포함. loopback 전용 + per-run 토큰이지만,
    # 이 URL(토큰 포함)은 브라우저 히스토리/주소창에 남는다는 점에 유의.
    url = f"http://{host}:{port}/?token={_TOKEN}"

    # URL은 stdout으로(이 호출 stdout만이 토큰을 노출), 토큰 없는 안내는 stderr로
    print(url, flush=True)
    print(f"[remote-pair-web] 서버 시작: http://{host}:{port}/  (Ctrl-C 로 종료)", file=sys.stderr)
    print("[remote-pair-web] 브라우저를 자동으로 열고 있습니다...", file=sys.stderr)

    # 브라우저 자동 오픈
    subprocess.Popen(
        ["open", url],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
    )

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        print("\n[remote-pair-web] 종료.", file=sys.stderr)
        server.shutdown()


if __name__ == "__main__":
    main()
