+/* ----------------------------------------------------------------------------
+ * RemotePair: text-only activity bar rail (Terminal / Browser / Settings).
+ * When the composite bar is created with icon:false, the action-item container
+ * does NOT get the `.icon` class, but updateLabel() still adds the codicon
+ * classNames AND the text label. Suppress the glyph and show the text.
+ * -------------------------------------------------------------------------- */
+.monaco-workbench .activitybar > .content :not(.monaco-menu) > .monaco-action-bar .action-item:not(.icon) .action-label.codicon::before {
+	display: none !important;
+}
+.monaco-workbench .activitybar > .content :not(.monaco-menu) > .monaco-action-bar .action-item:not(.icon) .action-label {
+	font-family: var(--vscode-font-family);
+	font-size: 10px;
+	font-weight: 500;
+	letter-spacing: 0.02em;
+	line-height: 1;
+	box-sizing: border-box;
+	color: var(--vscode-foreground);
+
+	/* RemotePair: thin vertical text rail. The label reads bottom-to-top along
+	   the slim rail. vertical-rl + 180deg rotation gives an upright, readable
+	   sideways label; the rail itself stays narrow (~30px). Tight padding and a
+	   small font keep the text crisp on the thin vertical strip. */
+	writing-mode: vertical-rl;
+	transform: rotate(180deg);
+	text-orientation: mixed;
+	white-space: nowrap;
+	overflow: hidden;
+	text-overflow: ellipsis;
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	width: 100%;
+	height: auto;
+	padding: 6px 0;
+}
+
+/* RemotePair: "+" rail action appended after the container list. */
+.monaco-workbench .activitybar > .content .remotepair-rail-add {
+	display: flex;
+	align-items: center;
+	justify-content: center;
+	width: 100%;
+	height: var(--activity-bar-action-height, 48px);
+	font-size: 16px;
+	font-weight: 400;
+	line-height: 1;
+	cursor: pointer;
+	color: var(--vscode-activityBar-inactiveForeground, var(--vscode-foreground));
+	box-sizing: border-box;
+	user-select: none;
+}
+
+.monaco-workbench .activitybar > .content .remotepair-rail-add:hover,
+.monaco-workbench .activitybar > .content .remotepair-rail-add:focus {
+	color: var(--vscode-activityBar-foreground, var(--vscode-foreground));
+	outline: none;
+}
