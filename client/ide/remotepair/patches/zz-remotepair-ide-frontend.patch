+	}
+}
+
+/**
+ * Sidebar ViewPane that hosts the embedded EditorPart. Step 1 (skeleton): render
+ * an empty EditorPart in the sidebar body. Step 2 (next): mount terminal editors
+ * into it via a scoped IEditorService.
+ */
+export class RemotePairTerminalSidebarView extends ViewPane {
