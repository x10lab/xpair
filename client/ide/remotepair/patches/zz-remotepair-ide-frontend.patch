+			} catch (e) {
+				rpLog('error', `openSessionInFolder: openTerminalInGroup threw: ${e}`); // best-effort
+			}
+		}, () => { /* part disposed */ });
+	}
+
+	/**
+	 * G005: open a terminal in the embedded group and stage `text` without a newline so the
+	 * user can complete the command (used by the Browser's "Add Mapping" action with the
+	 * staged `remote-pair map add ` prefix). Hosting-layer only — core terminal untouched.
+	 */
+	stageBrowserCommand(text: string): void {
+		const part = this.editorPart;
+		if (!part) {
+			return;
+		}
+		part.whenReady.then(() => {
+			if (this.editorPart !== part) {
+				return;
+			}
+			const group = part.activeGroup;
+			if (!group) {
+				return;
+			}
+			try {
+				const { instance, opened } = this.openTerminalInGroup(group);
+				opened.then(() => {
+					instance.sendText(text, false);
+				}, (e) => { rpLog('warn', `stageBrowserCommand: terminal open rejected: ${e}`); /* best-effort */ });
+			} catch (e) {
+				rpLog('error', `stageBrowserCommand: openTerminalInGroup threw: ${e}`); // best-effort
+			}
+		}, () => { /* part disposed */ });
+	}
+
+	/** Reflect the active terminal session's title in the view/container header. */
+	private syncTitleToActiveSession(): void {
+		const part = this.editorPart;
+		const input = part?.activeGroup?.activeEditor;
+		const instance = input instanceof TerminalEditorInput ? input.terminalInstance : undefined;
+
+		if (instance) {
+			this.activeTitleListener.value = instance.onTitleChanged(() => {
+				this.updateTitle(instance.title || RemotePairTerminalSidebarView.DEFAULT_TITLE);
+			});
+			this.updateTitle(instance.title || RemotePairTerminalSidebarView.DEFAULT_TITLE);
+		} else {
+			this.activeTitleListener.clear();
+			this.updateTitle(RemotePairTerminalSidebarView.DEFAULT_TITLE);
+		}
+	}
+
+	/** (Re)subscribe to the active group's active-editor changes. */
+	private trackActiveGroup(group: IEditorGroupView | undefined): void {
+		this.activeGroupListener.value = group?.onDidActiveEditorChange(() => {
+			this.syncTitleToActiveSession();
+			// Active session changed → refresh the Session Manager Attached row so its
+			// active-tab highlight (getActiveId) tracks the focused terminal.
+			notifyAttachedSessionsChanged();
+		});
+		this.syncTitleToActiveSession();
+	}
+
+	protected override renderBody(container: HTMLElement): void {
+		super.renderBody(container);
+
+		container.classList.add('remotepair-terminal-sidebar');
+
+		// G002: New Session "+" lives ONLY in the view title (row 1) via the MenuId.ViewTitle
+		// action `remotepair.terminalSidebar.newSession`, which DOES render in this container's
+		// merged composite title. The earlier in-body custom "+" button (row 2) was a duplicate
+		// (its original "ViewTitle does not render here" assumption is no longer true) and was
+		// removed per user feedback — the single row-1 "+" is sufficient.
+
+		// Defer the embedded EditorPart creation OUT of the synchronous composite-open
+		// path. renderBody runs inside compositePart.doOpenComposite → createComposite;
+		// instantiating a full EditorPart (with its own grid/group/editor + events) there
+		// re-enters the composite machinery so the sidebar's `activeComposite` never
+		// settles on Sessions. That marks the pane-composite-part `.empty`, and the
+		// full-height empty-pane-message (paneCompositePart.ts:615) shoves our viewlet off
+		// the bottom of the sidebar → blank. Building the part on the next frame lets
+		// doOpenComposite finish (activeComposite = Sessions) first.
+		this.partDisposables.add(scheduleAtNextAnimationFrame(getWindow(container), () => this.createEmbeddedPart(container)));
+	}
+
+	private createEmbeddedPart(container: HTMLElement): void {
+		if (this.editorPart) {
+			return; // already built (or rebuilt) — avoid duplicates
+		}
+
+		// EditorParts (the IEditorGroupsService impl) also implements IEditorPartsView.
+		const editorPartsView = this.editorGroupsService as unknown as IEditorPartsView;
+
+		// S0 — routing isolation (reverse-leak fix). We deliberately do NOT call
+		// `editorPartsView.registerPart(part)` here. Registration would add this part
+		// to EditorParts._parts and its MRU list, which feeds `getPartByDocument`
+		// (editorParts.ts:329) and `get activeGroup` (editorParts.ts:676). The result:
+		// when the user focuses this sidebar, `activePart`/`activeGroup` would resolve
+		// to the embedded group, so any editor opened with ACTIVE_GROUP (settings,
+		// search results, diffs, welcome) would be sucked into the session sidebar —
+		// the dual of the "main leak". It would also fire global `onDidActiveGroupChange`
+		// on every sidebar click (breadcrumbs/title/active-editor consumers misfire).
+		//
+		// The session sidebar is NOT a first-class editor area (unlike auxiliary
+		// windows, which is why AuxiliaryEditorPart *does* register). Leaving the part
+		// unregistered keeps it invisible to global group queries; we drive it solely
+		// via `part.activeGroup.openEditor` on the part instance, which is part-local
+		// and registration-independent. `groupsLabel`/`count` come from the part's own
+		// fields, so group construction still works standalone.
+		// CRITICAL: the editor-group layout CSS (editorgroupview.css) is scoped to
+		// `.monaco-workbench .part.editor > .content ...`. The main editor part gets the
+		// `.part .editor` classes from the workbench grid; an embedded part does not, so
+		// without these classes NONE of the group/grid/title/watermark layout rules apply
+		// → the grid container collapses to 0, the group's children fall back to static
+		// flow, the empty watermark stays in-flow, and the editor/terminal renders blank.
+		// `createContentArea` sets `this.element = parent` (this container) and appends the
+		// `.content` directly under it, so tagging the container `.part.editor` makes
+		// `.part.editor > .content` match and the editor renders correctly.
+		container.classList.add('part', 'editor');
+
+		const part = this.instantiationService.createInstance(EmbeddedEditorPart, editorPartsView);
+		this.partDisposables.add(part);
+		part.create(container);
+
+		this.editorPart = part;
+
+		// Blank-fix: drive the embedded part's visibility from the ViewPane body.
+		// Editor panes (including TerminalEditor/xterm) only attach and size when their
+		// group is told it is visible: EditorPart.setVisible → onDidVisibilityChange →
+		// EditorGroupView.onDidVisibilityChange (editorGroupView.ts:868) →
+		// editorPane.setVisible → TerminalEditor.setVisible (terminalEditor.ts:172) →
+		// terminalInstance.setVisible. An embedded part has nobody to drive this, so the
+		// xterm opens at 0×0 and stays blank. Wire it to the pane's own visibility.
+		this.partDisposables.add(this.onDidChangeBodyVisibility(visible => part.setVisible(visible)));
+		part.setVisible(this.isBodyVisible());
+
+		// Lay out immediately with the last known body size (layoutBody may have already
+		// run while the part did not yet exist).
+		if (this.lastWidth > 0 && this.lastHeight > 0) {
+			part.layout(this.lastWidth, this.lastHeight, 0, 0);
+		}
+
+		// Keep the header title in sync with the active session, swapping the
+		// per-group subscription whenever the embedded part's active group changes.
+		this.partDisposables.add(part.onDidChangeActiveGroup(group => this.trackActiveGroup(group)));
+		this.trackActiveGroup(part.activeGroup);
+
+		// RemotePair: on launch, show the New Session picker first (not an empty terminal).
+		// A terminal editor is created only when the user picks Claude/Shell/Codex/Gemini.
+		this.openSessionPicker();
+	}
+
+	protected override layoutBody(height: number, width: number): void {
+		super.layoutBody(height, width);
+		this.lastWidth = width;
+		this.lastHeight = height;
+		this.editorPart?.layout(width, height, 0, 0);
+	}
+
+	/** The live terminal instance in the embedded part's active group, if any. */
+	private activeTerminalInstance(): ITerminalInstance | undefined {
+		const input = this.editorPart?.activeGroup?.activeEditor;
+		return input instanceof TerminalEditorInput ? input.terminalInstance : undefined;
+	}
+
+	/**
+	 * Move keyboard focus onto the active terminal's xterm textarea — the ONLY element that
+	 * receives keystrokes. `instance.focus(true)` restores xterm's internal focus state but
+	 * does not reliably move DOM focus onto `.xterm-helper-textarea`; we therefore also focus
+	 * the textarea explicitly on a microtask (after any pending layout/visibility work). The
+	 * textarea is a descendant of this view's element, so its focus is picked up by the
+	 * ViewPane FocusTracker (onDidFocus) — keeping the workbench's focused-view tracking
+	 * correct so focus is not "fallen back" to the main editor. Hosting-layer only; uses the
+	 * terminal's public API and does not touch core terminal behavior.
+	 */
+	private focusActiveTerminal(): boolean {
+		const instance = this.activeTerminalInstance();
+		if (!instance) {
+			return false;
+		}
+		instance.focus(true);
+		queueMicrotask(() => {
+			if (this.activeTerminalInstance() === instance) {
+				instance.xterm?.raw.textarea?.focus();
+			}
+		});
+		return true;
+	}
+
+	/**
+	 * Route focus into the embedded terminal. We focus the xterm textarea DIRECTLY and
+	 * deliberately do NOT call `super.focus()` first: `ViewPane.focus()` runs
+	 * `this.element.focus()`, which moves DOM focus to the view *container* and steals it
+	 * from the xterm textarea — the root cause of unreliable terminal key input and the
+	 * focus "fallback". Only when there is no live terminal do we fall back to the default
+	 * ViewPane focus + group delegation. Hosting-layer only — core terminal behavior untouched.
+	 */
+	override focus(): void {
+		if (!this.focusActiveTerminal()) {
+			super.focus();
+			this.editorPart?.activeGroup?.focus();
+		}
+	}
+
+	override dispose(): void {
+		this.partDisposables.dispose();
+		this.editorPart = undefined;
+		super.dispose();
+	}
+}
+
+// --- registration: "Terminal" sidebar view container + view ----------------
+
+const viewContainerRegistry = Registry.as<IViewContainersRegistry>(ViewContainerExtensions.ViewContainersRegistry);
+const container = viewContainerRegistry.registerViewContainer({
+	id: REMOTEPAIR_TERMINAL_SIDEBAR_ID,
+	title: localize2('remotepairTerminalSidebar', "Sessions"),
+	ctorDescriptor: new SyncDescriptor(ViewPaneContainer, [REMOTEPAIR_TERMINAL_SIDEBAR_ID, { mergeViewWithContainerWhenSingleView: true }]),
+	storageId: REMOTEPAIR_TERMINAL_SIDEBAR_ID,
+	hideIfEmpty: false,
+	order: 1,
+}, ViewContainerLocation.Sidebar, { isDefault: false });
+
+const viewDescriptor: IViewDescriptor = {
+	id: REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view',
+	name: localize2('remotepairTerminalSidebarView', "Sessions"),
+	ctorDescriptor: new SyncDescriptor(RemotePairTerminalSidebarView),
+	canToggleVisibility: false,
+	canMoveView: false,
+};
+Registry.as<IViewsRegistry>(ViewContainerExtensions.ViewsRegistry).registerViews([viewDescriptor], container);
+
+// G002: "+" on the Sessions container top bar → opens the in-tab New Session picker.
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.terminalSidebar.newSession',
+			title: localize2('remotepairNewSession', "New Session"),
+			icon: Codicon.add,
+			f1: false,
+			menu: [{
+				id: MenuId.ViewTitle,
+				when: ContextKeyExpr.equals('view', REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view'),
+				group: 'navigation',
+				order: 1
+			}]
+		});
+	}
+	run(accessor: ServicesAccessor): void {
+		const viewsService = accessor.get(IViewsService);
+		const view = viewsService.getActiveViewWithId(REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view');
+		if (view instanceof RemotePairTerminalSidebarView) {
+			view.openSessionPicker();
+		}
+	}
+});
+
+// G005: open a session in a specific folder (from the Browser's per-folder "+"). Ensures
+// the Sessions sidebar is visible first (so the embedded EditorPart exists), then routes
+// the folder uri into the view's openSessionInFolder.
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.terminalSidebar.openSessionInFolder',
+			title: localize2('remotepairOpenSessionInFolder', "New Session Here"),
+			icon: Codicon.add,
+			f1: false
+		});
+	}
+	async run(accessor: ServicesAccessor, resource?: URI): Promise<void> {
+		const viewsService = accessor.get(IViewsService);
+		// Make the Sessions sidebar visible so the embedded EditorPart is constructed.
+		const view = await viewsService.openView(REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view', false);
+		if (view instanceof RemotePairTerminalSidebarView) {
+			view.openSessionInFolder(resource);
+		}
+	}
+});
+
+// G005: stage the `remote-pair map add ` command in a Sessions terminal (from the Browser's
+// "Add Mapping" action). Ensures the Sessions sidebar is visible first, then stages the text.
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.addMapping',
+			title: localize2('remotepairAddMapping', "RemotePair: Add Folder Mapping"),
+			icon: Codicon.add,
+			f1: true
+		});
+	}
+	async run(accessor: ServicesAccessor): Promise<void> {
+		const viewsService = accessor.get(IViewsService);
+		// Make the Sessions sidebar visible so the embedded EditorPart is constructed.
+		const view = await viewsService.openView(REMOTEPAIR_TERMINAL_SIDEBAR_ID + '.view', false);
+		if (view instanceof RemotePairTerminalSidebarView) {
+			view.stageBrowserCommand('remote-pair map add ');
+		}
+	}
+});
