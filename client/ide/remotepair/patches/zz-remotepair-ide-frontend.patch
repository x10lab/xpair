+++ b/src/vs/workbench/contrib/files/browser/remotePairBrowserActions.ts
@@ -0,0 +1,396 @@
+/*---------------------------------------------------------------------------------------------
+ *  RemotePair (G005): top-of-Browser actions and per-folder session creation.
+ *
+ *  The "Browser" is the relabeled Explorer view container (VIEWLET_ID). This file owns the
+ *  action contributions so they stay out of core explorer files:
+ *    - Browser title bar: Search / Extensions (MenuId.ViewContainerTitle). The row-1
+ *      "Add Mapping" action was removed (C1): the sole add entry point is now the
+ *      below-list / empty-state "Add Root" affordance which runs the mount-first
+ *      `remotepair.browser.addRoot` command (registered in the RemotePair extension).
+ *    - Empty-state "Add Root" button: a viewsWelcome entry on the explorer EmptyView.
+ *    - Per-folder inline "+": creates a Sessions terminal rooted at that folder.
+ *    - Per-folder inline star (C3): toggles the folder in the C2 Favorites store.
+ *    - Per-folder-row hover controls (C3): a star + '+' rendered on EVERY folder row (roots and
+ *      subfolders, never files) via the native IExplorerFileContribution mechanism — the
+ *      explorer file tree wires MenuId.ExplorerContext only to its right-click context menu
+ *      (explorerView.ts:701 showContextMenu), so group:'inline' there does NOT produce inline
+ *      hover icons on tree rows. The renderer instead invokes registered file contributions
+ *      (explorerViewer.ts:896/1015 contr.setResource(uri)) per row, which is the supported
+ *      inline-row hook. The contributions just dispatch the two Action2 commands below.
+ *  All work goes through public services / the existing Sessions helpers; core terminal,
+ *  explorer-tree, and EditorPart behavior is untouched (the file-contribution registry is a
+ *  public extension point — no core file is edited).
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize, localize2 } from '../../../../nls.js';
+import { Action2, registerAction2, MenuId } from '../../../../platform/actions/common/actions.js';
+import { ContextKeyExpr } from '../../../../platform/contextkey/common/contextkey.js';
+import { ServicesAccessor, IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+import { IListService } from '../../../../platform/list/browser/listService.js';
+import { Codicon } from '../../../../base/common/codicons.js';
+import { URI } from '../../../../base/common/uri.js';
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { $, append, addDisposableListener, EventType } from '../../../../base/browser/dom.js';
+import { IEditorService } from '../../../services/editor/common/editorService.js';
+import { VIEWLET_ID } from '../common/files.js';
+import { ExplorerFolderContext } from '../common/files.js';
+import { getResourceForCommand, IExplorerService } from './files.js';
+import { IExplorerFileContribution, explorerFileContribRegistry } from './explorerFileContrib.js';
+import { favoritesStore } from './remotePairFavorites.js';
+import { routeToExplorer, routeToSearch } from './remotePairBrowserRouter.js'; // RemotePair (C4.3): Explorer<->Search inner router
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { IViewsRegistry, Extensions as ViewExtensions, ViewContentGroups } from '../../../common/views.js';
+import { EmptyView } from './views/emptyView.js';
+import { WorkbenchStateContext } from '../../../common/contextkeys.js';
+import { rpLog } from '../../terminal/browser/remotePairLog.js'; // RemotePair: unified workbench logger (docs/logging.md §8)
+
+/**
+ * Browser title-bar (Row-1) action: Explorer → route the Browser inner content back to the
+ * Explorer file tree (C4.3 inner router). Stays within the Browser frame — does NOT navigate to a
+ * different viewlet. Ordered before Search so the pair reads "Explorer | Search".
+ */
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.routeExplorer',
+			title: localize2('remotepairBrowserExplorer', "Explorer"),
+			icon: Codicon.files,
+			f1: false,
+			menu: [{
+				id: MenuId.ViewContainerTitle,
+				when: ContextKeyExpr.equals('viewContainer', VIEWLET_ID),
+				group: 'navigation',
+				order: 9
+			}]
+		});
+	}
+	run(accessor: ServicesAccessor): void {
+		// RemotePair (C4.3): inner-route to Explorer (no global-viewlet navigation).
+		rpLog('debug', 'browser title-bar action: route to Explorer');
+		routeToExplorer(accessor);
+	}
+});
+
+/**
+ * Browser title-bar (Row-1) action: Search → route the Browser inner content to the hosted Search
+ * view (C4.3 inner router), swapping it in WITHIN the Browser frame. This replaces the previous
+ * `workbench.action.findInFiles` call, which navigated to the global Search viewlet covering the
+ * sidebar — the AC19 bug. The router keeps the active viewlet = Browser and escalates (logs) rather
+ * than ever falling back to that global navigation.
+ */
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.search',
+			title: localize2('remotepairBrowserSearch', "Search"),
+			icon: Codicon.search,
+			f1: false,
+			menu: [{
+				id: MenuId.ViewContainerTitle,
+				when: ContextKeyExpr.equals('viewContainer', VIEWLET_ID),
+				group: 'navigation',
+				order: 10
+			}]
+		});
+	}
+	run(accessor: ServicesAccessor): void {
+		// RemotePair (C4.3): inner-route to Search (no global-viewlet navigation).
+		rpLog('debug', 'browser title-bar action: route to Search');
+		routeToSearch(accessor);
+	}
+});
+
+/**
+ * Browser title-bar action: Extensions → opens the Extensions viewlet.
+ */
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.extensions',
+			title: localize2('remotepairBrowserExtensions', "Extensions"),
+			icon: Codicon.extensions,
+			f1: false,
+			menu: [{
+				id: MenuId.ViewContainerTitle,
+				when: ContextKeyExpr.equals('viewContainer', VIEWLET_ID),
+				group: 'navigation',
+				order: 11
+			}]
+		});
+	}
+	run(accessor: ServicesAccessor): void {
+		rpLog('debug', 'browser title-bar action: open Extensions viewlet');
+		accessor.get(ICommandService).executeCommand('workbench.view.extensions');
+	}
+});
+
+/**
+ * Per-folder "New Session Here": on Explorer folders, create a Sessions terminal rooted at
+ * that folder. Contributed to MenuId.ExplorerContext (the file explorer's right-click menu —
+ * the same menu New File/New Folder use); the generic MenuId.ViewItemContext is NOT honored by
+ * the file-tree renderer. Resolves the folder uri via getResourceForCommand and delegates to the
+ * Sessions command (which makes the sidebar visible first, then opens the terminal).
+ */
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.newSessionInFolder',
+			title: localize2('remotepairBrowserNewSessionInFolder', "New Session Here"),
+			icon: Codicon.add,
+			f1: false,
+			menu: [
+				// Right-click context menu entry.
+				{
+					id: MenuId.ExplorerContext,
+					when: ExplorerFolderContext,
+					group: 'navigation',
+					order: 5
+				},
+				// Inline (hover) entry on folder rows. The explorer tree's right-click menu honors
+				// group:'inline', and the C3 per-folder-row contribution below dispatches this same
+				// command so the '+' appears as a hover icon on the row itself.
+				{
+					id: MenuId.ExplorerContext,
+					when: ExplorerFolderContext,
+					group: 'inline',
+					order: 20
+				}
+			]
+		});
+	}
+	run(accessor: ServicesAccessor, resource?: unknown): void {
+		const editorService = accessor.get(IEditorService);
+		const listService = accessor.get(IListService);
+		const uri = getResourceForCommand(resource, editorService, listService);
+		// Log-only: do NOT alter control flow. openSessionInFolder(cwd: URI | undefined) accepts an
+		// undefined cwd by contract, so we still dispatch (best-effort) but flag the unresolved case.
+		if (uri) {
+			rpLog('info', `newSessionInFolder: opening Sessions terminal rooted at ${uri.toString()}`);
+		} else {
+			rpLog('warn', 'newSessionInFolder: could not resolve a folder uri; dispatching with undefined cwd');
+		}
+		accessor.get(ICommandService).executeCommand('remotepair.terminalSidebar.openSessionInFolder', uri);
+	}
+});
+
+/**
+ * C3 — Per-folder "Toggle Favorite" (the star). Resolves the folder uri (getResourceForCommand)
+ * and toggles it in the C2 Favorites store via the module-level accessor (favoritesStore()), so
+ * there is no hard import of the store class and no import cycle. Contributed to the explorer
+ * right-click menu (group:'inline') and dispatched inline by the per-folder-row contribution
+ * below. Folder-only via ExplorerFolderContext (AC13 / DR-6 primary gate).
+ */
+registerAction2(class extends Action2 {
+	constructor() {
+		super({
+			id: 'remotepair.browser.toggleFavorite',
+			title: localize2('remotepairBrowserToggleFavorite', "Toggle Favorite"),
+			icon: Codicon.star,
+			f1: false,
+			menu: [{
+				id: MenuId.ExplorerContext,
+				when: ExplorerFolderContext,
+				group: 'inline',
+				order: 21
+			}]
+		});
+	}
+	run(accessor: ServicesAccessor, resource?: unknown): void {
+		const editorService = accessor.get(IEditorService);
+		const listService = accessor.get(IListService);
+		const uri = getResourceForCommand(resource, editorService, listService);
+		if (uri) {
+			const store = favoritesStore();
+			if (store) {
+				rpLog('debug', `toggleFavorite: ${uri.toString()}`);
+				store.toggleFavorite(uri);
+			} else {
+				// Store not yet created (eager startup contribution missing); nothing to toggle.
+				rpLog('warn', `toggleFavorite: favorites store unavailable; ignoring ${uri.toString()}`);
+			}
+		} else {
+			rpLog('warn', 'toggleFavorite: could not resolve a folder uri; ignoring');
+		}
+	}
+});
+
+/**
+ * C1 empty-state "Add Root" button. When there are no FOLDER_MAPS roots the Browser removes all
+ * workspace roots (extension reconcileBrowserRoots), leaving zero folders → the workbench enters
+ * the 'empty' state and the explorer EmptyView shows. This viewsWelcome entry renders a single
+ * button that runs the mount-first `remotepair.browser.addRoot` command (registered in the
+ * RemotePair extension). It is the same entry point as the populated below-list footer
+ * (explorerView.ts append-hook). The command-link uses the rocket codicon ($(rocket)) so it is
+ * visibly distinct from the native New Folder icon (AC6).
+ *
+ * `when`: gated to the 'empty' workbench state (zero workspace folders, no .code-workspace open) —
+ * the exact state a RemotePair client lands in with zero FOLDER_MAPS roots (the extension manages
+ * roots via updateWorkspaceFolders on a plain window, never a .code-workspace). WITHOUT this gate
+ * the welcome had no `when`, so it was ALWAYS visible and STACKED on top of every native EmptyView
+ * welcome (explorerViewlet.ts:301-373): the viewsWelcome panel renders EVERY descriptor whose
+ * `when` matches (viewPane.ts onDidChangeViewWelcomeContent), so an un-gated entry duplicated
+ * content in the 'workspace'/'folder' states too — exactly where it never belonged (e.g. when a
+ * client HAS folders). Gating to 'empty' confines it to the no-roots Browser and removes the
+ * stacking on the 'workspace'-gated native welcomes (#1/#2, explorerViewlet.ts:301/314). The
+ * remaining native local-empty welcomes (#4/#5, gated on notWorkspace + remoteName=='') are
+ * core-owned and cannot be suppressed from here without editing core; this gate is the maximal
+ * de-stacking achievable in a RemotePair-owned file.
+ */
+Registry.as<IViewsRegistry>(ViewExtensions.ViewsRegistry).registerViewWelcomeContent(EmptyView.ID, {
+	content: localize(
+		{ key: 'remotepairAddRootWelcome', comment: ['Please do not translate the word "command", it is part of our internal syntax which must not change'] },
+		"No mapped folders yet.\n[$(rocket) Add Root](command:remotepair.browser.addRoot)\nMounts a host folder and adds it as a Browser root."
+	),
+	when: WorkbenchStateContext.isEqualTo('empty'),
+	group: ViewContentGroups.Open,
+	order: 1
+});
+
+/*---------------------------------------------------------------------------------------------
+ *  C3 — Per-folder-row hover controls (star + '+').
+ *
+ *  The native, supported way to put inline controls on EVERY explorer tree row is an
+ *  IExplorerFileContribution: the FilesRenderer instantiates one per row template and calls
+ *  setResource(uri) on every render (explorerViewer.ts:896/1015), including rapid scroll, and
+ *  setResource(undefined) to clear (explorerViewer.ts:924/991). We render a star + '+' anchored
+ *  to the right of the row, revealed on hover via CSS.
+ *
+ *  Folder-ness / DR-6 flicker guard: each row may be a file, a folder, or an unresolved row
+ *  during async model population. We confirm folder-ness with IExplorerService.findClosest(uri)
+ *  and render ONLY when it resolves to a directory. When findClosest(uri) is null (not yet in the
+ *  model) OR resolves to a file, the controls are HIDDEN — re-evaluated on the next setResource.
+ *  This prevents star/'+' flicker on files and unresolved rows during initial paint.
+ *
+ *  The star reflects live favorite state from the C2 store (favoritesStore()): filled star when
+ *  favorited, outline star otherwise; clicking it dispatches remotepair.browser.toggleFavorite and
+ *  the store's onDidChangeFavorites repaints the icon. The '+' dispatches
+ *  remotepair.browser.newSessionInFolder (single open contract). Both commands resolve the uri via
+ *  getResourceForCommand(uri) and we pass the row uri explicitly.
+ *--------------------------------------------------------------------------------------------*/
+class RemotePairFolderRowActions extends Disposable implements IExplorerFileContribution {
+
+	private readonly actions: HTMLElement;
+	private readonly starEl: HTMLElement;
+	private readonly addEl: HTMLElement;
+	private currentResource: URI | undefined;
+	// True once we have subscribed to the C2 store's onDidChangeFavorites. The store is created
+	// eagerly at startup, but this row template may (in principle) be constructed before that
+	// contribution runs — in which case favoritesStore() is undefined in the ctor and the
+	// subscription would never be made. We therefore (re)try the subscription lazily in
+	// setResource so the star auto-updates as soon as a store exists.
+	private favoritesSubscribed = false;
+
+	constructor(
+		container: HTMLElement,
+		@IExplorerService private readonly explorerService: IExplorerService,
+		@ICommandService private readonly commandService: ICommandService
+	) {
+		super();
+
+		this.actions = append(container, $('.remotepair-folder-row-actions'));
+		this.actions.style.display = 'none';
+
+		// Base classes only; the filled/outline star codicon class is set by updateStarIcon so the
+		// two glyphs never stack.
+		this.starEl = append(this.actions, $('.remotepair-folder-row-action.codicon'));
+		this.starEl.title = localize('remotepairFolderRowFavorite', "Toggle Favorite");
+		this.starEl.setAttribute('role', 'button');
+
+		this.addEl = append(this.actions, $('.remotepair-folder-row-action.codicon.codicon-' + Codicon.add.id));
+		this.addEl.title = localize('remotepairFolderRowNewSession', "New Session Here");
+		this.addEl.setAttribute('role', 'button');
+
+		// Dispatch on MOUSE_DOWN (not CLICK). The explorer tree changes list focus/selection on the
+		// row's native `click` (listWidget MouseController.onViewPointer), and that focus change
+		// re-renders the row template — which calls our setResource(undefined)/setResource(other),
+		// clearing this.currentResource BEFORE a CLICK handler would read it. Result: on a not-yet
+		// list-focused row the command saw an undefined uri and getResourceForCommand fell through to
+		// the (empty) focus branch, so nothing happened until the row was selected first. mousedown
+		// fires before that focus change, while this.currentResource is still the live row uri, and
+		// stopPropagation here keeps the tree from focusing/re-rendering the row out from under us.
+		// We snapshot the uri locally so the value passed to the command is exactly the row's uri.
+		this._register(addDisposableListener(this.starEl, EventType.MOUSE_DOWN, (e: MouseEvent) => {
+			e.stopPropagation();
+			e.preventDefault();
+			const resource = this.currentResource;
+			if (resource) {
+				rpLog('debug', `folder-row star clicked -> toggleFavorite ${resource.toString()}`);
+				this.commandService.executeCommand('remotepair.browser.toggleFavorite', resource);
+			}
+		}));
+		this._register(addDisposableListener(this.addEl, EventType.MOUSE_DOWN, (e: MouseEvent) => {
+			e.stopPropagation();
+			e.preventDefault();
+			const resource = this.currentResource;
+			if (resource) {
+				rpLog('debug', `folder-row '+' clicked -> newSessionInFolder ${resource.toString()}`);
+				this.commandService.executeCommand('remotepair.browser.newSessionInFolder', resource);
+			}
+		}));
+		// Also swallow the trailing CLICK so a stray click (e.g. synthetic, or if mousedown was
+		// missed) never reaches the tree row and triggers open/expand. No command runs here.
+		this._register(addDisposableListener(this.starEl, EventType.CLICK, (e: MouseEvent) => {
+			e.stopPropagation();
+			e.preventDefault();
+		}));
+		this._register(addDisposableListener(this.addEl, EventType.CLICK, (e: MouseEvent) => {
+			e.stopPropagation();
+			e.preventDefault();
+		}));
+
+		// Keep the star icon in sync with the C2 store while a folder row is shown. Subscribe now if
+		// the store already exists; otherwise setResource will retry (lazy late-binding).
+		this.ensureFavoritesSubscription();
+	}
+
+	/**
+	 * Subscribe (once) to the C2 store's onDidChangeFavorites so the star auto-updates when
+	 * favorites change elsewhere. Idempotent and leak-free: the subscription is registered with
+	 * this row (disposed with it), and the guard prevents re-subscribing on every setResource.
+	 */
+	private ensureFavoritesSubscription(): void {
+		if (this.favoritesSubscribed) {
+			return;
+		}
+		const store = favoritesStore();
+		if (store) {
+			this.favoritesSubscribed = true;
+			this._register(store.onDidChangeFavorites(() => this.updateStarIcon()));
+		}
+	}
+
+	/** Called by the FilesRenderer on every row render (and with undefined to clear). */
+	setResource(resource: URI | undefined): void {
+		// Late-bind the favorites subscription in case the store was not yet created at ctor time.
+		this.ensureFavoritesSubscription();
+		// DR-6: hide on unresolved/cleared rows. Confirm folder-ness via the explorer model;
+		// findClosest === null (not yet populated) OR a non-directory (file) → hide.
+		const item = resource ? this.explorerService.findClosest(resource) : null;
+		if (!resource || !item || !item.isDirectory) {
+			this.currentResource = undefined;
+			this.actions.style.display = 'none';
+			return;
+		}
+		this.currentResource = resource;
+		this.actions.style.display = '';
+		this.updateStarIcon();
+	}
+
+	private updateStarIcon(): void {
+		const favorited = !!this.currentResource && !!favoritesStore()?.isFavorite(this.currentResource);
+		// Toggle between the filled (favorited) and outline (not favorited) star codicons.
+		this.starEl.classList.toggle('codicon-' + Codicon.starFull.id, favorited);
+		this.starEl.classList.toggle('codicon-' + Codicon.starEmpty.id, !favorited);
+		this.starEl.classList.toggle('remotepair-folder-row-action-active', favorited);
+	}
+}
+
+// Register the per-folder-row contribution on the public explorer file-contribution registry
+// (no core explorer file is edited — the FilesRenderer already instantiates registered
+// contributions per row).
+explorerFileContribRegistry.register({
+	create(insta: IInstantiationService, container: HTMLElement): IExplorerFileContribution {
+		return insta.createInstance(RemotePairFolderRowActions, container);
+	}
+});
diff --git a/src/vs/workbench/contrib/files/browser/remotePairBrowserRouter.ts b/src/vs/workbench/contrib/files/browser/remotePairBrowserRouter.ts
new file mode 100644
index 0000000..ba861e2
--- /dev/null
+++ b/src/vs/workbench/contrib/files/browser/remotePairBrowserRouter.ts
@@ -0,0 +1,196 @@
+/*---------------------------------------------------------------------------------------------
+ *  RemotePair (C4.3): Explorer <-> Search inner ROUTER inside the Browser VIEW_CONTAINER.
+ *
+ *  GOAL (AC19/AC20): the Row-1 "Explorer" / "Search" buttons swap the inner content WITHIN the
+ *  Browser frame. The active viewlet/composite stays = Browser the entire time — we do NOT
+ *  navigate to a global Search viewlet (that navigation is the AC19 bug). The Browser 2-row
+ *  header persists across switches; Favorites (C2) stays registered at the bottom.
+ *
+ *  MECHANISM (deviation from the plan's literal wording — see the note below):
+ *    The plan (ADR-1 / Step C4.3) said "relocate the Search VIEW into the Browser container via
+ *    viewDescriptorService.moveViewsToContainer(...) + per-view visibility toggle". Grounding that
+ *    in the actual code surfaced TWO hard blockers that make the literal mechanism unsafe:
+ *      1. moveViewsToContainer() PERSISTS the relocation (viewDescriptorService.ts:411 ->
+ *         saveViewCustomizations -> views.customizations in PROFILE storage). Combined with the
+ *         search container's hideIfEmpty:true, this yanks Search out of its OWN viewlet
+ *         PERMANENTLY across reloads — a real footgun, not a transient state.
+ *      2. Both the Explorer file-tree view (explorerViewlet.ts) and the core Search view
+ *         (search.contribution.ts:67) are registered canToggleVisibility:false, so
+ *         viewContainerModel.setVisible() NO-OPS for them (viewContainerModel.ts:431). Visibility
+ *         routing is dead on arrival unless they are toggleable.
+ *
+ *    Faithful-to-intent fix (Option A spirit: HOST the Search view inside the Browser container,
+ *    keep active viewlet = Browser, no global navigation), but NON-PERSISTENT and without mutating
+ *    any core descriptor:
+ *      - Register a RemotePair-OWNED view descriptor (REMOTEPAIR_SEARCH_VIEW_ID) directly INTO the
+ *        Browser VIEW_CONTAINER whose ctorDescriptor instantiates the native SearchView class
+ *        (search browser/searchView.ts). Because its DEFAULT container is the Browser container,
+ *        viewDescriptorService never writes a customization for it (saveViewCustomizations skips
+ *        views already at their default location, viewDescriptorService.ts:686) — nothing persists,
+ *        and the native global Search viewlet is left fully intact.
+ *      - canToggleVisibility:true on OUR descriptor + the C4.3 edit making the Explorer file-tree
+ *        view canToggleVisibility:true (explorerViewlet.ts) let the router flip per-view visibility.
+ *      - Explorer C4.1 already disabled the single-view merge, so hiding either view never collapses
+ *        the 2-row header.
+ *
+ *  ROUTER:
+ *      showExplorer(): show Explorer file-tree view, hide the hosted Search view.
+ *      showSearch():   show the hosted Search view, hide the Explorer file-tree view.
+ *    Both via IViewDescriptorService.getViewContainerModel(BROWSER_CONTAINER).setVisible(id, vis).
+ *
+ *  DEFENSIVE / ESCALATION (mandated): every operation that could fail to resolve the container or
+ *  the view is wrapped. On failure we LOG a clear escalation marker and DO NOTHING further — we
+ *  NEVER silently fall back to opening the global Search viewlet (that would be the AC19 bug).
+ *
+ *  RUNTIME UNCERTAINTY (flagged for the orchestrator's CDP spike — NOT verifiable by tsc):
+ *    SearchView consumes a SINGLETON search model (ISearchViewModelWorkbenchService.searchModel,
+ *    searchView.ts:297) and binds GLOBAL search context keys in its ctor (searchView.ts:249-265).
+ *    Hosting a SECOND SearchView instance (ours, under a new id) alongside the native one MAY:
+ *      (a) share/contend on the one search model, and
+ *      (b) double-bind global search context keys / mis-target search keybindings bound to the
+ *          native VIEW_ID 'workbench.view.search'.
+ *    This is the #1 thing to validate at runtime via CDP. If the hosted Search view fails to
+ *    render or the singleton coupling breaks behavior, ESCALATE for redesign (e.g. host only the
+ *    Search WIDGET, or gate the native instance) — do NOT fall back to the global viewlet.
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize2 } from '../../../../nls.js';
+import { SyncDescriptor } from '../../../../platform/instantiation/common/descriptors.js';
+import { ServicesAccessor } from '../../../../platform/instantiation/common/instantiation.js';
+import { IFileService } from '../../../../platform/files/common/files.js';
+import { ILogService } from '../../../../platform/log/common/log.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { IViewDescriptor, IViewDescriptorService, IViewsRegistry, Extensions as ViewContainerExtensions } from '../../../common/views.js';
+import { IViewsService } from '../../../services/views/common/viewsService.js';
+import { IPathService } from '../../../services/path/common/pathService.js';
+import { SearchView } from '../../search/browser/searchView.js';
+import { VIEW_ID as EXPLORER_FILE_VIEW_ID } from '../common/files.js';
+import { VIEW_CONTAINER } from './explorerViewlet.js';
+import { configureRemotePairLog, rpLog } from '../../terminal/browser/remotePairLog.js';
+
+/** Distinct id (NOT the native 'workbench.view.search') for the Browser-hosted Search instance. */
+export const REMOTEPAIR_SEARCH_VIEW_ID = 'remotepair.browser.search';
+
+const RP_ROUTER_LOG_PREFIX = 'RemotePair C4:';
+const RP_ROUTER_ESCALATION = 'RemotePair C4: Search relocation failed — needs redesign';
+
+/**
+ * Wire the shared workbench logger (remotePairLog.ts) from the per-call ServicesAccessor so every
+ * router line is emitted in the unified docs/logging.md §3 format and best-effort mirrored to
+ * ~/.remote-pair/logs/workbench.log. Best-effort and never-throw: ILogService is required (resolve
+ * defensively), the file-mirror sinks are optional and degrade to ILogService-only when absent.
+ * configureRemotePairLog() is idempotent (last call wins, same renderer singletons), so calling it
+ * on each route is a cheap re-bind — it never changes control flow.
+ */
+function ensureRpLog(accessor: ServicesAccessor): void {
+	try {
+		const logService = accessor.get(ILogService);
+		let fileService: IFileService | undefined;
+		let pathService: IPathService | undefined;
+		try { fileService = accessor.get(IFileService); } catch { /* optional mirror sink */ }
+		try { pathService = accessor.get(IPathService); } catch { /* optional mirror sink */ }
+		configureRemotePairLog({ logService, fileService, pathService });
+	} catch {
+		// If even ILogService can't be resolved, rpLog stays a safe no-op; never throw into the UI.
+	}
+}
+
+// --- hosted Search view descriptor (registered into the Browser container, non-persistent) ------
+
+/** localize2 first arg MUST be a static string literal. */
+const remotePairSearchViewDescriptor: IViewDescriptor = {
+	id: REMOTEPAIR_SEARCH_VIEW_ID,
+	name: localize2('remotepairBrowserSearch', "Search"),
+	// Host the native SearchView class under our own id, directly in the Browser container, so the
+	// global Search viewlet is untouched and no view-location customization is persisted.
+	ctorDescriptor: new SyncDescriptor(SearchView),
+	// Order between the file tree (order:1) and Favorites (order:100). It is hidden by default and
+	// only revealed by the router when the user clicks Row-1 "Search".
+	order: 2,
+	canToggleVisibility: true,
+	canMoveView: false,
+	hideByDefault: true,
+	collapsed: false,
+};
+
+try {
+	Registry.as<IViewsRegistry>(ViewContainerExtensions.ViewsRegistry).registerViews([remotePairSearchViewDescriptor], VIEW_CONTAINER);
+} catch (err) {
+	// Registration failure must not crash workbench startup; the router below degrades to a no-op
+	// (showSearch logs the escalation marker). Do NOT fall back to the global viewlet.
+	// eslint-disable-next-line no-console
+	console.error(`${RP_ROUTER_ESCALATION} (descriptor registration threw)`, err);
+}
+
+// --- router ----------------------------------------------------------------------------------
+
+/**
+ * Toggle per-view visibility inside the Browser container. Resolves the Browser container + its
+ * model defensively; on any failure logs the escalation marker and returns false (the caller then
+ * does nothing — never navigates to the global viewlet).
+ */
+function setBrowserViewVisible(accessor: ServicesAccessor, viewId: string, visible: boolean): boolean {
+	const viewDescriptorService = accessor.get(IViewDescriptorService);
+	ensureRpLog(accessor);
+	try {
+		const container = viewDescriptorService.getViewContainerById(VIEW_CONTAINER.id);
+		if (!container) {
+			rpLog('error', `${RP_ROUTER_ESCALATION} (Browser container ${VIEW_CONTAINER.id} not resolved)`);
+			return false;
+		}
+		const model = viewDescriptorService.getViewContainerModel(container);
+		if (!model) {
+			rpLog('error', `${RP_ROUTER_ESCALATION} (no view container model for ${VIEW_CONTAINER.id})`);
+			return false;
+		}
+		if (!model.activeViewDescriptors.some(v => v.id === viewId)) {
+			// The target view is not active in the container — for the hosted Search view this means
+			// its registration failed above. Escalate; never silently open the global viewlet.
+			rpLog('error', `${RP_ROUTER_ESCALATION} (view ${viewId} not active in Browser container)`);
+			return false;
+		}
+		model.setVisible(viewId, visible);
+		return true;
+	} catch (err) {
+		rpLog('error', `${RP_ROUTER_ESCALATION} (setVisible ${viewId}=${visible} threw): ${err instanceof Error ? err.message : String(err)}`);
+		return false;
+	}
+}
+
+/**
+ * Route to the Explorer file tree: show Explorer, hide the hosted Search view. Keeps the active
+ * viewlet = Browser (we only flip inner view visibility; we never call openViewContainer for a
+ * different viewlet). Ensures the Browser container itself is open/focused.
+ */
+export function routeToExplorer(accessor: ServicesAccessor): void {
+	const viewsService = accessor.get(IViewsService);
+	ensureRpLog(accessor);
+	rpLog('trace', `${RP_ROUTER_LOG_PREFIX} routeToExplorer`);
+	// Hide Search first, then show Explorer (order avoids a transient 0-visible-views flicker).
+	setBrowserViewVisible(accessor, REMOTEPAIR_SEARCH_VIEW_ID, false);
+	const shown = setBrowserViewVisible(accessor, EXPLORER_FILE_VIEW_ID, true);
+	if (shown) {
+		// Reveal the Explorer view inside the (already-active) Browser container — openView focuses
+		// the view WITHOUT switching the active viewlet away from Browser.
+		viewsService.openView(EXPLORER_FILE_VIEW_ID, true).catch(err => rpLog('error', `${RP_ROUTER_LOG_PREFIX} openView(explorer) failed: ${err instanceof Error ? err.message : String(err)}`));
+	}
+}
+
+/**
+ * Route to Search: show the hosted Search view, hide the Explorer file tree. Active viewlet stays
+ * = Browser. On any failure the escalation marker is logged and we do NOTHING (no global-viewlet
+ * fallback — that is the AC19 bug we exist to avoid).
+ */
+export function routeToSearch(accessor: ServicesAccessor): void {
+	const viewsService = accessor.get(IViewsService);
+	ensureRpLog(accessor);
+	rpLog('trace', `${RP_ROUTER_LOG_PREFIX} routeToSearch`);
+	const shown = setBrowserViewVisible(accessor, REMOTEPAIR_SEARCH_VIEW_ID, true);
+	if (!shown) {
+		// Escalation already logged by setBrowserViewVisible. Do NOT open the global Search viewlet.
+		return;
+	}
+	// Only hide Explorer once Search is confirmed visible, so the container is never 0-visible.
+	setBrowserViewVisible(accessor, EXPLORER_FILE_VIEW_ID, false);
+	viewsService.openView(REMOTEPAIR_SEARCH_VIEW_ID, true).catch(err => rpLog('error', `${RP_ROUTER_LOG_PREFIX} openView(search) failed: ${err instanceof Error ? err.message : String(err)}`));
+}
diff --git a/src/vs/workbench/contrib/files/browser/remotePairFavorites.ts b/src/vs/workbench/contrib/files/browser/remotePairFavorites.ts
new file mode 100644
index 0000000..bbb8f38
--- /dev/null
+++ b/src/vs/workbench/contrib/files/browser/remotePairFavorites.ts
@@ -0,0 +1,360 @@
+/*---------------------------------------------------------------------------------------------
+ *  RemotePair (C2): Favorites store + Favorites view at the bottom of the Browser container.
+ *
+ *  The "Browser" is the relabeled Explorer view container (VIEWLET_ID / VIEW_CONTAINER). This
+ *  file owns:
+ *    - RemotePairFavoritesStore: a tiny store persisting favorite folder URIs via
+ *      IStorageService. Reads = union of WORKSPACE + PROFILE (global) scopes so favorites
+ *      survive across workspaces; writes update BOTH scopes (default write through workspace,
+ *      mirrored to global). Exposes onDidChangeFavorites + a small API.
+ *    - A module-level accessor (setFavoritesStore / favoritesStore) mirroring the
+ *      setSessionLauncher / setAttachedSessionsProvider injection pattern in the terminal
+ *      sidebar, so C3's per-folder star can call toggleFavorite/isFavorite without a hard
+ *      import cycle.
+ *    - RemotePairFavoritesView (extends ViewPane): renders the favorites as a simple list.
+ *      Clicking a row or its inline '+' starts a new Sessions terminal rooted at that folder
+ *      via the existing `remotepair.terminalSidebar.openSessionInFolder` command (single open
+ *      contract — never creates terminals directly). Each row also has an inline remove (X).
+ *    - Registration of the Favorites view into the Browser VIEW_CONTAINER, ordered AFTER the
+ *      file tree (mirroring how Outline/Timeline register as sibling views).
+ *
+ *  All logic stays in this RemotePair-owned file (rebase-safety); the only touch elsewhere is
+ *  the single import from files.contribution.ts so this module loads.
+ *--------------------------------------------------------------------------------------------*/
+
+import { localize, localize2 } from '../../../../nls.js';
+import { $, append, clearNode, addDisposableListener, EventType } from '../../../../base/browser/dom.js';
+import { StandardKeyboardEvent } from '../../../../base/browser/keyboardEvent.js';
+import { KeyCode } from '../../../../base/common/keyCodes.js';
+import { Emitter, Event } from '../../../../base/common/event.js';
+import { Disposable, DisposableStore } from '../../../../base/common/lifecycle.js';
+import { URI } from '../../../../base/common/uri.js';
+import { basename } from '../../../../base/common/resources.js';
+import { Codicon } from '../../../../base/common/codicons.js';
+import { SyncDescriptor } from '../../../../platform/instantiation/common/descriptors.js';
+import { IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';
+import { IThemeService } from '../../../../platform/theme/common/themeService.js';
+import { IConfigurationService } from '../../../../platform/configuration/common/configuration.js';
+import { IStorageService, StorageScope, StorageTarget } from '../../../../platform/storage/common/storage.js';
+import { IContextKeyService } from '../../../../platform/contextkey/common/contextkey.js';
+import { IKeybindingService } from '../../../../platform/keybinding/common/keybinding.js';
+import { IContextMenuService } from '../../../../platform/contextview/browser/contextView.js';
+import { IOpenerService } from '../../../../platform/opener/common/opener.js';
+import { IHoverService } from '../../../../platform/hover/browser/hover.js';
+import { ICommandService } from '../../../../platform/commands/common/commands.js';
+import { Registry } from '../../../../platform/registry/common/platform.js';
+import { ViewPane, IViewPaneOptions } from '../../../browser/parts/views/viewPane.js';
+import { IViewDescriptor, IViewDescriptorService, IViewsRegistry, Extensions as ViewContainerExtensions } from '../../../common/views.js';
+import { registerWorkbenchContribution2, WorkbenchPhase } from '../../../common/contributions.js';
+import { VIEW_CONTAINER } from './explorerViewlet.js';
+// RemotePair workbench logger (docs/logging.md §8). Sibling contrib dir: files/browser -> terminal/browser.
+// rpLog is a safe no-op until configureRemotePairLog() is wired by a consumer; never throws.
+import { rpLog } from '../../terminal/browser/remotePairLog.js';
+
+// --- store ------------------------------------------------------------------
+
+const FAVORITES_STORAGE_KEY = 'remotepair.browser.favorites';
+export const REMOTEPAIR_FAVORITES_VIEW_ID = 'remotepair.browser.favorites';
+
+/**
+ * Persists favorite folder URIs via IStorageService across BOTH the WORKSPACE and PROFILE
+ * (global) scopes. `getFavorites()` returns the de-duplicated union of both scopes so a folder
+ * favorited in any workspace is visible everywhere; writes update both scopes so the entry both
+ * survives reload in this workspace and follows the user across workspaces.
+ */
+export class RemotePairFavoritesStore extends Disposable {
+
+	private readonly _onDidChangeFavorites = this._register(new Emitter<void>());
+	readonly onDidChangeFavorites: Event<void> = this._onDidChangeFavorites.event;
+
+	// >0 while THIS store is performing its own multi-scope write (add/removeFavorite). storage's
+	// onDidChangeValue fires synchronously on same-window writes, so without this guard a single
+	// toggle that writes WORKSPACE+PROFILE would fire onDidChangeFavorites up to 3x (one per scope
+	// write + one explicit). We suppress the storage-listener fires during our own writes and emit
+	// exactly once at the end; cross-window storage changes (flag === 0) still fire normally.
+	private _selfWriteDepth = 0;
+
+	constructor(private readonly storageService: IStorageService) {
+		super();
+		// React to writes made in another window/scope so the view stays in sync.
+		// RemotePair: `this._store` is the protected DisposableStore inherited from Disposable
+		// (lifecycle.ts) — the same store this._register() adds to. It is the required 3rd
+		// `disposable` arg of onDidChangeValue (it scopes the Event.filter wrapper); the listener
+		// subscription itself is scoped via this._register(...). This matches the canonical
+		// onDidChangeValue usage elsewhere in the workbench (e.g. agentSessionsFilter.ts).
+		const onStorageChange = () => { if (this._selfWriteDepth === 0) { this._onDidChangeFavorites.fire(); } };
+		this._register(this.storageService.onDidChangeValue(StorageScope.WORKSPACE, FAVORITES_STORAGE_KEY, this._store)(onStorageChange));
+		this._register(this.storageService.onDidChangeValue(StorageScope.PROFILE, FAVORITES_STORAGE_KEY, this._store)(onStorageChange));
+	}
+
+	private readScope(scope: StorageScope.WORKSPACE | StorageScope.PROFILE): string[] {
+		const raw = this.storageService.get(FAVORITES_STORAGE_KEY, scope);
+		if (!raw) {
+			return [];
+		}
+		try {
+			const parsed = JSON.parse(raw);
+			return Array.isArray(parsed) ? parsed.filter((s): s is string => typeof s === 'string') : [];
+		} catch (err) {
+			// Corrupt persisted JSON for this scope -> the whole scope's favorites are unreadable.
+			// Best-effort: log and recover as empty (never throw; the store stays usable).
+			rpLog('error', `favorites: failed to parse persisted ${scope === StorageScope.WORKSPACE ? 'workspace' : 'profile'}-scope favorites; treating as empty: ${err instanceof Error ? err.message : String(err)}`);
+			return [];
+		}
+	}
+
+	private writeScope(scope: StorageScope.WORKSPACE | StorageScope.PROFILE, list: string[]): void {
+		this.storageService.store(FAVORITES_STORAGE_KEY, JSON.stringify(list), scope, StorageTarget.USER);
+	}
+
+	/** De-duplicated union of WORKSPACE + PROFILE favorites, in stable (workspace-first) order. */
+	getFavorites(): URI[] {
+		const seen = new Set<string>();
+		const out: URI[] = [];
+		for (const s of [...this.readScope(StorageScope.WORKSPACE), ...this.readScope(StorageScope.PROFILE)]) {
+			if (seen.has(s)) {
+				continue;
+			}
+			seen.add(s);
+			try {
+				out.push(URI.parse(s));
+			} catch (err) {
+				// Skip a single malformed persisted entry (best-effort; the rest still load).
+				rpLog('warn', `favorites: skipping malformed persisted favorite entry: ${err instanceof Error ? err.message : String(err)}`);
+			}
+		}
+		return out;
+	}
+
+	isFavorite(uri: URI): boolean {
+		const key = uri.toString();
+		return this.getFavorites().some(f => f.toString() === key);
+	}
+
+	addFavorite(uri: URI): void {
+		const key = uri.toString();
+		let changed = false;
+		// Suppress the synchronous per-scope storage-change fires; emit once below (see _selfWriteDepth).
+		this._selfWriteDepth++;
+		try {
+			for (const scope of [StorageScope.WORKSPACE, StorageScope.PROFILE] as const) {
+				const list = this.readScope(scope);
+				if (!list.includes(key)) {
+					list.push(key);
+					this.writeScope(scope, list);
+					changed = true;
+				}
+			}
+		} finally {
+			this._selfWriteDepth--;
+		}
+		if (changed) {
+			this._onDidChangeFavorites.fire();
+		}
+	}
+
+	removeFavorite(uri: URI): void {
+		const key = uri.toString();
+		let changed = false;
+		// Suppress the synchronous per-scope storage-change fires; emit once below (see _selfWriteDepth).
+		this._selfWriteDepth++;
+		try {
+			for (const scope of [StorageScope.WORKSPACE, StorageScope.PROFILE] as const) {
+				const list = this.readScope(scope);
+				const next = list.filter(s => s !== key);
+				if (next.length !== list.length) {
+					this.writeScope(scope, next);
+					changed = true;
+				}
+			}
+		} finally {
+			this._selfWriteDepth--;
+		}
+		if (changed) {
+			this._onDidChangeFavorites.fire();
+		}
+	}
+
+	toggleFavorite(uri: URI): void {
+		if (this.isFavorite(uri)) {
+			this.removeFavorite(uri);
+		} else {
+			this.addFavorite(uri);
+		}
+	}
+}
+
+// --- module-level accessor (mirrors setSessionLauncher / setAttachedSessionsProvider) --------
+
+let _store: RemotePairFavoritesStore | undefined;
+
+/** Register the singleton store (set eagerly by the workbench contribution below). */
+export function setFavoritesStore(store: RemotePairFavoritesStore): void { _store = store; }
+
+/** Accessor for C3's per-folder star (toggleFavorite / isFavorite) — no hard import cycle. */
+export function favoritesStore(): RemotePairFavoritesStore | undefined { return _store; }
+
+// --- eager store lifecycle --------------------------------------------------
+//
+// The store USED to be created in RemotePairFavoritesView's constructor. But that view is
+// registered with `collapsed: true` and is constructed lazily (only when first rendered/expanded),
+// so on a session where the user never opens Favorites, favoritesStore() stayed undefined — making
+// the C3 per-folder star a silent no-op (toggleFavorite()?. short-circuits) and the icon never
+// reflecting favorite state. We now create the store EAGERLY in a tiny IWorkbenchContribution at
+// startup and publish it via setFavoritesStore; the Favorites view USES this singleton rather than
+// owning it. Both the star and the view share one store instance.
+
+/**
+ * Eagerly creates the singleton RemotePairFavoritesStore at workbench startup and publishes it via
+ * setFavoritesStore, so C3's per-folder star can toggle/read favorites even if the (collapsed)
+ * Favorites view is never opened. Registered with registerWorkbenchContribution2 below.
+ */
+export class RemotePairFavoritesStoreContribution extends Disposable {
+	static readonly ID = 'workbench.contrib.remotePairFavoritesStore';
+
+	constructor(@IStorageService storageService: IStorageService) {
+		super();
+		setFavoritesStore(this._register(new RemotePairFavoritesStore(storageService)));
+		// Lifecycle: eager singleton store published at BlockStartup so C3's per-folder star works
+		// even if the (collapsed) Favorites view is never opened.
+		rpLog('info', 'favorites: store published at startup (eager singleton)');
+	}
+}
+
+// --- view -------------------------------------------------------------------
+
+/**
+ * Favorites ViewPane: renders favorite folders as a simple list. Each row is label + an inline
+ * '+' (start a new Sessions terminal rooted there) + an inline remove (X / unfavorite). Clicking
+ * the row itself also starts a session. Sessions are opened ONLY through the existing
+ * `remotepair.terminalSidebar.openSessionInFolder` command (single open contract).
+ */
+export class RemotePairFavoritesView extends ViewPane {
+
+	private list: HTMLElement | undefined;
+	private readonly store: RemotePairFavoritesStore;
+	// Per-render row listener store, cleared at the top of each render so listeners do not
+	// accumulate across re-renders.
+	private readonly rowDisposables = this._register(new DisposableStore());
+
+	constructor(
+		options: IViewPaneOptions,
+		@IKeybindingService keybindingService: IKeybindingService,
+		@IContextMenuService contextMenuService: IContextMenuService,
+		@IConfigurationService configurationService: IConfigurationService,
+		@IContextKeyService contextKeyService: IContextKeyService,
+		@IViewDescriptorService viewDescriptorService: IViewDescriptorService,
+		@IInstantiationService instantiationService: IInstantiationService,
+		@IOpenerService openerService: IOpenerService,
+		@IThemeService themeService: IThemeService,
+		@IHoverService hoverService: IHoverService,
+		@IStorageService storageService: IStorageService,
+		@ICommandService private readonly commandService: ICommandService
+	) {
+		super(options, keybindingService, contextMenuService, configurationService, contextKeyService, viewDescriptorService, instantiationService, openerService, themeService, hoverService);
+		// USE the eagerly-created singleton store (RemotePairFavoritesStoreContribution) so the view
+		// and C3's per-folder star share one instance. Fall back to creating + publishing one only if
+		// the contribution somehow has not run yet (defensive; should not happen in practice).
+		let store = favoritesStore();
+		if (!store) {
+			store = this._register(new RemotePairFavoritesStore(storageService));
+			setFavoritesStore(store);
+		}
+		this.store = store;
+	}
+
+	protected override renderBody(container: HTMLElement): void {
+		super.renderBody(container);
+		container.classList.add('remotepair-favorites');
+		this.list = append(container, $('.remotepair-favorites-list'));
+		this._register(this.store.onDidChangeFavorites(() => this.refresh()));
+		this.refresh();
+	}
+
+	private refresh(): void {
+		const list = this.list;
+		if (!list) {
+			return;
+		}
+		this.rowDisposables.clear();
+		clearNode(list);
+
+		const favorites = this.store.getFavorites();
+		if (favorites.length === 0) {
+			const empty = append(list, $('.remotepair-favorites-empty'));
+			empty.textContent = localize('remotepairFavoritesEmpty', "Star a folder to add it here.");
+			return;
+		}
+
+		for (const uri of favorites) {
+			this.addRow(uri);
+		}
+	}
+
+	/** Append one favorite row: label + inline '+' (new session) + inline remove (X). */
+	private addRow(uri: URI): void {
+		const list = this.list!;
+		const row = append(list, $('.remotepair-favorites-row'));
+		const text = basename(uri) || uri.fsPath || uri.toString();
+		row.title = uri.fsPath || uri.toString();
+		row.setAttribute('role', 'button');
+		row.setAttribute('tabindex', '0');
+
+		const label = append(row, $('.remotepair-favorites-label'));
+		label.textContent = text;
+
+		const actions = append(row, $('.remotepair-favorites-actions'));
+
+		const add = append(actions, $('.remotepair-favorites-action.codicon.codicon-' + Codicon.add.id));
+		add.title = localize('remotepairFavoritesNewSession', "New Session Here");
+		add.setAttribute('role', 'button');
+		add.setAttribute('tabindex', '0');
+
+		const remove = append(actions, $('.remotepair-favorites-action.codicon.codicon-' + Codicon.close.id));
+		remove.title = localize('remotepairFavoritesRemove', "Remove from Favorites");
+		remove.setAttribute('role', 'button');
+		remove.setAttribute('tabindex', '0');
+
+		const openSession = () => this.commandService.executeCommand('remotepair.terminalSidebar.openSessionInFolder', uri);
+
+		// Clicking the row or '+' starts a new Sessions terminal rooted at this folder.
+		this.rowDisposables.add(addDisposableListener(row, EventType.CLICK, openSession));
+		this.rowDisposables.add(addDisposableListener(row, EventType.KEY_DOWN, (e) => {
+			const k = new StandardKeyboardEvent(e as KeyboardEvent);
+			if (k.equals(KeyCode.Enter) || k.equals(KeyCode.Space)) { k.preventDefault(); openSession(); }
+		}));
+		// '+' opens a new session via the same single open contract.
+		this.rowDisposables.add(addDisposableListener(add, EventType.CLICK, (e) => {
+			e.stopPropagation();
+			openSession();
+		}));
+		// 'X' unfavorites; stopPropagation so it does not also fire the row's open-session click.
+		this.rowDisposables.add(addDisposableListener(remove, EventType.CLICK, (e) => {
+			e.stopPropagation();
+			this.store.removeFavorite(uri);
+		}));
+	}
+}
+
+// --- registration: Favorites view at the bottom of the Browser VIEW_CONTAINER ----------------
+
+const viewsRegistry = Registry.as<IViewsRegistry>(ViewContainerExtensions.ViewsRegistry);
+
+/** localize2 first arg MUST be a static string literal (dynamic NLS keys break the prod build). */
+const favoritesViewDescriptor: IViewDescriptor = {
+	id: REMOTEPAIR_FAVORITES_VIEW_ID,
+	name: localize2('remotepairFavorites', "Favorites"),
+	ctorDescriptor: new SyncDescriptor(RemotePairFavoritesView),
+	// Order AFTER the file tree (VIEW_ID order:1, OpenEditors order:0) so it sits at the bottom
+	// like Outline/Timeline.
+	order: 100,
+	canToggleVisibility: true,
+	canMoveView: true,
+	collapsed: true,
+};
+
+viewsRegistry.registerViews([favoritesViewDescriptor], VIEW_CONTAINER);
+
+// Create the Favorites store eagerly at startup so the C3 per-folder star works even when the
+// collapsed Favorites view is never opened (BlockStartup: before any view is constructed).
+registerWorkbenchContribution2(RemotePairFavoritesStoreContribution.ID, RemotePairFavoritesStoreContribution, WorkbenchPhase.BlockStartup);
