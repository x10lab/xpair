+		// G004: supply the Session Manager's Attached row with the sidebar's own terminal
+		// set. These instances bypass ITerminalService (S0 isolation), so we source them here.
+		setAttachedSessionsProvider({
+			getAttached: () => [...this.attached.values()].map(v => ({
+				id: v.instance.resource.toString(),
+				title: v.instance.title || 'Session',
+			})),
+			reveal: (id) => {
+				const v = this.attached.get(id);
+				if (v) {
+					v.group.openEditor(v.input, { pinned: true }).then(undefined, (e) => { rpLog('warn', `reveal: openEditor failed for attached session id=${id}: ${e}`); /* best-effort */ });
+					v.instance.focus(true);
+				}
+			},
+			// Close (dispose) the attached session — the instance's onDisposed handler removes it
+			// from `this.attached` and notifies the Attached row. Public dispose() only.
+			close: (id) => {
+				const v = this.attached.get(id);
+				if (v) {
+					try { v.instance.dispose(); } catch (e) { rpLog('warn', `close: instance.dispose threw for attached session id=${id}: ${e}`); /* best-effort */ }
+				}
+			},
+			// Best-effort: the embedded part's active group's active terminal editor → its resource
+			// string, which is the same id used as the attached-map key. undefined when unknown.
+			getActiveId: () => {
+				const input = this.editorPart?.activeGroup?.activeEditor;
+				const instance = input instanceof TerminalEditorInput ? input.terminalInstance : undefined;
+				return instance?.resource.toString();
+			},
+		});
+	}
+
+	/**
+	 * Open a session of `kind` inside the picker's own `group`, then close the picker
+	 * tab. Hosting-layer only: creates a terminal editor in the embedded group and, for
+	 * non-shell kinds, sends the launch command via the terminal's public sendText API.
+	 * Core terminal behavior is untouched.
+	 */
+	private launchSession(kind: SessionKind, group: IEditorGroup, pickerInput: EditorInput): void {
+		try {
+			const { instance, opened } = this.openTerminalInGroup(group);
+			opened.then(() => {
+				if (kind !== 'shell') {
+					// claude → remote-pair launcher (mosh+tmux+claude); codex/gemini → their CLI.
+					const cmd = kind === 'claude' ? 'remote-pair launch' : kind;
+					instance.sendText(cmd, true);
+				}
+				group.closeEditor(pickerInput).then(undefined, (e) => { rpLog('warn', `launchSession(${kind}): closeEditor(picker) failed: ${e}`); /* best-effort */ });
+			}, (e) => { rpLog('warn', `launchSession(${kind}): terminal open rejected: ${e}`); /* best-effort */ });
+		} catch (e) {
+			rpLog('error', `launchSession(${kind}): openTerminalInGroup threw: ${e}`); // best-effort
+		}
+	}
+
+	/**
+	 * G004: reattach a session by name into the embedded EditorPart group. Reuses the same
+	 * terminal-open path as launchSession and sends `remote-pair attach <name>` via the
+	 * terminal's public sendText API. Hosting-layer only — core terminal behavior untouched.
+	 */
+	private launchReattach(name: string): void {
+		const part = this.editorPart;
+		if (!part) {
+			return;
+		}
+		part.whenReady.then(() => {
+			if (this.editorPart !== part) {
+				return;
+			}
+			const group = part.activeGroup;
+			if (!group) {
+				return;
+			}
+			try {
+				const { instance, opened } = this.openTerminalInGroup(group);
+				opened.then(() => {
+					instance.sendText('remote-pair attach ' + name, true);
+				}, (e) => { rpLog('warn', `launchReattach(${name}): terminal open rejected: ${e}`); /* best-effort */ });
+			} catch (e) {
+				rpLog('error', `launchReattach(${name}): openTerminalInGroup threw: ${e}`); // best-effort
+			}
+		}, () => { /* part disposed */ });
+	}
+
+	/**
+	 * Shared terminal-open path: create a terminal editor in `group`, record it in the
+	 * `attached` map, and notify the Session Manager's Attached row. Both launchSession and
+	 * launchReattach use this so terminal-creation logic is not duplicated. Public services only.
+	 */
