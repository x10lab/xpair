+			// Record only after the editor is open so `group` is live.
+			this.attached.set(key, { instance, input, group });
+			notifyAttachedSessionsChanged();
+		}, (e) => {
+			// Open failed: tear down the orphaned instance + its listeners (don't strand it).
+			this.partDisposables.delete(store);
