+/*---------------------------------------------------------------------------------------------
+ *  RemotePair workbench logger (comp tag `workbench`).
+ *
+ *  This is the workbench (RENDERER process) logger named in docs/logging.md §8:
+ *    | workbench | client/ide/.../remotePairLog.ts | ILogService primary + mirror appender to
+ *      workbench.log using the SAME formatter |
+ *
+ *  It produces the unified RemotePair log line (docs/logging.md §3):
+ *
+ *      [<ISO-8601 ts>] [<LEVEL>] [workbench] [<session ?? '-'>] <message>
+ *
+ *  and routes it to ILogService.{trace,debug,info,warn,error} (the same DI service used by
+ *  remotePairBrowserRouter.ts), which persists to the workbench's user-data-dir/logs/.
+ *
+ *  ~/.remote-pair/logs/workbench.log MIRROR — FEASIBLE (and implemented here).
+ *  ---------------------------------------------------------------------------
+ *  The renderer is sandboxed and has NO direct Node `fs` (and this file deliberately imports
+ *  none). HOWEVER, the desktop workbench renderer registers an IPC-backed DiskFileSystemProvider
+ *  for the `file://` scheme (workbench/electron-browser/desktop.main.ts:259-260 ->
+ *  workbench/services/files/electron-browser/diskFileSystemProvider.ts, which proxies disk ops to
+ *  the main/utility process). That means IFileService can write ARBITRARY `file://` paths from the
+ *  renderer WITHOUT Node fs in this layer. So we mirror the exact same formatted line to
+ *  ~/.remote-pair/logs/workbench.log via IFileService:
+ *    - home dir resolved from IPathService.userHome({ preferLocal: true }) (a local file:// URI on
+ *      desktop), then joined to .remote-pair/logs/workbench.log;
+ *    - the logs dir is created with IFileService.createFolder (idempotent `mkdir -p`);
+ *    - each record is appended with writeFile(uri, buf, { append: true }) when the provider has the
+ *      FileAppend capability, else falls back to read+concat+write.
+ *
+ *  GRACEFUL DEGRADATION (the limitation, scoped): the mirror is BEST-EFFORT and OPT-IN. If
+ *  IFileService / IPathService are not supplied (e.g. a non-desktop/web build where no local
+ *  file:// disk provider is registered, or a caller that only wires ILogService), this logger
+ *  falls back to ILogService-ONLY — which still persists to user-data-dir/logs/. The mirror also
+ *  silently no-ops (never throws into caller UI code) if the file:// provider is absent, lacks
+ *  capabilities, or any write fails; failures are reported once to ILogService. We do NOT implement
+ *  §7 rotation/flock here: ILogService owns rotation for its own sink, and the renderer cannot take
+ *  the cross-process advisory lock that §7 requires for the multi-writer files — the
+ *  ~/.remote-pair/workbench.log mirror is single-writer (one renderer per window) and unbounded
+ *  growth is bounded in practice by INFO-default volume; hardening (size-check rotate) is a
+ *  follow-up if this file proves hot.
+ *--------------------------------------------------------------------------------------------*/
+
+import { VSBuffer } from '../../../../base/common/buffer.js';
+import { URI } from '../../../../base/common/uri.js';
+import { FileSystemProviderCapabilities, IFileService } from '../../../../platform/files/common/files.js';
+import { ILogService } from '../../../../platform/log/common/log.js';
+import { IPathService } from '../../../services/path/common/pathService.js';
+
+/** docs/logging.md §3 comp tag for the workbench renderer. */
+const COMP = 'workbench';
+
+export type RemotePairLogLevel = 'trace' | 'debug' | 'info' | 'warn' | 'error';
+
+/**
+ * Optional sinks for the workbench logger. `logService` is required for any output. The mirror to
+ * ~/.remote-pair/logs/workbench.log only runs when BOTH `fileService` and `pathService` are
+ * supplied AND a local file:// disk provider is available (desktop). Wire these from a consumer's
+ * DI constructor, e.g.:
+ *
+ *     constructor(..., @ILogService logService: ILogService,
+ *                      @IFileService fileService: IFileService,
+ *                      @IPathService pathService: IPathService) {
+ *         configureRemotePairLog({ logService, fileService, pathService });
+ *     }
+ */
+export interface IRemotePairLogSinks {
+	readonly logService: ILogService;
+	readonly fileService?: IFileService;
+	readonly pathService?: IPathService;
+}
+
+let sinks: IRemotePairLogSinks | undefined;
+
+/** Memoized ~/.remote-pair/logs/workbench.log file URI + its parent dir (resolved on first use). */
+let mirrorFileUri: URI | undefined;
+let mirrorDirUri: URI | undefined;
+/** Serialize mirror writes so concurrent rpLog() calls append in order and don't race create/write. */
+let mirrorChain: Promise<void> = Promise.resolve();
+/** Latches so we report a given mirror failure class to ILogService at most once (avoid log spam). */
+let mirrorDirEnsured = false;
+let mirrorReportedUnavailable = false;
+let mirrorReportedWriteError = false;
+
+/**
+ * Install the logger's sinks. Idempotent and safe to call from multiple consumer constructors; the
+ * last call wins (all consumers in one renderer share the same ILogService/IFileService singletons,
+ * so this is effectively a no-op re-bind). Without this, rpLog() is a safe no-op.
+ */
+export function configureRemotePairLog(next: IRemotePairLogSinks): void {
+	sinks = next;
+}
+
+/** Local-tz ISO-8601 with offset, second precision — matches docs/logging.md §3 (e.g. 2026-06-15T10:45:16+0900). */
+function isoTimestamp(d: Date = new Date()): string {
+	const pad = (n: number, w = 2) => String(Math.floor(Math.abs(n))).padStart(w, '0');
+	const offMin = -d.getTimezoneOffset(); // getTimezoneOffset is minutes BEHIND UTC, so negate.
+	const sign = offMin >= 0 ? '+' : '-';
+	return (
+		`${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}` +
+		`T${pad(d.getHours())}:${pad(d.getMinutes())}:${pad(d.getSeconds())}` +
+		`${sign}${pad(offMin / 60)}${pad(offMin % 60)}`
+	);
+}
+
+/** Build the canonical unified line (docs/logging.md §3). Single logical line: collapse newlines. */
+function formatLine(level: RemotePairLogLevel, msg: string, session: string | undefined): string {
+	const sess = session && session.length > 0 ? session : '-';
+	const oneLine = msg.replace(/\r?\n/g, ' ');
+	return `[${isoTimestamp()}] [${level.toUpperCase()}] [${COMP}] [${sess}] ${oneLine}`;
+}
+
+/**
+ * Primary RemotePair workbench log entry point.
+ *
+ *   rpLog('info', 'session attached', 'proj-main@1718430000')
+ *
+ * Routes the unified-format line to ILogService at the matching level, and best-effort mirrors the
+ * identical line to ~/.remote-pair/logs/workbench.log when the file sinks are wired. Safe no-op if
+ * configureRemotePairLog() has not been called. Never throws.
+ */
+export function rpLog(level: RemotePairLogLevel, msg: string, session?: string): void {
+	const s = sinks;
+	if (!s) {
+		return;
+	}
+	const line = formatLine(level, msg, session);
+
+	// 1) ILogService primary sink. Level threshold/rotation are owned by ILogService.
+	try {
+		switch (level) {
+			case 'trace': s.logService.trace(line); break;
+			case 'debug': s.logService.debug(line); break;
+			case 'info': s.logService.info(line); break;
+			case 'warn': s.logService.warn(line); break;
+			case 'error': s.logService.error(line); break;
+		}
+	} catch {
+		// ILogService should never throw; swallow to protect caller UI code regardless.
+	}
+
+	// 2) Best-effort ~/.remote-pair/logs/workbench.log mirror (desktop only; opt-in via sinks).
+	if (s.fileService && s.pathService) {
+		void mirrorAppend(s.logService, s.fileService, s.pathService, line);
+	}
+}
+
+/** Resolve (and memoize) the ~/.remote-pair/logs dir + workbench.log file URIs from userHome. */
+function resolveMirrorUris(pathService: IPathService): { dir: URI; file: URI } | undefined {
+	if (mirrorFileUri && mirrorDirUri) {
+		return { dir: mirrorDirUri, file: mirrorFileUri };
+	}
+	// preferLocal:true returns the LOCAL file:// home synchronously on desktop (NativePathService).
+	const home = pathService.userHome({ preferLocal: true });
+	if (!home || home.scheme !== 'file') {
+		return undefined; // No local file home (e.g. web/remote) -> mirror not applicable.
+	}
+	mirrorDirUri = URI.joinPath(home, '.remote-pair', 'logs');
+	mirrorFileUri = URI.joinPath(mirrorDirUri, 'workbench.log');
+	return { dir: mirrorDirUri, file: mirrorFileUri };
+}
+
+/**
+ * Append one line to the mirror file. Chained so calls serialize. Best-effort: any failure is
+ * reported to ILogService at most once and otherwise swallowed (the ILogService sink already has
+ * the record, so the mirror missing is non-fatal).
+ */
+function mirrorAppend(logService: ILogService, fileService: IFileService, pathService: IPathService, line: string): Promise<void> {
+	mirrorChain = mirrorChain.then(async () => {
+		const uris = resolveMirrorUris(pathService);
+		if (!uris) {
+			return;
+		}
+		const { dir, file } = uris;
+
+		// Require a local file:// disk provider in this layer (present on desktop renderer; absent
+		// on web/sandbox-without-IPC). Report once, then give up on the mirror permanently.
+		if (!fileService.hasProvider(file)) {
+			if (!mirrorReportedUnavailable) {
+				mirrorReportedUnavailable = true;
+				logService.info(`[${COMP}] ~/.remote-pair/logs/workbench.log mirror unavailable (no file:// provider); ILogService-only`);
+			}
+			return;
+		}
+
+		try {
+			// Idempotent mkdir -p of the logs dir (once per session unless it later vanishes).
+			if (!mirrorDirEnsured) {
+				if (!(await fileService.exists(dir))) {
+					await fileService.createFolder(dir);
+				}
+				mirrorDirEnsured = true;
+			}
+
+			const payload = VSBuffer.fromString(line + '\n');
+			if (fileService.hasCapability(file, FileSystemProviderCapabilities.FileAppend)) {
+				// Atomic-ish append (single provider write) when supported.
+				await fileService.writeFile(file, payload, { append: true });
+			} else {
+				// Portable fallback: read existing (if any), concat, overwrite.
+				let existing: VSBuffer | undefined;
+				if (await fileService.exists(file)) {
+					existing = (await fileService.readFile(file)).value;
+				}
+				const combined = existing ? VSBuffer.concat([existing, payload]) : payload;
+				await fileService.writeFile(file, combined);
+			}
+		} catch (err) {
+			// Allow re-ensuring the dir on a later attempt (it may have been transiently absent).
+			mirrorDirEnsured = false;
+			if (!mirrorReportedWriteError) {
+				mirrorReportedWriteError = true;
+				logService.warn(`[${COMP}] ~/.remote-pair/logs/workbench.log mirror write failed; ILogService-only`, err);
+			}
+		}
+	}).catch(() => {
+		// Never let the chain reject (would drop subsequent appends); already reported above.
+	});
+	return mirrorChain;
+}
