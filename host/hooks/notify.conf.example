# notify.conf.example — xpair notification configuration example.
# Actual file location: ~/.xpair/host/notify.conf
# Copy this file to use it: cp notify.conf.example ~/.xpair/host/notify.conf

# ENABLED_TYPES: specifies which event types to record to the queue and deliver to the client.
# Comma-separated. Write without spaces.
#
# Possible types:
#   Stop          — when a Claude Code session terminates normally
#   Notification  — notification messages the model sends to the user
#   SubagentStop  — when a subagent terminates
#   approve-wait  — PermissionRequest / permission_prompt (waiting for manual approval)
#   approve       — PermissionDenied / PostToolUseFailure (approval changed/finalized)
#
# Default (all enabled if this line is commented out or the file is missing):
ENABLED_TYPES=Stop,Notification,SubagentStop,approve-wait,approve

# e.g. when you only want notifications for Stop and approval waits/changes:
# ENABLED_TYPES=Stop,approve-wait,approve

# e.g. turn off all notifications (empty value):
# ENABLED_TYPES=
