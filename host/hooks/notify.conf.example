# notify.conf.example — remote-pair notification configuration example.
# Actual file location: ~/.remote-pair/notify.conf
# Copy this file to use it: cp notify.conf.example ~/.remote-pair/notify.conf

# ENABLED_TYPES: specifies which event types to record to the queue and deliver to the client.
# Comma-separated. Write without spaces.
#
# Possible types:
#   Stop          — when a Claude Code session terminates normally
#   Notification  — notification messages the model sends to the user
#   SubagentStop  — when a subagent terminates
#   approve       — PermissionDenied / PostToolUseFailure (awaiting GUI approval)
#
# Default (all enabled if this line is commented out or the file is missing):
ENABLED_TYPES=Stop,Notification,SubagentStop,approve

# e.g. when you only want notifications for Stop and approve:
# ENABLED_TYPES=Stop,approve

# e.g. turn off all notifications (empty value):
# ENABLED_TYPES=
